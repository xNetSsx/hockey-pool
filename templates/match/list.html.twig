{% extends 'base.html.twig' %}

{% block title %}Zápasy — {{ tournament.name }}{% endblock %}

{% block body %}
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">🏒 Program zápasů</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{{ tournament.name }}</p>
    </div>

    {% for phaseValue, games in groupedGames %}
        {# Phase header #}
        <div class="mb-4 mt-8 first:mt-0">
            <h2 class="inline-block rounded-lg bg-[#0f172a] px-4 py-2 text-sm font-semibold uppercase tracking-wider text-white">
                {{ phaseValue|phase_label }}
            </h2>
        </div>

        <div class="mb-6 overflow-hidden rounded-xl bg-white shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
            <div class="divide-y divide-gray-100 dark:divide-gray-700">
                {% set lastDate = null %}
                {% for game in games %}
                    {% set gameDate = game.playedAt|date('Y-m-d') %}
                    {% set prediction = userPredictions[game.id] ?? null %}

                    {# Date separator #}
                    {% if gameDate != lastDate %}
                        <div class="bg-gray-50 px-6 py-2 dark:bg-[#0f172a]/50">
                            <span class="text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">
                                {{ game.playedAt|date('d.m.Y') }}
                            </span>
                        </div>
                        {% set lastDate = gameDate %}
                    {% endif %}

                    <a href="{{ path('match_detail', {id: game.id}) }}" class="flex items-center gap-4 px-6 py-3 transition hover:bg-gray-50 dark:hover:bg-white/5 dark:text-gray-100">
                        {# Time #}
                        <div class="w-12 shrink-0 text-center text-xs text-gray-400 dark:text-gray-500">
                            {{ game.playedAt|date('H:i') }}
                        </div>

                        {# Teams + Score #}
                        <div class="flex min-w-0 flex-1 items-center gap-3">
                            {# Home team #}
                            <div class="flex w-24 items-center justify-end gap-1.5 text-sm sm:w-32">
                                <span class="truncate font-medium">{{ game.homeTeam.code }}</span>
                                <span>{{ team_flag(game.homeTeam.code) }}</span>
                            </div>

                            {# Score #}
                            <div class="w-16 text-center">
                                {% if game.isFinished %}
                                    <span class="rounded bg-[#0f172a] px-2.5 py-1 text-sm font-bold tabular-nums text-white">
                                        {{ game.homeScore }}:{{ game.awayScore }}
                                    </span>
                                {% else %}
                                    <span class="rounded bg-gray-200 px-2.5 py-1 text-xs font-medium text-gray-500 dark:bg-gray-700 dark:text-gray-400">
                                        TBD
                                    </span>
                                {% endif %}
                            </div>

                            {# Away team #}
                            <div class="flex w-24 items-center gap-1.5 text-sm sm:w-32">
                                <span>{{ team_flag(game.awayTeam.code) }}</span>
                                <span class="truncate font-medium">{{ game.awayTeam.code }}</span>
                            </div>
                        </div>

                        {# User's prediction #}
                        <div class="w-28 shrink-0 text-right sm:w-36">
                            {% if prediction %}
                                {% if game.isFinished %}
                                    {% if prediction.isExactScore(game) %}
                                        {% set predClass = 'bg-amber-100 text-amber-800 border-amber-300 dark:bg-amber-900/30 dark:text-amber-300 dark:border-amber-700' %}
                                    {% elseif prediction.isCorrectWinner(game) %}
                                        {% set predClass = 'bg-green-100 text-green-800 border-green-300 dark:bg-green-900/30 dark:text-green-300 dark:border-green-700' %}
                                    {% else %}
                                        {% set predClass = 'bg-red-100 text-red-800 border-red-300 dark:bg-red-900/30 dark:text-red-300 dark:border-red-700' %}
                                    {% endif %}
                                {% else %}
                                    {% set predClass = 'bg-blue-50 text-blue-700 border-blue-200 dark:bg-blue-900/30 dark:text-blue-300 dark:border-blue-700' %}
                                {% endif %}
                                <span class="inline-block rounded border px-2 py-0.5 text-xs font-medium tabular-nums {{ predClass }}">
                                    Tip: {{ prediction.homeScore }}:{{ prediction.awayScore }}
                                </span>
                            {% else %}
                                <span class="text-xs text-gray-300 dark:text-gray-600">—</span>
                            {% endif %}
                        </div>

                        {# Admin edit link #}
                        {% if is_granted('ROLE_ADMIN') %}
                            <div class="w-8 shrink-0 text-center">
                                <span class="text-gray-300 hover:text-gray-500 dark:text-gray-600 dark:hover:text-gray-400" title="Upravit výsledek">✏️</span>
                            </div>
                        {% endif %}
                    </a>
                {% endfor %}
            </div>
        </div>
    {% endfor %}
{% endblock %}
