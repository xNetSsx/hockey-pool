{% extends 'base.html.twig' %}

{% block title %}Výsledek: {{ game.homeTeam.code }} vs {{ game.awayTeam.code }} — Admin{% endblock %}

{% block body %}
    <div class="mb-6">
        <a href="{{ path('match_detail', {id: game.id}) }}" class="text-sm text-gray-500 hover:text-gray-700">← Zpět na detail zápasu</a>
    </div>

    <div class="mx-auto max-w-lg">
        <div class="overflow-hidden rounded-xl bg-white shadow">
            <div class="bg-[#0f172a] px-6 py-4">
                <h1 class="text-lg font-semibold text-white">Zadat výsledek</h1>
                <p class="mt-1 text-xs text-gray-400">
                    {{ game.phase.value|phase_label }} · {{ game.playedAt|date('d.m.Y H:i') }}
                </p>
            </div>

            <div class="p-6">
                <div class="mb-6 flex items-center justify-center gap-6 text-center">
                    <div>
                        <div>{{ team_flag(game.homeTeam.code, 'inline-block h-8 w-12 rounded-sm') }}</div>
                        <div class="mt-1 text-sm font-bold">{{ game.homeTeam.code }}</div>
                    </div>
                    <div class="text-xl font-bold text-gray-300">vs</div>
                    <div>
                        <div>{{ team_flag(game.awayTeam.code, 'inline-block h-8 w-12 rounded-sm') }}</div>
                        <div class="mt-1 text-sm font-bold">{{ game.awayTeam.code }}</div>
                    </div>
                </div>

                {{ form_start(form, {attr: {class: 'space-y-4'}}) }}
                    <div class="flex items-end justify-center gap-4">
                        <div class="text-center">
                            {{ form_label(form.homeScore, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.homeScore, {attr: {class: 'w-20 rounded-lg border border-gray-300 px-3 py-2 text-center text-lg font-bold focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20'}}) }}
                        </div>
                        <div class="pb-2 text-xl font-bold text-gray-400">:</div>
                        <div class="text-center">
                            {{ form_label(form.awayScore, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.awayScore, {attr: {class: 'w-20 rounded-lg border border-gray-300 px-3 py-2 text-center text-lg font-bold focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20'}}) }}
                        </div>
                    </div>

                    {{ form_errors(form) }}

                    <div class="pt-4 text-center">
                        {{ form_widget(form.save, {attr: {class: 'rounded-lg bg-blue-600 px-6 py-2.5 font-semibold text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2'}}) }}
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
