{% extends 'base.html.twig' %}

{% block title %}{{ game.homeTeam.code }} vs {{ game.awayTeam.code }} — Hockey Pool{% endblock %}

{% block body %}
    <div class="mb-6">
        <a href="{{ path('match_list') }}" class="text-sm text-gray-500 hover:text-gray-700">← Zpět na zápasy</a>
    </div>

    {# Match header #}
    <div class="mb-8 overflow-hidden rounded-2xl bg-[#0f172a] p-6 text-white shadow-xl sm:p-8">
        <div class="mb-2 text-center text-xs uppercase tracking-wider text-gray-400">
            {{ game.phase.value|phase_label }} · {{ game.playedAt|date('d.m.Y H:i') }}
        </div>
        <div class="flex items-center justify-center gap-6 sm:gap-10">
            <div class="text-center">
                <div class="text-3xl">{{ game.homeTeam.flagEmoji }}</div>
                <div class="mt-1 text-lg font-bold">{{ game.homeTeam.code }}</div>
                <div class="text-xs text-gray-400">{{ game.homeTeam.name }}</div>
            </div>
            <div class="text-center">
                {% if game.isFinished %}
                    <div class="text-4xl font-black tabular-nums sm:text-5xl">
                        {{ game.homeScore }}<span class="text-gray-500">:</span>{{ game.awayScore }}
                    </div>
                    {% if game.winner %}
                        <div class="mt-1 text-xs text-[#38bdf8]">
                            Vítěz: {{ game.winner.flagEmoji }} {{ game.winner.code }}
                        </div>
                    {% else %}
                        <div class="mt-1 text-xs text-gray-400">Remíza</div>
                    {% endif %}
                {% else %}
                    <div class="text-2xl font-bold text-gray-500">vs</div>
                    <div class="mt-1 text-xs text-gray-400">Dosud neodehráno</div>
                {% endif %}
            </div>
            <div class="text-center">
                <div class="text-3xl">{{ game.awayTeam.flagEmoji }}</div>
                <div class="mt-1 text-lg font-bold">{{ game.awayTeam.code }}</div>
                <div class="text-xs text-gray-400">{{ game.awayTeam.name }}</div>
            </div>
        </div>

        {% if is_granted('ROLE_ADMIN') %}
            <div class="mt-4 text-center">
                <a href="{{ path('admin_match_result', {id: game.id}) }}"
                   class="inline-block rounded bg-white/10 px-4 py-1.5 text-xs font-medium text-white hover:bg-white/20">
                    ✏️ Upravit výsledek
                </a>
            </div>
        {% endif %}
    </div>

    {# Predictions breakdown #}
    {% if breakdown|length > 0 %}
        <div class="overflow-hidden rounded-xl bg-white shadow">
            <div class="border-b border-gray-200 bg-[#0f172a] px-6 py-4">
                <h2 class="text-lg font-semibold text-white">Tipy hráčů</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-100 bg-gray-50 text-left text-xs uppercase tracking-wider text-gray-500">
                            <th class="px-6 py-3">Hráč</th>
                            <th class="px-6 py-3 text-center">Tip</th>
                            <th class="px-6 py-3 text-center">Výsledek</th>
                            <th class="px-6 py-3 text-right">Základ</th>
                            <th class="px-6 py-3 text-right">Bonus</th>
                            <th class="px-6 py-3 text-right">Přesný</th>
                            <th class="px-6 py-3 text-right font-semibold">Celkem</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in breakdown %}
                            {% set isCurrentUser = app.user and app.user.id == row.user.id %}
                            <tr class="{{ isCurrentUser ? 'bg-[#38bdf8]/10 font-semibold' : (loop.index is odd ? 'bg-white' : 'bg-gray-50') }} border-b border-gray-100 last:border-0">
                                <td class="px-6 py-3">
                                    {{ row.user.username }}
                                    {% if isCurrentUser %}
                                        <span class="ml-1 text-xs text-[#38bdf8]">← ty</span>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-3 text-center">
                                    {% if row.prediction %}
                                        <span class="tabular-nums font-medium">
                                            {{ row.prediction.homeScore }}:{{ row.prediction.awayScore }}
                                        </span>
                                    {% else %}
                                        <span class="text-gray-300">—</span>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-3 text-center">
                                    {% if game.isFinished %}
                                        {% if row.exactScore %}
                                            <span class="inline-block rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-semibold text-amber-800">🎯 Přesný</span>
                                        {% elseif row.correctWinner %}
                                            <span class="inline-block rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-semibold text-green-800">✓ Vítěz</span>
                                        {% else %}
                                            <span class="inline-block rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-semibold text-red-800">✗ Špatně</span>
                                        {% endif %}
                                    {% endif %}
                                </td>
                                <td class="px-6 py-3 text-right tabular-nums {{ row.basePoints > 0 ? 'text-green-700' : 'text-gray-300' }}">
                                    {{ row.basePoints > 0 ? row.basePoints|number_format(2) : '—' }}
                                </td>
                                <td class="px-6 py-3 text-right tabular-nums {{ row.opponentBonus > 0 ? 'text-blue-700' : 'text-gray-300' }}">
                                    {{ row.opponentBonus > 0 ? '+' ~ row.opponentBonus|number_format(2) : '—' }}
                                </td>
                                <td class="px-6 py-3 text-right tabular-nums {{ row.exactBonus > 0 ? 'text-amber-700' : 'text-gray-300' }}">
                                    {{ row.exactBonus > 0 ? '+' ~ row.exactBonus|number_format(2) : '—' }}
                                </td>
                                <td class="px-6 py-3 text-right tabular-nums font-bold {{ row.totalPoints > 0 ? '' : 'text-gray-300' }}">
                                    {{ row.totalPoints > 0 ? row.totalPoints|number_format(2) : '0.00' }}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% else %}
        <div class="rounded-xl bg-white p-8 text-center shadow">
            <p class="text-gray-500">Zatím žádné tipy pro tento zápas.</p>
        </div>
    {% endif %}
{% endblock %}
