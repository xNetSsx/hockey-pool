{% extends 'base.html.twig' %}
{% from '_macros.html.twig' import hp_prediction_badge_class %}

{% block title %}{{ game.homeTeam.code }} vs {{ game.awayTeam.code }} — Hockey Pool{% endblock %}

{% block body %}
    <div class="mb-6">
        <a href="{{ path('prediction_list') }}" style="font-size:14px;color:var(--fg-3);text-decoration:none;transition:color 0.15s"
           onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--fg-3)'">&larr; Zpět na zápasy</a>
    </div>

    <div class="match-detail-grid" style="display:grid;grid-template-columns:640px 1fr;gap:20px;align-items:start">
        {# Left column — sticky scoreboard #}
        <div class="match-detail-hero" style="position:sticky;top:80px">
            {# Match header #}
            <div class="hp-card" style="border:none;background:var(--bg-3);border-radius:var(--radius-lg);box-shadow:0 8px 32px oklch(0 0 0 / 0.25)">
                <div style="padding:28px 24px 24px;text-align:center">
                    <div style="margin-bottom:12px">
                        <span class="hp-chip hp-chip-accent">{{ game.phase.value|phase_label }}</span>
                        <span style="margin-left:6px;font-size:12px;color:var(--fg-4)">{{ game.playedAt|date('d.m.Y H:i') }}</span>
                    </div>
                    <div class="flex items-center justify-center gap-6 sm:gap-10">
                        <div class="text-center">
                            <div>{{ team_flag(game.homeTeam.code, 'hp-flag hp-flag-lg') }}</div>
                            <div style="margin-top:6px;font-family:var(--font-display);font-size:1.15rem;font-weight:700;color:var(--fg)">{{ game.homeTeam.code }}</div>
                            <div style="font-size:12px;color:var(--fg-4)">{{ game.homeTeam.name }}</div>
                        </div>
                        <div class="text-center">
                            {% if game.isFinished %}
                                <div style="font-family:var(--font-display);font-size:72px;font-weight:800;letter-spacing:-0.02em;line-height:1;color:var(--fg)">
                                    {{ game.homeScore }}<span style="color:var(--fg-4)">:</span>{{ game.awayScore }}
                                </div>
                                {% if game.winner %}
                                    <div style="margin-top:6px;font-size:12px;color:var(--accent)">
                                        Vítěz: {{ team_flag(game.winner.code) }} {{ game.winner.code }}
                                    </div>
                                {% else %}
                                    <div style="margin-top:6px;font-size:12px;color:var(--fg-4)">Remíza</div>
                                {% endif %}
                            {% else %}
                                <div style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--fg-4)">vs</div>
                                <div style="margin-top:4px;font-size:12px;color:var(--fg-4)">Dosud neodehráno</div>
                            {% endif %}
                        </div>
                        <div class="text-center">
                            <div>{{ team_flag(game.awayTeam.code, 'hp-flag hp-flag-lg') }}</div>
                            <div style="margin-top:6px;font-family:var(--font-display);font-size:1.15rem;font-weight:700;color:var(--fg)">{{ game.awayTeam.code }}</div>
                            <div style="font-size:12px;color:var(--fg-4)">{{ game.awayTeam.name }}</div>
                        </div>
                    </div>

                    {% if is_granted('ROLE_ADMIN') %}
                        <div style="margin-top:20px">
                            <a href="{{ path('admin_match_result', {id: game.id}) }}"
                               class="hp-btn hp-btn-ghost hp-btn-sm"
                               onclick="return confirm('Upravuješ výsledek zápasu, ne svůj tip. Pokračovat?')">
                                Upravit výsledek
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Right column — predictions #}
        <div>
            {# Predictions breakdown #}
            {% if breakdown|length > 0 %}
                <div class="hp-card">
                    <div class="hp-card-head">
                        <h2 class="hp-card-title">Tipy hráčů</h2>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="hp-tbl">
                            <thead>
                                <tr>
                                    <th scope="col">Hráč</th>
                                    <th scope="col" style="text-align:center">Tip</th>
                                    <th scope="col" style="text-align:center">Výsledek</th>
                                    <th scope="col" class="hidden sm:table-cell" style="text-align:right">Základ</th>
                                    <th scope="col" class="hidden sm:table-cell" style="text-align:right">Bonus</th>
                                    <th scope="col" class="hidden sm:table-cell" style="text-align:right">Přesný</th>
                                    <th scope="col" style="text-align:right;font-weight:700">Celkem</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for row in breakdown %}
                                    {% set isCurrentUser = app.user and app.user.id == row.user.id %}
                                    <tr{% if isCurrentUser %} style="background:color-mix(in oklab, var(--accent) 10%, transparent)"{% endif %}>
                                        <td style="{{ isCurrentUser ? 'font-weight:600;' : '' }}">
                                            {{ row.user.username }}
                                            {% if isCurrentUser %}
                                                <span style="margin-left:4px;font-size:11px;color:var(--accent)">&larr; ty</span>
                                            {% endif %}
                                        </td>
                                        <td style="text-align:center">
                                            {% if row.prediction %}
                                                <span style="font-variant-numeric:tabular-nums;font-weight:600;font-family:var(--font-mono);font-size:13px">
                                                    {{ row.prediction.homeScore }}:{{ row.prediction.awayScore }}
                                                </span>
                                            {% else %}
                                                <span style="color:var(--fg-4)">&mdash;</span>
                                            {% endif %}
                                        </td>
                                        <td style="text-align:center">
                                            {% if game.isFinished %}
                                                {% if row.exactScore %}
                                                    <span class="{{ hp_prediction_badge_class(row.prediction, game) }}">Přesný</span>
                                                {% elseif row.correctWinner %}
                                                    <span class="{{ hp_prediction_badge_class(row.prediction, game) }}">Vítěz</span>
                                                {% else %}
                                                    <span class="hp-pred-badge hp-pred-miss">Špatně</span>
                                                {% endif %}
                                            {% endif %}
                                        </td>
                                        <td class="hidden sm:table-cell hp-num" style="font-family:var(--font-mono);font-size:13px;{{ row.basePoints > 0 ? 'color:var(--pos)' : 'color:var(--fg-4)' }}">
                                            {{ row.basePoints > 0 ? row.basePoints|number_format(2) : '—' }}
                                        </td>
                                        <td class="hidden sm:table-cell hp-num" style="font-family:var(--font-mono);font-size:13px;{{ row.opponentBonus > 0 ? 'color:var(--accent)' : 'color:var(--fg-4)' }}">
                                            {{ row.opponentBonus > 0 ? '+' ~ row.opponentBonus|number_format(2) : '—' }}
                                        </td>
                                        <td class="hidden sm:table-cell hp-num" style="font-family:var(--font-mono);font-size:13px;{{ row.exactBonus > 0 ? 'color:var(--warn)' : 'color:var(--fg-4)' }}">
                                            {{ row.exactBonus > 0 ? '+' ~ row.exactBonus|number_format(2) : '—' }}
                                        </td>
                                        <td class="hp-num" style="font-family:var(--font-mono);font-size:13px;font-weight:700;{{ row.totalPoints > 0 ? 'color:var(--fg)' : 'color:var(--fg-4)' }}">
                                            {{ row.totalPoints > 0 ? row.totalPoints|number_format(2) : '0.00' }}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% elseif not matchStarted %}
                <div class="hp-card" style="padding:40px 24px;text-align:center">
                    <p style="color:var(--fg-3)">Tipy ostatních se zobrazí po začátku zápasu.</p>
                </div>
            {% else %}
                <div class="hp-card" style="padding:40px 24px;text-align:center">
                    <p style="color:var(--fg-3)">Zatím žádné tipy pro tento zápas.</p>
                </div>
            {% endif %}
        </div>
    </div>

    <style>
        @media (max-width: 1023px) {
            .match-detail-grid { grid-template-columns: 1fr !important; }
            .match-detail-hero { position: static !important; }
        }
    </style>
{% endblock %}
