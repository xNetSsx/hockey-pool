{% extends 'base.html.twig' %}

{% block title %}{{ title }} — {{ tournament ? tournament.name : 'Hockey Pool' }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/trix@2.1.18/dist/trix.min.css"
          integrity="sha384-OdKlax565lFPdig7pB3qfqRiYdNqdvvlGVkiIyAf3ZPuanZ6+F4Tm1fz4Pk6NGtr"
          crossorigin="anonymous">
{% endblock %}

{% block body %}
    <div class="mx-auto max-w-3xl">
        <div class="mb-6">
            <h1 class="text-2xl font-bold" style="color:var(--fg)">{{ title }}</h1>
            {% if tournament %}
                <p class="mt-1 text-sm" style="color:var(--fg-3)">{{ tournament.name }}</p>
            {% endif %}
        </div>

        <div class="hp-card p-6 sm:p-8">
            {% if content %}
                {# |raw is safe here: content is authored exclusively by admins via the Trix editor #}
                <div class="trix-content prose max-w-none">
                    {{ content|raw }}
                </div>
            {% else %}
                <p class="text-center" style="color:var(--fg-3)">{{ emptyMessage }}</p>
            {% endif %}
        </div>

        {% if is_granted('ROLE_ADMIN') and tournament %}
            <div class="mt-4 text-center">
                <a href="{{ path('admin_tournament_content', {id: tournament.id, field: field}) }}"
                   class="text-sm hover:underline" style="color:var(--accent)">
                    Upravit obsah
                </a>
            </div>
        {% endif %}
    </div>
{% endblock %}
