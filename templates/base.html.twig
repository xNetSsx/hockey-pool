{% import '_macros.html.twig' as m %}
<!DOCTYPE html>
<html lang="cs" data-variant="rink">
    <head>
        <meta charset="UTF-8">
        <script>(function(){var t=localStorage.getItem('hp:theme')||localStorage.getItem('theme');var d=t==='dark'||(!t&&window.matchMedia('(prefers-color-scheme:dark)').matches);document.documentElement.dataset.theme=d?'dark':'light';if(d)document.documentElement.classList.add('dark')})();</script>
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Hockey Pool{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🏒</text></svg>">

        {# Google Fonts #}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Barlow+Condensed:wght@500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap">

        {% block stylesheets %}{% endblock %}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1/dist/driver.min.css">

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="hp-app">
        {# ── Nav bar ── #}
        <nav class="hp-nav" {{ stimulus_controller('nav') }}>
            <div class="hp-container hp-nav-inner">
                {# Brand + tournament #}
                <div style="display:flex;align-items:center;gap:12px">
                    <a href="{{ path('homepage') }}" class="hp-brand">
                        {{ m.brand_mark() }}
                        <span class="hp-brand-name">Hockey Pool</span>
                    </a>
                    {% if current_tournament %}
                        <a href="{{ path('tournament_archive') }}" class="hp-brand-sub" title="Změnit turnaj">
                            {{ current_tournament.name }}
                        </a>
                    {% endif %}
                </div>

                {# Theme toggle for logged-out users #}
                {% if not app.user %}
                    <button type="button" {{ stimulus_controller('theme') }} {{ stimulus_action('theme', 'toggle') }}
                            class="hp-icon-btn" title="Přepnout vzhled" aria-label="Přepnout vzhled">
                        {{ m.theme_icons() }}
                    </button>
                {% endif %}

                {# Desktop nav #}
                {% if app.user %}
                    <div class="hidden items-center sm:flex">
                        {% set _route = app.request.attributes.get('_route') %}
                        <div class="hp-nav-links">
                            <a href="{{ path('prediction_list') }}" class="{{ m.nav_link_class(_route starts with 'prediction_' or _route starts with 'match_' or _route == 'special_bet_overview') }}">Tipy</a>
                            <a href="{{ path('player_compare') }}" class="{{ m.nav_link_class(_route starts with 'player_compare') }}">Porovnat</a>
                            <a href="{{ path('tournament_archive') }}" class="{{ m.nav_link_class(_route starts with 'tournament_') }}">Turnaje</a>
                            <a href="{{ path('hall_of_fame') }}" class="{{ m.nav_link_class(_route == 'hall_of_fame') }}">Síň slávy</a>
                            {% block nav_links %}{% endblock %}
                        </div>
                    </div>
                {% endif %}

                {# Right side: user + actions #}
                {% if app.user %}
                    <div class="hidden sm:flex hp-nav-right">
                        <a href="{{ path('player_profile', {username: app.user.username}) }}" class="hp-nav-user">
                            {{ m.avatar(app.user.username, 'sm') }}
                            {{ app.user.username }}
                        </a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('admin_tournaments') }}" class="hp-chip" style="color:var(--neg);border-color:color-mix(in oklab, var(--neg) 30%, transparent);font-size:11px;font-weight:600">Admin</a>
                        {% endif %}
                        <a href="{{ path('change_password') }}" class="hp-icon-btn" title="Změnit heslo" aria-label="Změnit heslo">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                            </svg>
                        </a>
                        <button type="button" {{ stimulus_controller('theme') }} {{ stimulus_action('theme', 'toggle') }}
                                class="hp-icon-btn" title="Přepnout vzhled" aria-label="Přepnout vzhled">
                            {{ m.theme_icons() }}
                        </button>
                        <a href="{{ path('app_logout') }}" class="hp-icon-btn" title="Odhlásit" aria-label="Odhl��sit">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" />
                            </svg>
                        </a>
                    </div>

                    {# Mobile: theme + hamburger #}
                    <div class="flex items-center gap-1 sm:hidden">
                        <button type="button" {{ stimulus_controller('theme') }} {{ stimulus_action('theme', 'toggle') }}
                                class="hp-icon-btn" title="Přepnout vzhled" aria-label="Přepnout vzhled">
                            {{ m.theme_icons() }}
                        </button>
                        <button type="button" class="hp-icon-btn" {{ stimulus_action('nav', 'toggle') }} aria-label="Otevřít menu">
                            <svg {{ stimulus_target('nav', 'openIcon') }} class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                            </svg>
                            <svg {{ stimulus_target('nav', 'closeIcon') }} class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                {% endif %}
            </div>

            {# Mobile menu #}
            {% if app.user %}
                <div {{ stimulus_target('nav', 'menu') }} class="hidden sm:hidden hp-mobile-menu">
                    {% if current_tournament %}
                        <span class="hp-chip hp-chip-accent" style="margin-bottom:8px">{{ current_tournament.name }}</span>
                    {% endif %}
                    {% set _route = app.request.attributes.get('_route') %}
                    <a href="{{ path('prediction_list') }}" class="{{ m.nav_link_class(_route starts with 'prediction_' or _route starts with 'match_' or _route == 'special_bet_overview', true) }}" {{ stimulus_action('nav', 'close') }}>Tipy</a>
                    <a href="{{ path('player_compare') }}" class="{{ m.nav_link_class(_route starts with 'player_compare', true) }}" {{ stimulus_action('nav', 'close') }}>Porovnat</a>
                    <a href="{{ path('tournament_archive') }}" class="{{ m.nav_link_class(_route starts with 'tournament_', true) }}" {{ stimulus_action('nav', 'close') }}>Turnaje</a>
                    <a href="{{ path('hall_of_fame') }}" class="{{ m.nav_link_class(_route == 'hall_of_fame', true) }}" {{ stimulus_action('nav', 'close') }}>Síň slávy</a>
                    <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--line)">
                        <a href="{{ path('player_profile', {username: app.user.username}) }}" class="hp-mobile-link" {{ stimulus_action('nav', 'close') }}>{{ app.user.username }}</a>
                        <a href="{{ path('change_password') }}" class="hp-mobile-link" {{ stimulus_action('nav', 'close') }}>Změnit heslo</a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('admin_tournaments') }}" class="hp-mobile-link" style="color:var(--neg)" {{ stimulus_action('nav', 'close') }}>Admin</a>
                        {% endif %}
                        <a href="{{ path('app_logout') }}" class="hp-mobile-link" {{ stimulus_action('nav', 'close') }}>Odhlásit</a>
                    </div>
                </div>
            {% endif %}
        </nav>

        <main class="hp-container" style="padding-top:32px;padding-bottom:40px">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div role="{{ label == 'error' ? 'alert' : 'status' }}"
                         aria-live="{{ label == 'error' ? 'assertive' : 'polite' }}"
                         class="hp-alert {{ label == 'success' ? 'hp-alert-success' : (label == 'error' ? 'hp-alert-error' : 'hp-alert-info') }}"
                         data-controller="toast">
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:12px">
                            <span>{{ message }}</span>
                            <button type="button"
                                    data-action="click->toast#dismiss"
                                    style="background:none;border:none;color:inherit;font-size:18px;line-height:1;cursor:pointer;padding:0 2px;opacity:0.6;flex-shrink:0"
                                    aria-label="Zavřít">&times;</button>
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        {% block modals %}{% endblock %}

        {% if app.user %}
        <script src="https://cdn.jsdelivr.net/npm/driver.js@1/dist/driver.js.iife.js" defer></script>
        {% set _route = app.request.attributes.get('_route') %}
        <div data-controller="help" data-help-route-value="{{ _route }}">
            {# Floating help button #}
            <button data-action="click->help#toggle"
                    class="fixed bottom-6 right-6 z-50 flex h-14 w-14 items-center justify-center rounded-full hp-btn-primary"
                    style="box-shadow:0 10px 30px color-mix(in oklab, var(--accent) 40%, transparent)"
                    aria-label="Nápověda">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
            </button>

            {# Backdrop #}
            <div data-help-target="backdrop"
                 data-action="click->help#close"
                 class="fixed inset-0 z-40 hidden" style="background:oklch(0 0 0 / 0.4);backdrop-filter:blur(4px)"></div>

            {# Slide-over panel #}
            <div data-help-target="panel"
                 class="fixed bottom-0 right-0 top-0 z-50 w-80 translate-x-full overflow-y-auto transition-transform duration-300 sm:w-96"
                 style="background:var(--bg-2);box-shadow:0 20px 60px oklch(0 0 0 / 0.4)">

                {# Resize handle #}
                <div data-action="mousedown->help#startResize touchstart->help#startResizeTouch"
                     class="group absolute bottom-0 left-0 top-0 z-10 w-2 cursor-col-resize select-none"
                     aria-hidden="true">
                    <div style="position:absolute;inset:0;left:2px;width:1px;background:var(--line)"></div>
                </div>

                {# Header #}
                <div style="display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--line);padding:16px 20px">
                    <h2 style="font-weight:700;color:var(--fg)">Nápověda</h2>
                    <button data-action="click->help#close" class="hp-icon-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
                    </button>
                </div>

                {# Interactive tours #}
                <div style="border-bottom:1px solid var(--line);padding:20px">
                    <p class="hp-label" style="margin-bottom:12px">Průvodci aplikací</p>
                    <div style="display:flex;flex-direction:column;gap:8px">
                        {# Predictions tour #}
                        {% if _route == 'prediction_list' %}
                            <button data-action="click->help#startTour" class="hp-btn hp-btn-primary" style="justify-content:flex-start;gap:12px;padding:14px 16px">
                                <span style="font-size:20px" aria-hidden="true">🎯</span>
                                <div style="text-align:left">
                                    <div style="font-size:13px;font-weight:600">Průvodce tipováním</div>
                                    <div style="font-size:11px;opacity:0.7;font-weight:400">Jak zadávat tipy a co vše najdeš zde</div>
                                </div>
                            </button>
                        {% else %}
                            <a href="{{ path('prediction_list') }}?tour=1" class="hp-btn hp-btn-ghost" style="justify-content:flex-start;gap:12px;padding:14px 16px">
                                <span style="font-size:20px" aria-hidden="true">🎯</span>
                                <div style="text-align:left">
                                    <div style="font-size:13px;font-weight:600">Průvodce tipováním</div>
                                    <div style="font-size:11px;color:var(--fg-3);font-weight:400">Jak zadávat tipy a orientovat se</div>
                                </div>
                            </a>
                        {% endif %}

                        {# Leaderboard tour #}
                        {% if _route == 'homepage' %}
                            <button data-action="click->help#startTour" class="hp-btn hp-btn-primary" style="justify-content:flex-start;gap:12px;padding:14px 16px">
                                <span style="font-size:20px" aria-hidden="true">🏆</span>
                                <div style="text-align:left">
                                    <div style="font-size:13px;font-weight:600">Pr��vodce žebříčkem</div>
                                    <div style="font-size:11px;opacity:0.7;font-weight:400">Žebříček, graf a statistiky turnaje</div>
                                </div>
                            </button>
                        {% else %}
                            <a href="{{ path('homepage') }}?tour=1" class="hp-btn hp-btn-ghost" style="justify-content:flex-start;gap:12px;padding:14px 16px">
                                <span style="font-size:20px" aria-hidden="true">🏆</span>
                                <div style="text-align:left">
                                    <div style="font-size:13px;font-weight:600">Průvodce žebříčkem</div>
                                    <div style="font-size:11px;color:var(--fg-3);font-weight:400">Žebříček, graf bodů a statistiky</div>
                                </div>
                            </a>
                        {% endif %}

                        {# Hall of Fame tour #}
                        {% if _route == 'hall_of_fame' %}
                            <button data-action="click->help#startTour" class="hp-btn hp-btn-primary" style="justify-content:flex-start;gap:12px;padding:14px 16px">
                                <span style="font-size:20px" aria-hidden="true">🏅</span>
                                <div style="text-align:left">
                                    <div style="font-size:13px;font-weight:600">Průvodce Síní slávy</div>
                                    <div style="font-size:11px;opacity:0.7;font-weight:400">Celkové pořadí a historie turnajů</div>
                                </div>
                            </button>
                        {% else %}
                            <a href="{{ path('hall_of_fame') }}?tour=1" class="hp-btn hp-btn-ghost" style="justify-content:flex-start;gap:12px;padding:14px 16px">
                                <span style="font-size:20px" aria-hidden="true">🏅</span>
                                <div style="text-align:left">
                                    <div style="font-size:13px;font-weight:600">Průvodce Síní slávy</div>
                                    <div style="font-size:11px;color:var(--fg-3);font-weight:400">Celkové pořadí a historie turnajů</div>
                                </div>
                            </a>
                        {% endif %}
                    </div>
                </div>

                {# Rules accordion #}
                <div style="border-bottom:1px solid var(--line)">
                    <button data-action="click->help#toggleRules"
                            style="display:flex;align-items:center;justify-content:space-between;width:100%;padding:16px 20px;text-align:left;font-size:14px;font-weight:600;color:var(--fg);background:transparent;border:none;cursor:pointer">
                        <span>Pravidla</span>
                        <span data-help-target="rulesArrow" style="font-size:12px;color:var(--fg-4)">&#x25BC;</span>
                    </button>
                    <div data-help-target="rulesContent" class="hidden" style="padding:0 20px 20px">
                        {% if current_tournament and current_tournament.rulesContent %}
                            <div class="trix-content" style="font-size:14px;color:var(--fg-2)">
                                {{ current_tournament.rulesContent|raw }}
                            </div>
                        {% else %}
                            <p style="font-size:14px;color:var(--fg-4)">Pravidla zatím nebyla nastavena.</p>
                        {% endif %}
                    </div>
                </div>

                {# Manual accordion #}
                <div>
                    <button data-action="click->help#toggleManual"
                            style="display:flex;align-items:center;justify-content:space-between;width:100%;padding:16px 20px;text-align:left;font-size:14px;font-weight:600;color:var(--fg);background:transparent;border:none;cursor:pointer">
                        <span>Manuál</span>
                        <span data-help-target="manualArrow" style="font-size:12px;color:var(--fg-4)">&#x25BC;</span>
                    </button>
                    <div data-help-target="manualContent" class="hidden" style="padding:0 20px 20px">
                        {% if current_tournament and current_tournament.manualContent %}
                            <div class="trix-content" style="font-size:14px;color:var(--fg-2)">
                                {{ current_tournament.manualContent|raw }}
                            </div>
                        {% else %}
                            <p style="font-size:14px;color:var(--fg-4)">Manuál zatím nebyl nastaven.</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
    </body>
</html>
