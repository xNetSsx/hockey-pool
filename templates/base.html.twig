{% import '_macros.html.twig' as m %}
<!DOCTYPE html>
<html lang="cs">
    <head>
        <meta charset="UTF-8">
        <script>(function(){var t=localStorage.getItem('theme');var d=t==='dark'||(!t&&window.matchMedia('(prefers-color-scheme:dark)').matches);if(d)document.documentElement.classList.add('dark')})();</script>
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Hockey Pool{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🏒</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="min-h-screen bg-gray-100 text-gray-900 dark:bg-[#0b1120] dark:text-gray-100">
        <nav class="bg-white shadow dark:bg-[#0f172a] dark:shadow-gray-800" {{ stimulus_controller('nav') }}>
            <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
                <div class="flex h-16 items-center justify-between">
                    {# Logo + tournament badge #}
                    <div class="flex items-center gap-3">
                        <a href="{{ path('homepage') }}" class="text-xl font-bold text-gray-900 dark:text-white">
                            Hockey Pool
                        </a>
                        {% if current_tournament %}
                            <a href="{{ path('tournament_archive') }}"
                               class="hidden rounded-full bg-[#0f172a] px-3 py-1 text-xs font-medium text-white hover:bg-[#1e293b] dark:bg-[#38bdf8] dark:text-[#0f172a] dark:hover:bg-[#7dd3fc] sm:inline-block"
                               title="Změnit turnaj">
                                {{ current_tournament.name }}
                            </a>
                        {% endif %}
                    </div>

                    {# Theme toggle for logged-out users #}
                    {% if not app.user %}
                        <button type="button" {{ stimulus_controller('theme') }} {{ stimulus_action('theme', 'toggle') }}
                                class="rounded-lg p-2 text-gray-500 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-white/10 dark:hover:text-white" title="Přepnout vzhled">
                            {{ m.theme_icons() }}
                        </button>
                    {% endif %}

                    {# Desktop nav #}
                    {% if app.user %}
                        <div class="hidden items-center gap-1 sm:flex">
                            {% set _route = app.request.attributes.get('_route') %}
                            <a href="{{ path('prediction_list') }}" class="rounded-lg px-3 py-2 text-sm font-medium {{ m.nav_link_class(_route starts with 'prediction_' or _route starts with 'match_' or _route == 'special_bet_overview') }}">Tipy</a>
                            <a href="{{ path('player_compare') }}" class="rounded-lg px-3 py-2 text-sm font-medium {{ m.nav_link_class(_route starts with 'player_compare') }}">Porovnat</a>
                            <a href="{{ path('rules_page') }}" class="rounded-lg px-3 py-2 text-sm font-medium {{ m.nav_link_class(_route == 'rules_page') }}">Pravidla</a>
                            <a href="{{ path('manual_page') }}" class="rounded-lg px-3 py-2 text-sm font-medium {{ m.nav_link_class(_route == 'manual_page') }}">Manuál</a>
                            <a href="{{ path('tournament_archive') }}" class="rounded-lg px-3 py-2 text-sm font-medium {{ m.nav_link_class(_route starts with 'tournament_') }}">Turnaje</a>
                            {% block nav_links %}{% endblock %}
                            <div class="ml-2 flex items-center gap-2 border-l border-gray-200 pl-3 dark:border-gray-700">
                                <a href="{{ path('change_password') }}" class="rounded-lg px-3 py-2 text-sm font-medium text-gray-900 hover:bg-gray-100 dark:text-white dark:hover:bg-white/10">{{ app.user.username }}</a>
                                {% if is_granted('ROLE_ADMIN') %}
                                    <a href="{{ path('admin_dashboard') }}" class="rounded bg-red-500/10 px-2.5 py-1 text-xs font-semibold text-red-600 hover:bg-red-500/20 dark:text-red-400">Admin</a>
                                {% endif %}
                                <a href="{{ path('app_logout') }}" class="rounded-lg px-3 py-2 text-sm text-gray-500 hover:bg-gray-100 hover:text-gray-700 dark:text-gray-400 dark:hover:bg-white/10 dark:hover:text-gray-200">Odhlásit</a>
                                <button type="button" {{ stimulus_controller('theme') }} {{ stimulus_action('theme', 'toggle') }}
                                        class="rounded-lg p-2 text-gray-500 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-white/10 dark:hover:text-white" title="Přepnout vzhled">
                                    {{ m.theme_icons() }}
                                </button>
                            </div>
                        </div>
                    {% endif %}

                    {# Mobile: theme toggle + hamburger #}
                    {% if app.user %}
                        <div class="flex items-center gap-1 sm:hidden">
                            <button type="button" {{ stimulus_controller('theme') }} {{ stimulus_action('theme', 'toggle') }}
                                    class="rounded-lg p-2 text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-white/10" title="Přepnout vzhled">
                                {{ m.theme_icons() }}
                            </button>
                            <button type="button" class="inline-flex items-center justify-center rounded-lg p-2 text-gray-500 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-white/10 dark:hover:text-white" {{ stimulus_action('nav', 'toggle') }}>
                            <svg {{ stimulus_target('nav', 'openIcon') }} class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                            </svg>
                            <svg {{ stimulus_target('nav', 'closeIcon') }} class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# Mobile menu #}
            {% if app.user %}
                <div {{ stimulus_target('nav', 'menu') }} class="hidden border-t border-gray-200 dark:border-gray-700 sm:hidden">
                    <div class="space-y-1 px-4 pb-4 pt-3">
                        {% if current_tournament %}
                            <span class="mb-2 inline-block rounded-full bg-[#0f172a] px-3 py-1 text-xs font-medium text-white dark:bg-[#38bdf8] dark:text-[#0f172a]">
                                {{ current_tournament.name }}
                            </span>
                        {% endif %}
                        {% set _route = app.request.attributes.get('_route') %}
                        <a href="{{ path('prediction_list') }}" class="block rounded-lg px-3 py-2 text-base font-medium {{ m.nav_link_class(_route starts with 'prediction_' or _route starts with 'match_' or _route == 'special_bet_overview', true) }}" {{ stimulus_action('nav', 'close') }}>Tipy</a>
                        <a href="{{ path('player_compare') }}" class="block rounded-lg px-3 py-2 text-base font-medium {{ m.nav_link_class(_route starts with 'player_compare', true) }}" {{ stimulus_action('nav', 'close') }}>Porovnat</a>
                        <a href="{{ path('rules_page') }}" class="block rounded-lg px-3 py-2 text-base font-medium {{ m.nav_link_class(_route == 'rules_page', true) }}" {{ stimulus_action('nav', 'close') }}>Pravidla</a>
                        <a href="{{ path('manual_page') }}" class="block rounded-lg px-3 py-2 text-base font-medium {{ m.nav_link_class(_route == 'manual_page', true) }}" {{ stimulus_action('nav', 'close') }}>Manuál</a>
                        <a href="{{ path('tournament_archive') }}" class="block rounded-lg px-3 py-2 text-base font-medium {{ m.nav_link_class(_route starts with 'tournament_', true) }}" {{ stimulus_action('nav', 'close') }}>Turnaje</a>
                        <div class="mt-3 border-t border-gray-200 pt-3 dark:border-gray-700">
                            <a href="{{ path('change_password') }}" class="block rounded-lg px-3 py-2 text-base font-medium text-gray-900 hover:bg-gray-100 dark:text-white dark:hover:bg-white/10">{{ app.user.username }}</a>
                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('admin_dashboard') }}" class="block rounded-lg px-3 py-2 text-base font-medium text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-500/10">Admin</a>
                            {% endif %}
                            <a href="{{ path('app_logout') }}" class="block rounded-lg px-3 py-2 text-base text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-white/10">Odhlásit</a>
                        </div>
                    </div>
                </div>
            {% endif %}
        </nav>

        <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div role="{{ label == 'error' ? 'alert' : 'status' }}"
                         aria-live="{{ label == 'error' ? 'assertive' : 'polite' }}"
                         class="mb-4 rounded-md p-4 {{ label == 'success' ? 'bg-green-50 text-green-800 dark:bg-green-900/30 dark:text-green-300' : (label == 'error' ? 'bg-red-50 text-red-800 dark:bg-red-900/30 dark:text-red-300' : 'bg-blue-50 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300') }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        {% block modals %}{% endblock %}
    </body>
</html>
