{% extends 'base.html.twig' %}

{% block title %}Síň slávy — Hockey Pool{% endblock %}

{% block body %}
    {# Page header #}
    <div class="mb-10">
        <div class="flex items-center gap-4">
            <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-amber-400/15 dark:bg-amber-400/10">
                <svg class="h-8 w-8 text-amber-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.166 2.621v.858c-1.035.148-2.059.33-3.071.543a.75.75 0 0 0-.584.859 6.753 6.753 0 0 0 6.138 5.6 6.73 6.73 0 0 0 2.743 1.346A6.707 6.707 0 0 1 9.279 15H8.54c-1.036 0-1.875.84-1.875 1.875V19.5h-.75a2.25 2.25 0 0 0-2.25 2.25c0 .414.336.75.75.75h15a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-2.25-2.25h-.75v-2.625c0-1.036-.84-1.875-1.875-1.875h-.739a6.706 6.706 0 0 1-1.112-3.173 6.73 6.73 0 0 0 2.743-1.347 6.753 6.753 0 0 0 6.139-5.6.75.75 0 0 0-.585-.858 47.077 47.077 0 0 0-3.07-.543V2.62a.75.75 0 0 0-.658-.744 49.798 49.798 0 0 0-6.093-.377c-2.063 0-4.096.128-6.093.377a.75.75 0 0 0-.657.744Zm0 2.629c0 1.196.312 2.32.857 3.294A5.266 5.266 0 0 1 3.16 5.337a45.6 45.6 0 0 1 2.006-.343v.256Zm13.5 0v-.256c.674.1 1.343.214 2.006.343a5.265 5.265 0 0 1-2.863 3.207 6.72 6.72 0 0 0 .857-3.294Z" clip-rule="evenodd" />
                </svg>
            </div>
            <div>
                <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Síň slávy</h1>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Přehled výsledků všech odehraných turnajů.</p>
            </div>
        </div>
    </div>

    {# All-time standings #}
    <div class="mb-12">
        <h2 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">Celkové pořadí</h2>

        {% if standings|length == 0 %}
            <div class="rounded-xl bg-white p-8 text-center shadow dark:bg-[#1e293b]">
                <p class="text-gray-500 dark:text-gray-400">Žádná data k zobrazení.</p>
            </div>
        {% else %}
            <div class="overflow-hidden rounded-xl bg-white shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                        <thead class="bg-[#0f172a]">
                            <tr>
                                <th scope="col" class="w-12 px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400">#</th>
                                <th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400">Hráč</th>
                                <th scope="col" class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-400">Turnaje</th>
                                <th scope="col" class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-amber-400">
                                    <span title="1. místo">🥇</span>
                                </th>
                                <th scope="col" class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-400">
                                    <span title="2. místo">🥈</span>
                                </th>
                                <th scope="col" class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-400">
                                    <span title="3. místo">🥉</span>
                                </th>
                                <th scope="col" class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-400">Prům. pořadí</th>
                                <th scope="col" class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-400">Úspěšnost</th>
                                <th scope="col" class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-400">Přesná skóre</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                            {% for row in standings %}
                                <tr class="transition
                                    {% if row.rank == 1 %}bg-amber-50/50 hover:bg-amber-50 dark:bg-amber-900/10 dark:hover:bg-amber-900/20
                                    {% elseif row.rank == 2 %}bg-gray-50/80 hover:bg-gray-100/80 dark:bg-gray-800/30 dark:hover:bg-gray-800/50
                                    {% elseif row.rank == 3 %}bg-amber-50/30 hover:bg-amber-50/60 dark:bg-amber-900/5 dark:hover:bg-amber-900/10
                                    {% else %}hover:bg-gray-50 dark:hover:bg-white/5{% endif %}">
                                    <td class="px-4 py-3 text-sm font-bold tabular-nums">
                                        {% if row.rank == 1 %}
                                            <span class="text-lg" title="1. místo">🥇</span>
                                        {% elseif row.rank == 2 %}
                                            <span class="text-lg" title="2. místo">🥈</span>
                                        {% elseif row.rank == 3 %}
                                            <span class="text-lg" title="3. místo">🥉</span>
                                        {% else %}
                                            <span class="text-gray-500 dark:text-gray-400">{{ row.rank }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="px-4 py-3">
                                        <a href="{{ path('player_profile', {username: row.user.username}) }}" class="font-semibold text-gray-900 hover:text-[#38bdf8] dark:text-white dark:hover:text-[#38bdf8] {{ row.rank == 1 ? 'text-base' : 'text-sm' }}">
                                            {{ row.user.username }}
                                        </a>
                                    </td>
                                    <td class="px-4 py-3 text-center text-sm tabular-nums text-gray-600 dark:text-gray-300">{{ row.tournamentsPlayed }}</td>
                                    <td class="px-4 py-3 text-center text-sm font-semibold tabular-nums {{ row.firstPlace > 0 ? 'text-amber-600 dark:text-amber-400' : 'text-gray-400 dark:text-gray-600' }}">{{ row.firstPlace }}</td>
                                    <td class="px-4 py-3 text-center text-sm font-semibold tabular-nums {{ row.secondPlace > 0 ? 'text-gray-500 dark:text-gray-300' : 'text-gray-400 dark:text-gray-600' }}">{{ row.secondPlace }}</td>
                                    <td class="px-4 py-3 text-center text-sm font-semibold tabular-nums {{ row.thirdPlace > 0 ? 'text-amber-700 dark:text-amber-600' : 'text-gray-400 dark:text-gray-600' }}">{{ row.thirdPlace }}</td>
                                    <td class="px-4 py-3 text-center text-sm tabular-nums text-gray-600 dark:text-gray-300">
                                        {% if row.averageRank is not null %}
                                            {{ row.averageRank|number_format(2) }}
                                        {% else %}
                                            —
                                        {% endif %}
                                    </td>
                                    <td class="px-4 py-3 text-center text-sm tabular-nums text-gray-600 dark:text-gray-300">
                                        {% if row.careerAccuracy is not null %}{{ row.careerAccuracy }}%{% else %}—{% endif %}
                                    </td>
                                    <td class="px-4 py-3 text-center text-sm tabular-nums text-gray-600 dark:text-gray-300">
                                        {{ row.careerExactScores }}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}
    </div>

    {# Tournament history / podiums #}
    <div>
        <h2 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">Historie turnajů</h2>

        {% if podiums|length == 0 %}
            <div class="rounded-xl bg-white p-8 text-center shadow dark:bg-[#1e293b]">
                <p class="text-gray-500 dark:text-gray-400">Žádné ukončené turnaje.</p>
            </div>
        {% else %}
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {% for entry in podiums %}
                    <div class="overflow-hidden rounded-xl bg-white shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
                        <div class="bg-gradient-to-r from-[#0f172a] to-[#1e3a5f] px-6 py-4">
                            <div class="flex items-start justify-between gap-3">
                                <h3 class="text-base font-bold leading-snug text-white">{{ entry.tournament.name }}</h3>
                                <span class="shrink-0 rounded-full bg-white/10 px-2.5 py-0.5 text-xs font-semibold text-gray-300 ring-1 ring-white/20">
                                    {{ entry.tournament.year }}
                                </span>
                            </div>
                        </div>
                        <div class="divide-y divide-gray-100 dark:divide-gray-700">
                            {% if entry.podium|length == 0 %}
                                <p class="px-6 py-4 text-sm text-gray-400 dark:text-gray-500">Žádná data.</p>
                            {% else %}
                                {% for finisher in entry.podium %}
                                    <div class="flex items-center justify-between py-3 pl-4 pr-6
                                        {% if finisher.rank == 1 %}border-l-4 border-amber-400
                                        {% elseif finisher.rank == 2 %}border-l-4 border-gray-400
                                        {% else %}border-l-4 border-amber-700 dark:border-amber-600{% endif %}">
                                        <div class="flex items-center gap-3">
                                            <span class="text-lg leading-none"
                                                  title="{{ finisher.rank }}. místo">{% if finisher.rank == 1 %}🥇{% elseif finisher.rank == 2 %}🥈{% else %}🥉{% endif %}</span>
                                            <a href="{{ path('player_profile', {username: finisher.user.username}) }}" class="text-sm font-semibold text-gray-900 hover:text-[#38bdf8] dark:text-white dark:hover:text-[#38bdf8]">
                                                {{ finisher.user.username }}
                                            </a>
                                        </div>
                                        <span class="text-sm font-semibold tabular-nums
                                            {% if finisher.rank == 1 %}text-amber-600 dark:text-amber-400
                                            {% elseif finisher.rank == 2 %}text-gray-500 dark:text-gray-300
                                            {% else %}text-amber-700 dark:text-amber-600{% endif %}">
                                            {{ finisher.points|number_format(2) }} b
                                        </span>
                                    </div>
                                {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
