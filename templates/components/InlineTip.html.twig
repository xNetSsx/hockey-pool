<div{{ attributes }}>
    {% if treasonStage == 1 %}
        {# First treason warning #}
        <style>@keyframes shake{0%,100%{transform:translateX(0)}10%,30%,50%,70%,90%{transform:translateX(-4px)}20%,40%,60%,80%{transform:translateX(4px)}}</style>
        <div style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;background:oklch(0 0 0 / 0.85);display:flex;align-items:center;justify-content:center;padding:0 1rem">
            <div class="hp-card" style="max-width:400px;width:100%;padding:32px;text-align:center;border-color:var(--neg);animation:shake 0.5s ease-in-out">
                <div style="margin-bottom:12px;font-size:64px">🇨🇿</div>
                <h2 style="font-family:var(--font-display);font-size:28px;font-weight:900;text-transform:uppercase;letter-spacing:0.04em;color:var(--neg);margin-bottom:4px">Vlastizrada!</h2>
                <p style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--neg);margin-bottom:16px">Detekován tip proti vlasti</p>
                <p style="font-size:14px;color:var(--fg-3);margin-bottom:24px">
                    Vážně tipuješ prohru České republiky?<br>
                    <strong style="color:var(--fg-2)">Tohle je tvoje šance to napravit.</strong>
                </p>
                <div style="display:flex;flex-direction:column;gap:8px">
                    <button
                        type="button"
                        autofocus
                        class="hp-btn hp-btn-primary"
                        style="width:100%"
                        data-action="live#action"
                        data-live-action-param="cancelTreason"
                    >🇨🇿 Sláva! Opravím to</button>
                    <button
                        type="button"
                        class="hp-btn hp-btn-ghost"
                        style="width:100%"
                        data-action="live#action"
                        data-live-action-param="escalateTreason"
                    >Stojím si za tím...</button>
                </div>
            </div>
        </div>
    {% elseif treasonStage == 2 %}
        {# Second treason warning #}
        <div style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;background:oklch(0.15 0.08 25 / 0.9);display:flex;align-items:center;justify-content:center;padding:0 1rem">
            <div class="hp-card" style="max-width:400px;width:100%;padding:32px;text-align:center;border-color:var(--neg);animation:shake 0.3s ease-in-out 3">
                <div style="margin-bottom:12px;font-size:64px">⛔</div>
                <h2 style="font-family:var(--font-display);font-size:24px;font-weight:900;text-transform:uppercase;color:var(--neg);margin-bottom:16px">Poslední varování!</h2>
                <div style="background:color-mix(in oklab, var(--neg) 15%, var(--bg-2));padding:12px;border-radius:var(--radius);margin-bottom:16px">
                    <p style="font-size:14px;color:var(--neg)">Tímto se oficiálně prohlašuješ za</p>
                    <p style="margin-top:4px;font-family:var(--font-display);font-size:22px;font-weight:900;color:var(--neg)">VLASTIZRÁDCE</p>
                </div>
                <p style="font-size:12px;color:var(--fg-4);margin-bottom:24px">
                    Tvůj hanebný tip bude zaznamenán.<br>Ostatní se to dozví. Není cesta zpět.
                </p>
                <div style="display:flex;flex-direction:column;gap:8px">
                    <button
                        type="button"
                        autofocus
                        class="hp-btn"
                        style="width:100%;background:var(--pos);color:var(--accent-ink)"
                        data-action="live#action"
                        data-live-action-param="cancelTreason"
                    >🇨🇿 Měním tip! Sláva Čechům!</button>
                    <button
                        type="button"
                        class="hp-btn"
                        style="width:100%;background:color-mix(in oklab, var(--neg) 30%, var(--bg-3));color:var(--neg);font-size:12px"
                        data-action="live#action"
                        data-live-action-param="confirmTreason"
                    >Potvrzuji zradu...</button>
                </div>
            </div>
        </div>
    {% elseif saved and not editing %}
        {# Saved confirmation #}
        <div class="flex items-center gap-2">
            <span class="hp-pred-badge hp-pred-good">
                {{ homeScore }}:{{ awayScore }}
            </span>
            <span style="font-size:12px;font-weight:600;color:var(--pos)">
                &#10003; Uloženo
            </span>
        </div>
    {% elseif editing %}
        {# Inline editing mode #}
        <div class="flex flex-col items-center gap-2">
            {% if errorMessage %}
                <div style="font-size:11px;font-weight:600;color:var(--neg);margin-bottom:2px">
                    {{ errorMessage }}
                </div>
            {% endif %}
            <div class="flex items-center gap-3">
                {# Home score bumper #}
                <div class="flex flex-col items-center gap-1">
                    <button
                        type="button"
                        class="hp-btn hp-btn-ghost hp-btn-sm"
                        style="padding:2px 8px;font-size:16px;line-height:1"
                        data-action="live#action"
                        data-live-action-param="bump"
                        data-live-side-param="home"
                        data-live-delta-param="1"
                    >&#9650;</button>
                    <span style="font-family:var(--font-display);font-size:48px;font-weight:800;color:var(--accent);line-height:1;user-select:none">
                        {{ homeScore }}
                    </span>
                    <button
                        type="button"
                        class="hp-btn hp-btn-ghost hp-btn-sm"
                        style="padding:2px 8px;font-size:16px;line-height:1"
                        data-action="live#action"
                        data-live-action-param="bump"
                        data-live-side-param="home"
                        data-live-delta-param="-1"
                    >&#9660;</button>
                </div>

                {# Colon separator #}
                <span style="font-family:var(--font-display);font-size:36px;color:var(--fg-4);user-select:none;padding-bottom:4px">:</span>

                {# Away score bumper #}
                <div class="flex flex-col items-center gap-1">
                    <button
                        type="button"
                        class="hp-btn hp-btn-ghost hp-btn-sm"
                        style="padding:2px 8px;font-size:16px;line-height:1"
                        data-action="live#action"
                        data-live-action-param="bump"
                        data-live-side-param="away"
                        data-live-delta-param="1"
                    >&#9650;</button>
                    <span style="font-family:var(--font-display);font-size:48px;font-weight:800;color:var(--accent);line-height:1;user-select:none">
                        {{ awayScore }}
                    </span>
                    <button
                        type="button"
                        class="hp-btn hp-btn-ghost hp-btn-sm"
                        style="padding:2px 8px;font-size:16px;line-height:1"
                        data-action="live#action"
                        data-live-action-param="bump"
                        data-live-side-param="away"
                        data-live-delta-param="-1"
                    >&#9660;</button>
                </div>
            </div>

            {# Action buttons #}
            <div class="flex items-center gap-2">
                <button
                    type="button"
                    class="hp-btn hp-btn-primary hp-btn-sm"
                    style="padding:4px 12px;font-size:12px"
                    data-action="live#action"
                    data-live-action-param="save"
                >Uložit</button>
                <button
                    type="button"
                    class="hp-btn hp-btn-ghost hp-btn-sm"
                    style="padding:4px 12px;font-size:12px"
                    data-action="live#action"
                    data-live-action-param="cancel"
                >Zrušit</button>
            </div>
        </div>
    {% else %}
        {# Default display state #}
        <div class="flex items-center gap-2">
            {% if hasPrediction %}
                <span class="hp-pred-badge hp-pred-good">
                    {{ homeScore }}:{{ awayScore }}
                </span>
            {% else %}
                <span class="countdown-timer flex items-center gap-1 text-[11px] tabular-nums" data-deadline="{{ deadline }}"></span>
            {% endif %}
            <button
                type="button"
                class="hp-btn hp-btn-primary hp-btn-sm"
                style="padding:4px 10px;font-size:12px"
                data-action="live#action"
                data-live-action-param="open"
            >{{ hasPrediction ? 'Změnit' : 'Tipovat' }}</button>
        </div>
    {% endif %}
</div>
