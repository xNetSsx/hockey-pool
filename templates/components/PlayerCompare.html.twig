{% import '_macros.html.twig' as m %}

<div{{ attributes }}>
    {# Section header #}
    <div class="hp-section-head" style="margin-bottom:24px">
        <div>
            <div style="display:flex;gap:10px;margin-bottom:6px">
                <span class="hp-chip hp-chip-accent">Porovnání</span>
            </div>
            <h2>Porovnat hráče</h2>
        </div>
    </div>

    {# Player picker pills #}
    <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:24px">
        {% for player in this.players %}
            {% set isOn = player.username in this.selected %}
            <button
                type="button"
                data-action="live#action"
                data-live-action-param="toggle"
                data-live-username-param="{{ player.username }}"
                style="display:inline-flex;align-items:center;gap:8px;padding:6px 12px 6px 6px;border-radius:999px;font-size:13px;font-weight:500;cursor:pointer;transition:all 0.15s;border:1px solid {{ isOn ? 'var(--accent)' : 'var(--line)' }};background:{{ isOn ? 'color-mix(in oklab, var(--accent) 18%, var(--bg-2))' : 'var(--bg-2)' }};color:{{ isOn ? 'var(--fg)' : 'var(--fg-2)' }}"
            >
                {{ m.avatar(player.username, 'sm') }}
                {{ player.username }}
            </button>
        {% endfor %}
    </div>

    {% if this.hasComparison %}
        {% set data = this.comparisonData %}
        {% if data %}
            {% set users = data.users %}
            {% set leaderboardByUserId = data.leaderboardByUserId %}
            {% set comparison = data.comparison %}
            {% set userStats = data.userStats %}

            {# Summary cards #}
            <div style="display:flex;gap:16px;margin-bottom:24px;overflow-x:auto;padding-bottom:8px">
                {% for user in users %}
                    {% set stats = userStats[user.id] %}
                    {% set lb = leaderboardByUserId[user.id] ?? null %}
                    <div class="hp-card" style="padding:20px;min-width:260px;flex:1 0 260px">
                        <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px">
                            {{ m.avatar(user.username, 'lg') }}
                            <div style="min-width:0">
                                <div style="font-weight:700;font-size:18px;color:var(--fg);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ user.username }}</div>
                                <div style="font-size:12px;color:var(--fg-3)">
                                    {{ lb ? lb.totalPoints|number_format(2) ~ ' b. · ' ~ lb.rank ~ '. místo' : '—' }}
                                </div>
                            </div>
                        </div>
                        <div style="display:grid;grid-template-columns:repeat(3, 1fr);gap:8px">
                            <div style="padding:10px 6px;border-radius:10px;background:var(--bg-3);text-align:center">
                                <div class="hp-label" style="font-size:9px">Úspěšnost</div>
                                <div style="font-family:var(--font-display);font-size:24px;font-weight:800;color:var(--accent)">{{ stats.accuracy }}%</div>
                            </div>
                            <div style="padding:10px 6px;border-radius:10px;background:var(--bg-3);text-align:center">
                                <div class="hp-label" style="font-size:9px">Přesné</div>
                                <div style="font-family:var(--font-display);font-size:24px;font-weight:800;color:var(--fg)">{{ stats.exactScores }}</div>
                            </div>
                            <div style="padding:10px 6px;border-radius:10px;background:var(--bg-3);text-align:center">
                                <div class="hp-label" style="font-size:9px">Vítěz</div>
                                <div style="font-family:var(--font-display);font-size:24px;font-weight:800;color:var(--fg)">{{ stats.correctWinners }}</div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            {# Match-by-match table #}
            <div class="hp-card">
                <div class="hp-card-head">
                    <span class="hp-card-title">Tipy po zápasech</span>
                    <span class="hp-card-sub">{{ users|length }} hráčů · {{ comparison.games|filter(g => g.isFinished)|length }} zápasů</span>
                </div>
                <div style="overflow-x:auto">
                    <table class="hp-tbl" style="min-width:{{ 320 + users|length * 120 }}px">
                        <thead>
                            <tr>
                                <th style="position:sticky;left:0;background:var(--bg-3);z-index:2;min-width:160px">Zápas</th>
                                <th class="hp-num" style="min-width:80px">Skóre</th>
                                {% for user in users %}
                                    <th style="text-align:center;min-width:110px">
                                        <div style="display:flex;align-items:center;gap:6px;justify-content:center">
                                            {{ m.avatar(user.username, 'sm') }}
                                            <span style="white-space:nowrap">{{ user.username }}</span>
                                        </div>
                                    </th>
                                {% endfor %}
                            </tr>
                        </thead>
                        <tbody>
                            {% for game in comparison.games %}
                                {% if game.isFinished %}
                                    {% set maxPoints = 0 %}
                                    {% for user in users %}
                                        {% set pts = comparison.matchPoints[user.id][game.id] ?? 0 %}
                                        {% if pts > maxPoints %}{% set maxPoints = pts %}{% endif %}
                                    {% endfor %}

                                    <tr>
                                        <td style="position:sticky;left:0;background:var(--bg-2);z-index:1;white-space:nowrap">
                                            <div style="display:flex;align-items:center;gap:6px;font-size:13px">
                                                {{ team_flag(game.homeTeam.code) }}
                                                <span style="font-weight:600">{{ game.homeTeam.code }}</span>
                                                <span style="color:var(--fg-4);font-size:10px">vs</span>
                                                <span style="font-weight:600">{{ game.awayTeam.code }}</span>
                                                {{ team_flag(game.awayTeam.code) }}
                                            </div>
                                        </td>
                                        <td class="hp-num">
                                            <span class="hp-score" style="font-size:14px;padding:2px 8px">
                                                {{ game.homeScore }}<span style="opacity:0.45">:</span>{{ game.awayScore }}
                                            </span>
                                        </td>
                                        {% for user in users %}
                                            {% set prediction = comparison.predictions[user.id][game.id] ?? null %}
                                            {% set pts = comparison.matchPoints[user.id][game.id] ?? 0 %}
                                            {% set isBest = pts > 0 and pts == maxPoints %}
                                            {% set isExact = prediction and prediction.homeScore == game.homeScore and prediction.awayScore == game.awayScore %}
                                            <td style="text-align:center;{% if isBest %}background:color-mix(in oklab, var(--pos) 8%, transparent){% endif %}">
                                                {% if prediction %}
                                                    <div style="display:flex;flex-direction:column;align-items:center;gap:3px">
                                                        {% if isExact %}
                                                            <span class="hp-pred-badge hp-pred-exact">{{ prediction.homeScore }}:{{ prediction.awayScore }}</span>
                                                        {% elseif pts > 0 %}
                                                            <span class="hp-pred-badge hp-pred-good">{{ prediction.homeScore }}:{{ prediction.awayScore }}</span>
                                                        {% else %}
                                                            <span class="hp-pred-badge hp-pred-miss">{{ prediction.homeScore }}:{{ prediction.awayScore }}</span>
                                                        {% endif %}
                                                        <span style="font-size:11px;font-family:var(--font-mono);font-weight:700;color:{{ pts > 0 ? 'var(--pos)' : 'var(--fg-4)' }}">
                                                            {{ pts > 0 ? '+' ~ pts|number_format(2) : '0' }}{% if isBest %} 👑{% endif %}
                                                        </span>
                                                    </div>
                                                {% else %}
                                                    <span style="font-size:12px;color:var(--fg-4)">—</span>
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                {% endif %}
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}
    {% else %}
        <div class="hp-card" style="padding:40px;text-align:center">
            <p style="color:var(--fg-3);font-size:15px">Vyber alespoň 2 hráče k porovnání</p>
        </div>
    {% endif %}
</div>
