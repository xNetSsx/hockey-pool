{% extends 'base.html.twig' %}

{% block title %}Turnaje — Hockey Pool{% endblock %}

{% macro tournament_card(tournament, current_tournament, showSelect) %}
    {% set isSelected = current_tournament and current_tournament.id == tournament.id %}
    <div class="hp-card {{ isSelected ? 'ring-2' : '' }}" {% if isSelected %}style="--tw-ring-color:var(--accent)"{% endif %}>
        <div class="hp-card-head" style="background:var(--bg-3)">
            <div>
                <h3 class="hp-card-title">{{ tournament.name }}</h3>
                <p class="hp-card-sub">{{ tournament.year }}</p>
            </div>
        </div>
        <div class="flex items-center justify-between px-6 py-4">
            <div>
                {% if tournament.status.value == 'in_progress' %}
                    <span class="hp-chip" style="background:color-mix(in oklab, var(--pos) 18%, transparent);color:var(--pos);border-color:color-mix(in oklab, var(--pos) 30%, transparent)">Probíhá</span>
                {% elseif tournament.status.value == 'finished' %}
                    <span class="hp-chip">Ukončen</span>
                {% else %}
                    <span class="hp-chip hp-chip-accent">Nadcházející</span>
                {% endif %}
                {% if isSelected %}
                    <span class="ml-1 text-xs" style="color:var(--accent)">aktivní</span>
                {% endif %}
            </div>
            <div class="flex gap-2">
                <a href="{{ path('tournament_dashboard', {slug: tournament.slug}) }}"
                   class="hp-btn hp-btn-ghost hp-btn-sm">
                    Zobrazit
                </a>
                {% if showSelect and not isSelected %}
                    <a href="{{ path('tournament_select', {slug: tournament.slug}) }}"
                       class="hp-btn hp-btn-primary hp-btn-sm">
                        Vybrat
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
{% endmacro %}

{% block body %}
    <h1 class="mb-6 text-2xl font-bold" style="color:var(--fg)">Turnaje</h1>

    {% if current|length == 0 and archived|length == 0 %}
        <div class="hp-card p-8 text-center">
            <p style="color:var(--fg-3)">Žádné turnaje.</p>
        </div>
    {% endif %}

    {% if current|length > 0 %}
        <h2 class="mb-4 text-lg font-semibold" style="color:var(--fg)">Aktuální</h2>
        <div class="mb-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {% for tournament in current %}
                {{ _self.tournament_card(tournament, current_tournament, true) }}
            {% endfor %}
        </div>
    {% endif %}

    {% if archived|length > 0 %}
        <h2 class="mb-4 text-lg font-semibold" style="color:var(--fg-2)">Archiv</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {% for tournament in archived %}
                {{ _self.tournament_card(tournament, current_tournament, false) }}
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
