{% extends 'base.html.twig' %}
{% from '_macros.html.twig' import prediction_badge_class %}

{% block title %}{{ player.username }} — Hockey Pool{% endblock %}

{% block body %}
    <a href="{{ path('homepage') }}" class="mb-4 inline-flex items-center gap-1 text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
        Zpět na žebříček
    </a>

    {# Profile header #}
    <div class="mb-8 overflow-hidden rounded-2xl bg-[#0f172a] p-6 text-white shadow-xl ring-1 ring-white/5 sm:p-8 dark:bg-[#1e293b] dark:ring-white/10">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-3xl font-bold">{{ player.username }}</h1>
                <p class="mt-1 text-sm text-gray-400">{{ tournament.name }}</p>
            </div>
            <div class="flex gap-4">
                <div class="rounded-xl bg-white/10 px-5 py-3 text-center">
                    <div class="text-2xl font-black text-[#38bdf8]">{{ playerRank ?? '—' }}.</div>
                    <div class="text-xs text-gray-400">Pořadí</div>
                </div>
                <div class="rounded-xl bg-white/10 px-5 py-3 text-center">
                    <div class="text-2xl font-black">{{ playerPoints|number_format(2) }}</div>
                    <div class="text-xs text-gray-400">Body</div>
                </div>
                <div class="rounded-xl bg-white/10 px-5 py-3 text-center">
                    <div class="text-2xl font-black">{{ stats.accuracy }}%</div>
                    <div class="text-xs text-gray-400">Úspěšnost</div>
                </div>
            </div>
        </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
        {# Stats cards #}
        <div class="space-y-6 lg:col-span-1">
            <div class="rounded-xl bg-white shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
                <div class="border-b border-gray-200 bg-[#0f172a] px-6 py-4 dark:border-gray-700">
                    <h2 class="text-lg font-semibold text-white">📊 Statistiky</h2>
                </div>
                <div class="divide-y divide-gray-100 dark:divide-gray-700">
                    <div class="flex justify-between px-6 py-3">
                        <span class="text-sm text-gray-500 dark:text-gray-400">Správný vítěz</span>
                        <span class="font-semibold text-green-700 dark:text-green-400">{{ stats.correctWinners }}×</span>
                    </div>
                    <div class="flex justify-between px-6 py-3">
                        <span class="text-sm text-gray-500 dark:text-gray-400">Přesné skóre</span>
                        <span class="font-semibold text-amber-700 dark:text-amber-400">{{ stats.exactScores }}×</span>
                    </div>
                    <div class="flex justify-between px-6 py-3">
                        <span class="text-sm text-gray-500 dark:text-gray-400">Špatně</span>
                        <span class="font-semibold text-red-700 dark:text-red-400">{{ stats.wrongPredictions }}×</span>
                    </div>
                    <div class="flex justify-between px-6 py-3">
                        <span class="text-sm text-gray-500 dark:text-gray-400">Celkem tipů</span>
                        <span class="font-semibold dark:text-gray-100">{{ stats.totalPredictions }}</span>
                    </div>
                    {% if stats.bestMatchDay %}
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm text-gray-500 dark:text-gray-400">Nejlepší den</span>
                            <span class="font-semibold text-green-700 dark:text-green-400">{{ stats.bestMatchDay.points|number_format(2) }}b
                                <span class="text-xs text-gray-400 dark:text-gray-500">({{ stats.bestMatchDay.date|date('d.m.') }})</span>
                            </span>
                        </div>
                    {% endif %}
                    {% if stats.worstMatchDay %}
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm text-gray-500 dark:text-gray-400">Nejhorší den</span>
                            <span class="font-semibold text-red-700 dark:text-red-400">{{ stats.worstMatchDay.points|number_format(2) }}b
                                <span class="text-xs text-gray-400 dark:text-gray-500">({{ stats.worstMatchDay.date|date('d.m.') }})</span>
                            </span>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# Career stats #}
            {% if careerStats.tournamentsPlayed > 0 %}
                <div class="rounded-xl bg-white shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
                    <div class="border-b border-gray-200 bg-[#0f172a] px-6 py-4 dark:border-gray-700">
                        <h2 class="text-lg font-semibold text-white">
                            <svg class="mr-1 inline-block h-5 w-5 text-amber-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M5.166 2.621v.858c-1.035.148-2.059.33-3.071.543a.75.75 0 0 0-.584.859 6.753 6.753 0 0 0 6.138 5.6 6.73 6.73 0 0 0 2.743 1.346A6.707 6.707 0 0 1 9.279 15H8.54c-1.036 0-1.875.84-1.875 1.875V19.5h-.75a2.25 2.25 0 0 0-2.25 2.25c0 .414.336.75.75.75h15a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-2.25-2.25h-.75v-2.625c0-1.036-.84-1.875-1.875-1.875h-.739a6.706 6.706 0 0 1-1.112-3.173 6.73 6.73 0 0 0 2.743-1.347 6.753 6.753 0 0 0 6.139-5.6.75.75 0 0 0-.585-.858 47.077 47.077 0 0 0-3.07-.543V2.62a.75.75 0 0 0-.658-.744 49.798 49.798 0 0 0-6.093-.377c-2.063 0-4.096.128-6.093.377a.75.75 0 0 0-.657.744Zm0 2.629c0 1.196.312 2.32.857 3.294A5.266 5.266 0 0 1 3.16 5.337a45.6 45.6 0 0 1 2.006-.343v.256Zm13.5 0v-.256c.674.1 1.343.214 2.006.343a5.265 5.265 0 0 1-2.863 3.207 6.72 6.72 0 0 0 .857-3.294Z" clip-rule="evenodd" />
                            </svg>
                            Kariéra
                        </h2>
                    </div>
                    <div class="divide-y divide-gray-100 dark:divide-gray-700">
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm text-gray-500 dark:text-gray-400">Odehraných turnajů</span>
                            <span class="font-semibold dark:text-gray-100">{{ careerStats.tournamentsPlayed }}</span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm text-gray-500 dark:text-gray-400">Nejlepší umístění</span>
                            <span class="font-semibold dark:text-gray-100">
                                {% if careerStats.bestRank is not null %}{{ careerStats.bestRank }}.{% else %}—{% endif %}
                            </span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm text-gray-500 dark:text-gray-400">Průměrné pořadí</span>
                            <span class="font-semibold dark:text-gray-100">
                                {% if careerStats.averageRank is not null %}{{ careerStats.averageRank|number_format(2) }}{% else %}—{% endif %}
                            </span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm text-gray-500 dark:text-gray-400">Pódiová umístění</span>
                            <span class="font-semibold dark:text-gray-100">{{ careerStats.podiumFinishes }}</span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm text-gray-500 dark:text-gray-400">1. místo</span>
                            <span class="font-semibold text-amber-600 dark:text-amber-400">{{ careerStats.firstPlace }}×</span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm text-gray-500 dark:text-gray-400">2. místo</span>
                            <span class="font-semibold text-gray-500 dark:text-gray-300">{{ careerStats.secondPlace }}×</span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm text-gray-500 dark:text-gray-400">3. místo</span>
                            <span class="font-semibold text-amber-700 dark:text-amber-600">{{ careerStats.thirdPlace }}×</span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm text-gray-500 dark:text-gray-400">Celkem tipů</span>
                            <span class="font-semibold dark:text-gray-100">{{ careerStats.totalPredictions }}</span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm text-gray-500 dark:text-gray-400">Přesná skóre</span>
                            <span class="font-semibold text-amber-700 dark:text-amber-400">{{ careerStats.careerExactScores }}×</span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm text-gray-500 dark:text-gray-400">Správný vítěz</span>
                            <span class="font-semibold text-green-700 dark:text-green-400">{{ careerStats.careerCorrectWinners }}×</span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm text-gray-500 dark:text-gray-400">Celková úspěšnost</span>
                            <span class="font-semibold dark:text-gray-100">
                                {% if careerStats.careerAccuracy is not null %}{{ careerStats.careerAccuracy }}%{% else %}—{% endif %}
                            </span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm text-gray-500 dark:text-gray-400">Přesná skóre %</span>
                            <span class="font-semibold dark:text-gray-100">
                                {% if careerStats.careerExactRate is not null %}{{ careerStats.careerExactRate }}%{% else %}—{% endif %}
                            </span>
                        </div>
                        {% if careerStats.bestTournamentAccuracy is not null %}
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm text-gray-500 dark:text-gray-400">Nejlepší sezóna</span>
                            <span class="font-semibold text-green-700 dark:text-green-400">{{ careerStats.bestTournamentAccuracy }}%</span>
                        </div>
                        {% endif %}
                    </div>
                </div>
            {% endif %}

            {# Special bets #}
            {% if specialBets|length > 0 %}
                <div class="rounded-xl bg-white shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
                    <div class="border-b border-gray-200 bg-[#0f172a] px-6 py-4 dark:border-gray-700">
                        <h2 class="text-lg font-semibold text-white">⭐ Speciální tipy</h2>
                    </div>
                    <div class="divide-y divide-gray-100 dark:divide-gray-700">
                        {% for ruleId, bet in specialBets %}
                            <div class="flex items-center justify-between px-6 py-3">
                                <span class="text-sm text-gray-500 dark:text-gray-400">{{ bet.rule.name }}</span>
                                <span class="text-sm font-medium dark:text-gray-100">
                                    {% if bet.teamValue %}
                                        {{ team_flag(bet.teamValue.code) }} {{ bet.teamValue.code }}
                                    {% elseif bet.stringValue %}
                                        {{ bet.stringValue }}
                                    {% elseif bet.intValue is not null %}
                                        {{ bet.intValue }}
                                    {% endif %}
                                </span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>

        {# Match predictions #}
        <div class="lg:col-span-2">
            {% for phaseValue, games in groupedGames %}
                <div class="mb-4 mt-6 first:mt-0">
                    <h3 class="inline-block rounded-lg bg-[#0f172a] px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-white">
                        {{ phaseValue|phase_label }}
                    </h3>
                </div>
                <div class="mb-4 overflow-hidden rounded-xl bg-white shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
                    <div class="divide-y divide-gray-100 dark:divide-gray-700">
                        {% for game in games %}
                            {% set prediction = userPredictions[game.id] ?? null %}
                            <a href="{{ path('match_detail', {id: game.id}) }}" class="flex items-center gap-3 px-4 py-2.5 text-sm transition hover:bg-gray-50 dark:hover:bg-white/5 dark:text-gray-100 sm:px-6">
                                <span class="w-10 shrink-0 text-xs text-gray-400 dark:text-gray-500">{{ game.playedAt|date('d.m.') }}</span>
                                <div class="flex min-w-0 flex-1 items-center gap-2">
                                    <span class="w-16 text-right text-xs sm:w-20">{{ team_flag(game.homeTeam.code) }} {{ game.homeTeam.code }}</span>
                                    {% if game.isFinished %}
                                        <span class="w-10 text-center text-xs font-bold tabular-nums">{{ game.homeScore }}:{{ game.awayScore }}</span>
                                    {% else %}
                                        <span class="w-10 text-center text-xs text-gray-400 dark:text-gray-500">vs</span>
                                    {% endif %}
                                    <span class="w-16 text-xs sm:w-20">{{ team_flag(game.awayTeam.code) }} {{ game.awayTeam.code }}</span>
                                </div>
                                <div class="w-24 shrink-0 text-right">
                                    {% if prediction %}
                                        <span class="inline-block rounded border px-2 py-0.5 text-xs font-medium tabular-nums {{ prediction_badge_class(prediction, game) }}">
                                            {{ prediction.homeScore }}:{{ prediction.awayScore }}
                                        </span>
                                    {% else %}
                                        <span class="text-xs text-gray-300 dark:text-gray-600">—</span>
                                    {% endif %}
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
