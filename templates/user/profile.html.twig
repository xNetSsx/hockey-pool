{% extends 'base.html.twig' %}
{% from '_macros.html.twig' import prediction_badge_class %}

{% block title %}{{ player.username }} — Hockey Pool{% endblock %}

{% block body %}
    <a href="{{ path('homepage') }}" class="mb-4 inline-flex items-center gap-1 text-sm font-medium hover:underline" style="color:var(--fg-3)">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
        Zpět na žebříček
    </a>

    {# Profile header #}
    <div class="hp-card mb-8 p-6 sm:p-8">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-3xl font-bold" style="color:var(--fg)">{{ player.username }}</h1>
                <p class="mt-1 text-sm" style="color:var(--fg-3)">{{ tournament.name }}</p>
            </div>
            <div class="flex gap-4">
                <div class="rounded-xl px-5 py-3 text-center" style="background:var(--bg-3)">
                    <div class="text-2xl font-black" style="color:var(--accent)">{{ playerRank ?? '—' }}.</div>
                    <div class="text-xs" style="color:var(--fg-4)">Pořadí</div>
                </div>
                <div class="rounded-xl px-5 py-3 text-center" style="background:var(--bg-3)">
                    <div class="text-2xl font-black" style="color:var(--fg)">{{ playerPoints|number_format(2) }}</div>
                    <div class="text-xs" style="color:var(--fg-4)">Body</div>
                </div>
                <div class="rounded-xl px-5 py-3 text-center" style="background:var(--bg-3)">
                    <div class="text-2xl font-black" style="color:var(--fg)">{{ stats.accuracy }}%</div>
                    <div class="text-xs" style="color:var(--fg-4)">Úspěšnost</div>
                </div>
            </div>
        </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
        {# Stats cards #}
        <div class="space-y-6 lg:col-span-1">
            <div class="hp-card">
                <div class="hp-card-head" style="background:var(--bg-3)">
                    <h2 class="hp-card-title">Statistiky</h2>
                </div>
                <div class="divide-y" style="border-color:var(--line-soft)">
                    <div class="flex justify-between px-6 py-3">
                        <span class="text-sm" style="color:var(--fg-3)">Správný vítěz</span>
                        <span class="font-semibold" style="color:var(--pos)">{{ stats.correctWinners }}×</span>
                    </div>
                    <div class="flex justify-between px-6 py-3">
                        <span class="text-sm" style="color:var(--fg-3)">Přesné skóre</span>
                        <span class="font-semibold" style="color:var(--warn)">{{ stats.exactScores }}×</span>
                    </div>
                    <div class="flex justify-between px-6 py-3">
                        <span class="text-sm" style="color:var(--fg-3)">Špatně</span>
                        <span class="font-semibold" style="color:var(--neg)">{{ stats.wrongPredictions }}×</span>
                    </div>
                    <div class="flex justify-between px-6 py-3">
                        <span class="text-sm" style="color:var(--fg-3)">Celkem tipů</span>
                        <span class="font-semibold" style="color:var(--fg)">{{ stats.totalPredictions }}</span>
                    </div>
                    {% if stats.bestMatchDay %}
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm" style="color:var(--fg-3)">Nejlepší den</span>
                            <span class="font-semibold" style="color:var(--pos)">{{ stats.bestMatchDay.points|number_format(2) }}b
                                <span class="text-xs" style="color:var(--fg-4)">({{ stats.bestMatchDay.date|date('d.m.') }})</span>
                            </span>
                        </div>
                    {% endif %}
                    {% if stats.worstMatchDay %}
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm" style="color:var(--fg-3)">Nejhorší den</span>
                            <span class="font-semibold" style="color:var(--neg)">{{ stats.worstMatchDay.points|number_format(2) }}b
                                <span class="text-xs" style="color:var(--fg-4)">({{ stats.worstMatchDay.date|date('d.m.') }})</span>
                            </span>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# Career stats #}
            {% if careerStats.tournamentsPlayed > 0 %}
                <div class="hp-card">
                    <div class="hp-card-head" style="background:var(--bg-3)">
                        <h2 class="hp-card-title">
                            <svg class="mr-1 inline-block h-5 w-5" style="color:var(--warn)" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M5.166 2.621v.858c-1.035.148-2.059.33-3.071.543a.75.75 0 0 0-.584.859 6.753 6.753 0 0 0 6.138 5.6 6.73 6.73 0 0 0 2.743 1.346A6.707 6.707 0 0 1 9.279 15H8.54c-1.036 0-1.875.84-1.875 1.875V19.5h-.75a2.25 2.25 0 0 0-2.25 2.25c0 .414.336.75.75.75h15a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-2.25-2.25h-.75v-2.625c0-1.036-.84-1.875-1.875-1.875h-.739a6.706 6.706 0 0 1-1.112-3.173 6.73 6.73 0 0 0 2.743-1.347 6.753 6.753 0 0 0 6.139-5.6.75.75 0 0 0-.585-.858 47.077 47.077 0 0 0-3.07-.543V2.62a.75.75 0 0 0-.658-.744 49.798 49.798 0 0 0-6.093-.377c-2.063 0-4.096.128-6.093.377a.75.75 0 0 0-.657.744Zm0 2.629c0 1.196.312 2.32.857 3.294A5.266 5.266 0 0 1 3.16 5.337a45.6 45.6 0 0 1 2.006-.343v.256Zm13.5 0v-.256c.674.1 1.343.214 2.006.343a5.265 5.265 0 0 1-2.863 3.207 6.72 6.72 0 0 0 .857-3.294Z" clip-rule="evenodd" />
                            </svg>
                            Kariéra
                        </h2>
                    </div>
                    <div class="divide-y" style="border-color:var(--line-soft)">
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm" style="color:var(--fg-3)">Odehraných turnajů</span>
                            <span class="font-semibold" style="color:var(--fg)">{{ careerStats.tournamentsPlayed }}</span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm" style="color:var(--fg-3)">Nejlepší umístění</span>
                            <span class="font-semibold" style="color:var(--fg)">
                                {% if careerStats.bestRank is not null %}{{ careerStats.bestRank }}.{% else %}—{% endif %}
                            </span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm" style="color:var(--fg-3)">Průměrné pořadí</span>
                            <span class="font-semibold" style="color:var(--fg)">
                                {% if careerStats.averageRank is not null %}{{ careerStats.averageRank|number_format(2) }}{% else %}—{% endif %}
                            </span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm" style="color:var(--fg-3)">Pódiová umístění</span>
                            <span class="font-semibold" style="color:var(--fg)">{{ careerStats.podiumFinishes }}</span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm" style="color:var(--fg-3)">1. místo</span>
                            <span class="font-semibold" style="color:var(--warn)">{{ careerStats.firstPlace }}×</span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm" style="color:var(--fg-3)">2. místo</span>
                            <span class="font-semibold" style="color:var(--fg-2)">{{ careerStats.secondPlace }}×</span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm" style="color:var(--fg-3)">3. místo</span>
                            <span class="font-semibold" style="color:var(--warn)">{{ careerStats.thirdPlace }}×</span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm" style="color:var(--fg-3)">Celkem tipů</span>
                            <span class="font-semibold" style="color:var(--fg)">{{ careerStats.totalPredictions }}</span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm" style="color:var(--fg-3)">Přesná skóre</span>
                            <span class="font-semibold" style="color:var(--warn)">{{ careerStats.careerExactScores }}×</span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm" style="color:var(--fg-3)">Správný vítěz</span>
                            <span class="font-semibold" style="color:var(--pos)">{{ careerStats.careerCorrectWinners }}×</span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm" style="color:var(--fg-3)">Celková úspěšnost</span>
                            <span class="font-semibold" style="color:var(--fg)">
                                {% if careerStats.careerAccuracy is not null %}{{ careerStats.careerAccuracy }}%{% else %}—{% endif %}
                            </span>
                        </div>
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm" style="color:var(--fg-3)">Přesná skóre %</span>
                            <span class="font-semibold" style="color:var(--fg)">
                                {% if careerStats.careerExactRate is not null %}{{ careerStats.careerExactRate }}%{% else %}—{% endif %}
                            </span>
                        </div>
                        {% if careerStats.bestTournamentAccuracy is not null %}
                        <div class="flex justify-between px-6 py-3">
                            <span class="text-sm" style="color:var(--fg-3)">Nejlepší sezóna</span>
                            <span class="font-semibold" style="color:var(--pos)">{{ careerStats.bestTournamentAccuracy }}%</span>
                        </div>
                        {% endif %}
                    </div>
                </div>
            {% endif %}

            {# Special bets #}
            {% if specialBets|length > 0 %}
                <div class="hp-card">
                    <div class="hp-card-head" style="background:var(--bg-3)">
                        <h2 class="hp-card-title">Speciální tipy</h2>
                    </div>
                    <div class="divide-y" style="border-color:var(--line-soft)">
                        {% for ruleId, bet in specialBets %}
                            <div class="flex items-center justify-between px-6 py-3">
                                <span class="text-sm" style="color:var(--fg-3)">{{ bet.rule.name }}</span>
                                <span class="text-sm font-medium" style="color:var(--fg)">
                                    {% if bet.teamValue %}
                                        {{ team_flag(bet.teamValue.code) }} {{ bet.teamValue.code }}
                                    {% elseif bet.stringValue %}
                                        {{ bet.stringValue }}
                                    {% elseif bet.intValue is not null %}
                                        {{ bet.intValue }}
                                    {% endif %}
                                </span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>

        {# Match predictions #}
        <div class="lg:col-span-2">
            {% for phaseValue, games in groupedGames %}
                <div class="mb-4 mt-6 first:mt-0">
                    <h3 class="hp-chip hp-chip-accent inline-block text-xs font-semibold uppercase tracking-wider">
                        {{ phaseValue|phase_label }}
                    </h3>
                </div>
                <div class="hp-card mb-4">
                    <div class="divide-y" style="border-color:var(--line-soft)">
                        {% for game in games %}
                            {% set prediction = userPredictions[game.id] ?? null %}
                            <a href="{{ path('match_detail', {id: game.id}) }}" class="flex items-center gap-3 px-4 py-2.5 text-sm transition sm:px-6" style="color:var(--fg)">
                                <span class="w-10 shrink-0 text-xs" style="color:var(--fg-4)">{{ game.playedAt|date('d.m.') }}</span>
                                <div class="flex min-w-0 flex-1 items-center gap-2">
                                    <span class="w-16 text-right text-xs sm:w-20">{{ team_flag(game.homeTeam.code) }} {{ game.homeTeam.code }}</span>
                                    {% if game.isFinished %}
                                        <span class="w-10 text-center text-xs font-bold tabular-nums">{{ game.homeScore }}:{{ game.awayScore }}</span>
                                    {% else %}
                                        <span class="w-10 text-center text-xs" style="color:var(--fg-4)">vs</span>
                                    {% endif %}
                                    <span class="w-16 text-xs sm:w-20">{{ team_flag(game.awayTeam.code) }} {{ game.awayTeam.code }}</span>
                                </div>
                                <div class="w-24 shrink-0 text-right">
                                    {% if prediction %}
                                        <span class="inline-block rounded border px-2 py-0.5 text-xs font-medium tabular-nums {{ prediction_badge_class(prediction, game) }}">
                                            {{ prediction.homeScore }}:{{ prediction.awayScore }}
                                        </span>
                                    {% else %}
                                        <span class="text-xs" style="color:var(--fg-4)">—</span>
                                    {% endif %}
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
