{% extends 'base.html.twig' %}

{% block title %}Změna hesla — Hockey Pool{% endblock %}

{% set input_class = 'w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-gray-900 placeholder-gray-400 focus:border-[#38bdf8] focus:outline-none focus:ring-2 focus:ring-[#38bdf8]/20 dark:border-gray-600 dark:bg-[#0f172a] dark:text-white dark:placeholder-gray-500' %}
{% set label_class = 'mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300' %}

{% block body %}
    <div class="flex min-h-[60vh] items-center justify-center">
        <div class="w-full max-w-md px-4">
            <div class="rounded-2xl bg-white p-8 shadow-lg dark:bg-[#1e293b]">
                <h1 class="mb-6 text-center text-2xl font-bold text-gray-900 dark:text-white">Změna hesla</h1>

                {{ form_start(form, { attr: { class: 'space-y-4' } }) }}
                    <div>
                        {{ form_label(form.currentPassword, null, { label_attr: { class: label_class } }) }}
                        {{ form_widget(form.currentPassword, { attr: { class: input_class } }) }}
                        {{ form_errors(form.currentPassword, { attr: { class: 'mt-1 text-sm text-red-600 dark:text-red-400' } }) }}
                    </div>

                    <div>
                        {{ form_label(form.newPassword.first, null, { label_attr: { class: label_class } }) }}
                        {{ form_widget(form.newPassword.first, { attr: { class: input_class } }) }}
                        {{ form_errors(form.newPassword.first, { attr: { class: 'mt-1 text-sm text-red-600 dark:text-red-400' } }) }}
                    </div>

                    <div>
                        {{ form_label(form.newPassword.second, null, { label_attr: { class: label_class } }) }}
                        {{ form_widget(form.newPassword.second, { attr: { class: input_class } }) }}
                        {{ form_errors(form.newPassword.second, { attr: { class: 'mt-1 text-sm text-red-600 dark:text-red-400' } }) }}
                    </div>

                    <button
                        type="submit"
                        class="w-full rounded-lg bg-[#0f172a] px-4 py-2.5 font-semibold text-white shadow-sm hover:bg-[#1e293b] focus:outline-none focus:ring-2 focus:ring-[#38bdf8] focus:ring-offset-2 dark:bg-[#38bdf8] dark:text-[#0f172a] dark:hover:bg-[#7dd3fc]"
                    >
                        Změnit heslo
                    </button>
                {{ form_end(form) }}

                <div class="mt-4 text-center">
                    <a href="{{ path('homepage') }}" class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">Zpět</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
