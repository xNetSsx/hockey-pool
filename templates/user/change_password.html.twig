{% extends 'base.html.twig' %}

{% block title %}Změna hesla — Hockey Pool{% endblock %}

{% block body %}
    <div class="flex min-h-[60vh] items-center justify-center">
        <div class="w-full max-w-md px-4">
            <div class="hp-card p-8">
                <h1 class="mb-6 text-center text-2xl font-bold" style="color:var(--fg)">Změna hesla</h1>

                {{ form_start(form, { attr: { class: 'space-y-4' } }) }}
                    <div class="hp-field">
                        {{ form_label(form.currentPassword, null, { label_attr: { class: 'hp-field-label' } }) }}
                        {{ form_widget(form.currentPassword, { attr: { class: 'hp-field-input w-full' } }) }}
                        {{ form_errors(form.currentPassword, { attr: { class: 'mt-1 text-sm', style: 'color:var(--neg)' } }) }}
                    </div>

                    <div class="hp-field">
                        {{ form_label(form.newPassword.first, null, { label_attr: { class: 'hp-field-label' } }) }}
                        {{ form_widget(form.newPassword.first, { attr: { class: 'hp-field-input w-full' } }) }}
                        {{ form_errors(form.newPassword.first, { attr: { class: 'mt-1 text-sm', style: 'color:var(--neg)' } }) }}
                    </div>

                    <div class="hp-field">
                        {{ form_label(form.newPassword.second, null, { label_attr: { class: 'hp-field-label' } }) }}
                        {{ form_widget(form.newPassword.second, { attr: { class: 'hp-field-input w-full' } }) }}
                        {{ form_errors(form.newPassword.second, { attr: { class: 'mt-1 text-sm', style: 'color:var(--neg)' } }) }}
                    </div>

                    <button type="submit" class="hp-btn hp-btn-primary w-full">
                        Změnit heslo
                    </button>
                {{ form_end(form) }}

                <div class="mt-4 text-center">
                    <a href="{{ path('player_profile', {username: user.username}) }}" class="text-sm hover:underline" style="color:var(--fg-3)">Zpět</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
