{% extends 'base.html.twig' %}

{% block title %}Změna hesla — Hockey Pool{% endblock %}

{% block body %}
    <div class="flex min-h-[60vh] items-center justify-center">
        <div class="w-full max-w-md">
            <div class="rounded-2xl bg-white p-8 shadow-lg">
                <h1 class="mb-6 text-center text-2xl font-bold text-gray-900">Změna hesla</h1>

                {{ form_start(form, { attr: { class: 'space-y-4' } }) }}
                    <div>
                        {{ form_label(form.currentPassword, null, {
                            label_attr: { class: 'mb-1 block text-sm font-medium text-gray-700' }
                        }) }}
                        {{ form_widget(form.currentPassword, {
                            attr: { class: 'w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 placeholder-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20' }
                        }) }}
                        {{ form_errors(form.currentPassword, { attr: { class: 'mt-1 text-sm text-red-600' } }) }}
                    </div>

                    <div>
                        {{ form_label(form.newPassword.first, null, {
                            label_attr: { class: 'mb-1 block text-sm font-medium text-gray-700' }
                        }) }}
                        {{ form_widget(form.newPassword.first, {
                            attr: { class: 'w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 placeholder-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20' }
                        }) }}
                        {{ form_errors(form.newPassword.first, { attr: { class: 'mt-1 text-sm text-red-600' } }) }}
                    </div>

                    <div>
                        {{ form_label(form.newPassword.second, null, {
                            label_attr: { class: 'mb-1 block text-sm font-medium text-gray-700' }
                        }) }}
                        {{ form_widget(form.newPassword.second, {
                            attr: { class: 'w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 placeholder-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20' }
                        }) }}
                        {{ form_errors(form.newPassword.second, { attr: { class: 'mt-1 text-sm text-red-600' } }) }}
                    </div>

                    <button
                        type="submit"
                        class="w-full rounded-lg bg-blue-600 px-4 py-2.5 font-semibold text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
                    >
                        Změnit heslo
                    </button>
                {{ form_end(form) }}

                <div class="mt-4 text-center">
                    <a href="{{ path('homepage') }}" class="text-sm text-gray-500 hover:text-gray-700">Zpět</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
