{% extends 'base.html.twig' %}

{% block title %}{{ player.username }} — Hockey Pool{% endblock %}

{% block body %}
    <div class="flex min-h-[50vh] items-center justify-center">
        <div class="text-center">
            <div class="mb-4 text-6xl">🏒</div>
            <h1 class="text-2xl font-bold" style="color:var(--fg)">{{ player.username }}</h1>
            <p class="mt-2" style="color:var(--fg-3)">Žádný turnaj k zobrazení.</p>
            <a href="{{ path('tournament_archive') }}" class="hp-btn hp-btn-primary mt-4 inline-flex text-sm">Podívej se na archiv turnajů</a>
        </div>
    </div>
{% endblock %}
