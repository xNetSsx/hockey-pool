{% extends 'base.html.twig' %}

{% block title %}Porovnání: {{ users|map(u => u.username)|join(' vs ') }} — Hockey Pool{% endblock %}

{% set colors = ['text-blue-600', 'text-red-600', 'text-green-600', 'text-purple-600'] %}
{% set bgColors = ['bg-blue-50 dark:bg-blue-900/20', 'bg-red-50 dark:bg-red-900/20', 'bg-green-50 dark:bg-green-900/20', 'bg-purple-50 dark:bg-purple-900/20'] %}

{% block body %}
    <div class="mb-6">
        <a href="{{ path('player_compare') }}" class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">← Změnit výběr</a>
    </div>

    <h1 class="mb-6 text-2xl font-bold text-gray-900 dark:text-white">⚔️ {{ users|map(u => u.username)|join(' vs ') }}</h1>

    {# Stats comparison cards #}
    <div class="mb-8 grid gap-4 {{ users|length == 2 ? 'grid-cols-2' : 'grid-cols-' ~ users|length }}">
        {% for user in users %}
            {% set stats = userStats[user.id] %}
            {% set lb = leaderboardByUserId[user.id] ?? null %}
            <div class="rounded-xl bg-white p-5 shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
                <div class="mb-3 text-center">
                    <h2 class="text-lg font-bold {{ colors[loop.index0 % colors|length] }}">{{ user.username }}</h2>
                    <div class="mt-1 text-2xl font-black dark:text-gray-100">{{ lb ? lb.totalPoints|number_format(2) : '0.00' }}</div>
                    <div class="text-xs text-gray-400 dark:text-gray-500">{{ lb ? lb.rank ~ '. místo' : '—' }}</div>
                </div>
                <div class="space-y-1.5 text-xs">
                    <div class="flex justify-between">
                        <span class="text-gray-500 dark:text-gray-400">Úspěšnost</span>
                        <span class="font-semibold dark:text-gray-100">{{ stats.accuracy }}%</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500 dark:text-gray-400">Správný vítěz</span>
                        <span class="font-semibold text-green-700 dark:text-green-400">{{ stats.correctWinners }}×</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500 dark:text-gray-400">Přesné skóre</span>
                        <span class="font-semibold text-amber-700 dark:text-amber-400">{{ stats.exactScores }}×</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500 dark:text-gray-400">Špatně</span>
                        <span class="font-semibold text-red-700 dark:text-red-400">{{ stats.wrongPredictions }}×</span>
                    </div>
                    {% if stats.bestMatchDay %}
                        <div class="flex justify-between">
                            <span class="text-gray-500 dark:text-gray-400">Nejlepší den</span>
                            <span class="font-semibold dark:text-gray-100">{{ stats.bestMatchDay.points|number_format(2) }}b</span>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>

    {# Match-by-match comparison #}
    <div class="overflow-hidden rounded-xl bg-white shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
        <div class="border-b border-gray-200 bg-[#0f172a] px-6 py-4 dark:border-gray-700">
            <h2 class="text-lg font-semibold text-white">Zápas po zápase</h2>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-100 bg-gray-50 text-xs uppercase tracking-wider text-gray-500 dark:border-gray-700 dark:bg-[#0f172a] dark:text-gray-400">
                        <th class="px-4 py-3 text-left">Zápas</th>
                        <th class="px-3 py-3 text-center">Výsledek</th>
                        {% for user in users %}
                            <th class="px-3 py-3 text-center {{ colors[loop.index0 % colors|length] }}">
                                {{ user.username }}
                            </th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% for game in comparison.games %}
                        {% if game.isFinished %}
                            {# Find who scored most this match #}
                            {% set maxPoints = 0 %}
                            {% for user in users %}
                                {% set pts = comparison.matchPoints[user.id][game.id] ?? 0 %}
                                {% if pts > maxPoints %}{% set maxPoints = pts %}{% endif %}
                            {% endfor %}

                            <tr class="border-b border-gray-100 last:border-0 dark:border-gray-700 dark:text-gray-100">
                                <td class="whitespace-nowrap px-4 py-2.5">
                                    <span class="text-xs">
                                        {{ team_flag(game.homeTeam.code) }} {{ game.homeTeam.code }}
                                        <span class="text-gray-400 dark:text-gray-500">vs</span>
                                        {{ team_flag(game.awayTeam.code) }} {{ game.awayTeam.code }}
                                    </span>
                                </td>
                                <td class="px-3 py-2.5 text-center">
                                    <span class="text-xs font-bold tabular-nums">{{ game.homeScore }}:{{ game.awayScore }}</span>
                                </td>
                                {% for user in users %}
                                    {% set prediction = comparison.predictions[user.id][game.id] ?? null %}
                                    {% set pts = comparison.matchPoints[user.id][game.id] ?? 0 %}
                                    {% set running = comparison.runningTotals[user.id][game.id] ?? 0 %}
                                    {% set isBest = pts > 0 and pts == maxPoints %}
                                    <td class="px-3 py-2.5 text-center {{ isBest ? bgColors[loop.index0 % bgColors|length] : '' }}">
                                        {% if prediction %}
                                            <span class="tabular-nums text-xs">{{ prediction.homeScore }}:{{ prediction.awayScore }}</span>
                                            {% if pts > 0 %}
                                                <span class="ml-1 text-xs font-semibold text-green-700 dark:text-green-400">+{{ pts|number_format(2) }}</span>
                                            {% endif %}
                                            <div class="text-[10px] tabular-nums text-gray-400 dark:text-gray-500">Σ {{ running|number_format(2) }}</div>
                                        {% else %}
                                            <span class="text-xs text-gray-300 dark:text-gray-600">—</span>
                                        {% endif %}
                                    </td>
                                {% endfor %}
                            </tr>
                        {% endif %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
