{% extends 'base.html.twig' %}

{% block title %}Porovnání: {{ users|map(u => u.username)|join(' vs ') }} — Hockey Pool{% endblock %}

{% set colors = ['text-blue-600', 'text-red-600', 'text-green-600', 'text-purple-600'] %}
{% set bgColors = ['bg-blue-50', 'bg-red-50', 'bg-green-50', 'bg-purple-50'] %}

{% block body %}
    <div class="mb-6">
        <a href="{{ path('player_compare') }}" class="text-sm text-gray-500 hover:text-gray-700">← Změnit výběr</a>
    </div>

    <h1 class="mb-6 text-2xl font-bold text-gray-900">⚔️ {{ users|map(u => u.username)|join(' vs ') }}</h1>

    {# Stats comparison cards #}
    <div class="mb-8 grid gap-4 {{ users|length == 2 ? 'grid-cols-2' : 'grid-cols-' ~ users|length }}">
        {% for user in users %}
            {% set stats = userStats[user.id] %}
            {% set lb = leaderboardByUserId[user.id] ?? null %}
            <div class="rounded-xl bg-white p-5 shadow">
                <div class="mb-3 text-center">
                    <h2 class="text-lg font-bold {{ colors[loop.index0 % colors|length] }}">{{ user.username }}</h2>
                    <div class="mt-1 text-2xl font-black">{{ lb ? lb.totalPoints|number_format(2) : '0.00' }}</div>
                    <div class="text-xs text-gray-400">{{ lb ? lb.rank ~ '. místo' : '—' }}</div>
                </div>
                <div class="space-y-1.5 text-xs">
                    <div class="flex justify-between">
                        <span class="text-gray-500">Úspěšnost</span>
                        <span class="font-semibold">{{ stats.accuracy }}%</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Správný vítěz</span>
                        <span class="font-semibold text-green-700">{{ stats.correctWinners }}×</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Přesné skóre</span>
                        <span class="font-semibold text-amber-700">{{ stats.exactScores }}×</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Špatně</span>
                        <span class="font-semibold text-red-700">{{ stats.wrongPredictions }}×</span>
                    </div>
                    {% if stats.bestMatchDay %}
                        <div class="flex justify-between">
                            <span class="text-gray-500">Nejlepší den</span>
                            <span class="font-semibold">{{ stats.bestMatchDay.points|number_format(2) }}b</span>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>

    {# Match-by-match comparison #}
    <div class="overflow-hidden rounded-xl bg-white shadow">
        <div class="border-b border-gray-200 bg-[#0f172a] px-6 py-4">
            <h2 class="text-lg font-semibold text-white">Zápas po zápase</h2>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-100 bg-gray-50 text-xs uppercase tracking-wider text-gray-500">
                        <th class="px-4 py-3 text-left">Zápas</th>
                        <th class="px-3 py-3 text-center">Výsledek</th>
                        {% for user in users %}
                            <th class="px-3 py-3 text-center {{ colors[loop.index0 % colors|length] }}">
                                {{ user.username }}
                            </th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% for game in comparison.games %}
                        {% if game.isFinished %}
                            {# Find who scored most this match #}
                            {% set maxPoints = 0 %}
                            {% for user in users %}
                                {% set pts = comparison.matchPoints[user.id][game.id] ?? 0 %}
                                {% if pts > maxPoints %}{% set maxPoints = pts %}{% endif %}
                            {% endfor %}

                            <tr class="border-b border-gray-100 last:border-0">
                                <td class="whitespace-nowrap px-4 py-2.5">
                                    <span class="text-xs">
                                        {{ game.homeTeam.flagEmoji }} {{ game.homeTeam.code }}
                                        <span class="text-gray-400">vs</span>
                                        {{ game.awayTeam.flagEmoji }} {{ game.awayTeam.code }}
                                    </span>
                                </td>
                                <td class="px-3 py-2.5 text-center">
                                    <span class="text-xs font-bold tabular-nums">{{ game.homeScore }}:{{ game.awayScore }}</span>
                                </td>
                                {% for user in users %}
                                    {% set prediction = comparison.predictions[user.id][game.id] ?? null %}
                                    {% set pts = comparison.matchPoints[user.id][game.id] ?? 0 %}
                                    {% set running = comparison.runningTotals[user.id][game.id] ?? 0 %}
                                    {% set isBest = pts > 0 and pts == maxPoints %}
                                    <td class="px-3 py-2.5 text-center {{ isBest ? bgColors[loop.index0 % bgColors|length] : '' }}">
                                        {% if prediction %}
                                            <span class="tabular-nums text-xs">{{ prediction.homeScore }}:{{ prediction.awayScore }}</span>
                                            {% if pts > 0 %}
                                                <span class="ml-1 text-xs font-semibold text-green-700">+{{ pts|number_format(2) }}</span>
                                            {% endif %}
                                            <div class="text-[10px] tabular-nums text-gray-400">Σ {{ running|number_format(2) }}</div>
                                        {% else %}
                                            <span class="text-xs text-gray-300">—</span>
                                        {% endif %}
                                    </td>
                                {% endfor %}
                            </tr>
                        {% endif %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
