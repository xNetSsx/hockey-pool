{% extends 'base.html.twig' %}

{% block title %}Porovnat hráče — Hockey Pool{% endblock %}

{% set avatarColors = [
    '#3b82f6', '#f43f5e', '#10b981', '#8b5cf6',
    '#f59e0b', '#06b6d4', '#ec4899', '#14b8a6',
    '#f97316', '#6366f1', '#84cc16', '#d946ef',
    '#0ea5e9', '#b91c1c', '#15803d', '#7e22ce',
] %}

{% block body %}
    <div class="mx-auto max-w-lg">
        <h1 class="mb-6 text-2xl font-bold text-gray-900 dark:text-white">Porovnat hráče</h1>

        <div class="rounded-xl bg-white p-6 shadow dark:bg-[#1e293b] dark:shadow-gray-900/30"
             data-controller="compare-select">
            <form method="get" action="{{ path('player_compare') }}">
                <p class="mb-4 text-sm text-gray-500 dark:text-gray-400">Vyber alespoň 2 hráče k porovnání:</p>

                {% if players is empty %}
                    <p class="py-8 text-center text-sm text-gray-400 dark:text-gray-500">Žádný aktivní turnaj.</p>
                {% else %}
                    <div class="grid grid-cols-2 gap-3">
                        {% for player in players %}
                            {% set color = avatarColors[loop.index0 % avatarColors|length] %}
                            <label class="relative flex cursor-pointer flex-col items-center gap-3 rounded-xl border-2 border-gray-200 p-4 transition hover:border-green-400 dark:border-gray-700 dark:hover:border-green-400">
                                <input type="checkbox" name="users[]" value="{{ player.username }}"
                                       class="sr-only"
                                       data-action="change->compare-select#update">
                                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-lg font-bold text-white"
                                     style="background-color: {{ color }}">
                                    {{ player.username|slice(0, 1)|upper }}
                                </div>
                                <span class="text-sm font-semibold text-gray-800 dark:text-gray-100">{{ player.username }}</span>
                            </label>
                        {% endfor %}
                    </div>

                    <div class="mt-5 flex items-center justify-between">
                        <span class="text-sm text-gray-500 dark:text-gray-400" data-compare-select-target="counter">Vybráno: 0</span>
                        <div class="flex items-center gap-2">
                            <button type="button"
                                    data-action="click->compare-select#compareAll"
                                    class="rounded-lg border border-gray-300 px-4 py-2.5 text-sm font-semibold text-gray-700 transition hover:border-gray-400 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#38bdf8] focus:ring-offset-2 dark:border-gray-600 dark:text-gray-300 dark:hover:border-gray-500 dark:hover:bg-gray-800">
                                Porovnat vše
                            </button>
                            <button type="submit"
                                    data-compare-select-target="submit"
                                    disabled
                                    class="rounded-lg bg-[#0f172a] px-6 py-2.5 font-semibold text-white transition hover:bg-[#1e293b] focus:outline-none focus:ring-2 focus:ring-[#38bdf8] focus:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-40 dark:bg-[#38bdf8] dark:text-[#0f172a] dark:hover:bg-[#7dd3fc] dark:disabled:opacity-30">
                                Porovnat
                            </button>
                        </div>
                    </div>
                {% endif %}
            </form>
        </div>
    </div>
{% endblock %}
