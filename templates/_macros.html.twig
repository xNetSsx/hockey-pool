{# Reusable Twig macros for base layout components #}

{#
 # Renders the moon/sun SVG icon pair used by the theme toggle Stimulus controller.
 # The darkIcon is visible in light mode (clicking switches to dark), and vice versa.
 #}
{% macro theme_icons() %}
    <svg {{ stimulus_target('theme', 'darkIcon') }} class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
    </svg>
    <svg {{ stimulus_target('theme', 'lightIcon') }} class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
    </svg>
{% endmacro %}

{#
 # Returns the CSS class string for a nav link.
 #   active  — boolean, whether this link matches the current route
 #   mobile  — boolean, use mobile-menu variant (slightly different inactive colour)
 #}
{% macro prediction_badge_class(prediction, game) -%}
    {%- if not game.isFinished -%}
        bg-blue-50 text-blue-700 border-blue-200 dark:bg-blue-900/30 dark:text-blue-300 dark:border-blue-700
    {%- elseif prediction.isExactScore(game) -%}
        bg-amber-100 text-amber-800 border-amber-300 dark:bg-amber-900/30 dark:text-amber-300 dark:border-amber-700
    {%- elseif prediction.isCorrectWinner(game) -%}
        bg-green-100 text-green-800 border-green-300 dark:bg-green-900/30 dark:text-green-300 dark:border-green-700
    {%- else -%}
        bg-red-100 text-red-800 border-red-300 dark:bg-red-900/30 dark:text-red-300 dark:border-red-700
    {%- endif -%}
{% endmacro %}

{% macro nav_link_class(active, mobile = false) -%}
    {%- if active -%}
        bg-gray-100 text-gray-900 dark:bg-white/10 dark:text-white
    {%- elseif mobile -%}
        text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-white/10
    {%- else -%}
        text-gray-600 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-300 dark:hover:bg-white/10 dark:hover:text-white
    {%- endif -%}
{% endmacro %}
