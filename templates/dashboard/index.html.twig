{% extends 'base.html.twig' %}
{% import '_macros.html.twig' as m %}

{% block title %}{{ tournament.name }} — Hockey Pool{% endblock %}

{% block body %}
    {# ═══ Hero band ═══ #}
    <div style="display:grid;grid-template-columns:1.2fr 1fr;gap:16px;margin-bottom:24px" class="hp-hero-grid">

        {# ── Tournament banner ── #}
        <div class="hp-card" style="padding:24px;position:relative;overflow:hidden">
            <div style="position:absolute;inset:0;pointer-events:none;background:radial-gradient(circle at 80% -20%, color-mix(in oklab, var(--accent) 25%, transparent), transparent 60%)"></div>
            <div style="position:relative">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
                    {% if not isFinished %}
                        <span class="hp-chip hp-chip-accent"><span class="hp-live-dot" style="background:var(--accent)"></span> PROBÍHÁ</span>
                    {% else %}
                        <span class="hp-chip">UKONČEN</span>
                    {% endif %}
                    <span class="hp-chip">{{ tournament.name }}</span>
                </div>

                <h1 style="font-family:var(--font-display);font-size:48px;line-height:0.95;margin:6px 0 4px;letter-spacing:-0.02em;font-weight:800;color:var(--fg)">
                    {{ tournament.name|upper }}
                </h1>

                <div style="color:var(--fg-3);font-size:14px">
                    {% if isFinished %}
                        Turnaj ukončen · {{ matchesPlayed }} zápasů odehráno
                    {% else %}
                        {{ matchesPlayed }} z {{ matchesTotal }} zápasů odehráno
                    {% endif %}
                </div>

                {% if leaderboard|length > 0 %}
                    <div style="display:flex;gap:20px;margin-top:22px;align-items:center">
                        <div>
                            <div class="hp-label">Vedoucí</div>
                            <div style="display:flex;align-items:center;gap:10px;margin-top:6px">
                                {{ m.avatar(leaderboard[0].user.username, 'lg') }}
                                <div>
                                    <div style="font-weight:700;font-size:18px;color:var(--fg)">{{ leaderboard[0].user.username }}</div>
                                    <div style="font-family:var(--font-mono);font-size:13px;color:var(--fg-3)"><span data-controller="countup" data-countup-value-value="{{ leaderboard[0].totalPoints }}" data-countup-decimals-value="2">{{ leaderboard[0].totalPoints|number_format(2) }}</span> b.</div>
                                </div>
                            </div>
                        </div>
                        {% if todayPoints|length > 0 %}
                            {% set bestToday = null %}
                            {% set bestTodayPts = 0 %}
                            {% for row in leaderboard %}
                                {% set tp = todayPoints[row.user.id] ?? 0 %}
                                {% if tp > bestTodayPts %}
                                    {% set bestToday = row %}
                                    {% set bestTodayPts = tp %}
                                {% endif %}
                            {% endfor %}
                            {% if bestToday %}
                                <div class="hp-divider" style="height:44px"></div>
                                <div>
                                    <div class="hp-label">Dnes nejvíc</div>
                                    <div style="display:flex;align-items:center;gap:10px;margin-top:6px">
                                        {{ m.avatar(bestToday.user.username, 'lg') }}
                                        <div>
                                            <div style="font-weight:700;font-size:18px;color:var(--fg)">{{ bestToday.user.username }}</div>
                                            <div style="font-family:var(--font-mono);font-size:13px;color:var(--pos)">+{{ bestTodayPts|number_format(2) }} b.</div>
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        {% endif %}
                    </div>
                {% endif %}

                {# Medal podium for finished tournaments #}
                {% if isFinished and medalRules|length >= 3 %}
                    <div style="display:flex;align-items:end;gap:6px;margin-top:20px">
                        <div style="display:flex;flex-direction:column;align-items:center;padding:10px 8px 8px;background:var(--bg-3);border-radius:var(--radius-sm);width:56px">
                            <span style="font-size:16px" aria-hidden="true">🥈</span>
                            <div style="margin:4px 0">{{ team_flag(medalRules[1].actualTeamValue.code) }}</div>
                            <span style="font-size:12px;font-weight:500;color:var(--fg-2)">{{ medalRules[1].actualTeamValue.code }}</span>
                        </div>
                        <div style="display:flex;flex-direction:column;align-items:center;padding:16px 8px 8px;background:var(--bg-3);border-radius:var(--radius-sm);width:64px">
                            <span style="font-size:18px;color:var(--warn)" aria-hidden="true">🥇</span>
                            <div style="margin:4px 0">{{ team_flag(medalRules[0].actualTeamValue.code) }}</div>
                            <span style="font-size:13px;font-weight:700;color:var(--fg)">{{ medalRules[0].actualTeamValue.code }}</span>
                        </div>
                        <div style="display:flex;flex-direction:column;align-items:center;padding:6px 8px 8px;background:var(--bg-3);border-radius:var(--radius-sm);width:56px">
                            <span style="font-size:16px" aria-hidden="true">🥉</span>
                            <div style="margin:4px 0">{{ team_flag(medalRules[2].actualTeamValue.code) }}</div>
                            <span style="font-size:12px;font-weight:500;color:var(--fg-2)">{{ medalRules[2].actualTeamValue.code }}</span>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>

        {# ── Right column: My position + upcoming ── #}
        <div style="display:flex;flex-direction:column;gap:16px">
            {# Your position card #}
            {% set myRank = null %}
            {% set myRow = null %}
            {% for row in leaderboard %}
                {% if currentUser and currentUser.id == row.user.id %}
                    {% set myRank = row.rank %}
                    {% set myRow = row %}
                {% endif %}
            {% endfor %}
            {% if myRow %}
                <div class="hp-card" style="padding:20px;background:linear-gradient(135deg, color-mix(in oklab, var(--accent) 18%, var(--bg-2)), var(--bg-2))">
                    <div class="hp-label" style="color:var(--fg-3)">Tvoje pozice</div>
                    <div style="display:flex;align-items:center;gap:16px;margin-top:12px">
                        {{ m.rank_chip(myRank, true) }}
                        {{ m.avatar(myRow.user.username, 'lg') }}
                        <div style="flex:1">
                            <div style="font-weight:700;font-size:20px;letter-spacing:-0.01em;color:var(--fg)">{{ myRow.user.username }}</div>
                            {% set myToday = todayPoints[myRow.user.id] ?? 0 %}
                            <div style="font-size:12px;color:var(--fg-3)">
                                {% set myStreak = playerStreaks[myRow.user.id] ?? null %}
                                {% if myStreak and myStreak.hot %}
                                    <span style="color:var(--warn)">🔥 Streak {{ myStreak.streak }}</span> ·
                                {% elseif myStreak and myStreak.cold %}
                                    <span style="color:var(--accent-2)">❄ Studená {{ myStreak.streak }}</span> ·
                                {% endif %}
                                {% if myToday > 0 %}
                                    dnes +{{ myToday|number_format(2) }}
                                {% else %}
                                    dnes zatím 0 b.
                                {% endif %}
                            </div>
                        </div>
                        <div style="text-align:right">
                            <div class="hp-pts hp-pts-xl" style="line-height:1;color:var(--fg)"
                                 data-controller="countup" data-countup-value-value="{{ myRow.totalPoints }}" data-countup-decimals-value="2">{{ myRow.totalPoints|number_format(2) }}</div>
                            <div class="hp-label" style="margin-top:2px">BODŮ</div>
                        </div>
                    </div>
                </div>
            {% endif %}

            {# Upcoming matches or tournament finished card #}
            {% if not isFinished and upcomingMatches|length > 0 %}
                <div class="hp-card" style="flex:1">
                    <div class="hp-card-head">
                        <span class="hp-card-title">Nadcházející zápasy</span>
                        <a href="{{ path('prediction_list') }}" style="font-size:12px;color:var(--accent);text-decoration:none">Všechny &rarr;</a>
                    </div>
                    <div>
                        {% for game in upcomingMatches %}
                            <div style="padding:14px 20px;display:flex;align-items:center;gap:12px;{{ not loop.last ? 'border-bottom:1px solid var(--line-soft)' : '' }}">
                                <div style="font-family:var(--font-mono);font-size:12px;color:var(--fg-3);width:80px">
                                    {{ game.playedAt|date('d.m. H:i') }}
                                </div>
                                <div style="flex:1;display:flex;align-items:center;justify-content:space-between">
                                    <span style="display:inline-flex;align-items:center;gap:8px">
                                        {{ team_flag(game.homeTeam.code) }}
                                        <span style="font-weight:600;font-size:13px;color:var(--fg)">{{ game.homeTeam.code }}</span>
                                    </span>
                                    <span style="color:var(--fg-4);font-size:11px">vs</span>
                                    <span style="display:inline-flex;align-items:center;gap:8px;flex-direction:row-reverse">
                                        {{ team_flag(game.awayTeam.code) }}
                                        <span style="font-weight:600;font-size:13px;color:var(--fg)">{{ game.awayTeam.code }}</span>
                                    </span>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% elseif isFinished %}
                <div class="hp-card" style="padding:24px;text-align:center;flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center">
                    <div style="font-size:40px;margin-bottom:8px" aria-hidden="true">🏆</div>
                    <h3 style="font-size:18px;font-weight:800;color:var(--fg)">Turnaj ukončen</h3>
                    {% if leaderboard|length > 0 %}
                        <p style="margin-top:8px;color:var(--accent);font-weight:600">
                            Vítěz: {{ leaderboard[0].user.username }}
                            <span style="color:var(--fg-3)">({{ leaderboard[0].totalPoints|number_format(2) }} b.)</span>
                        </p>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>

    {# ═══ Missing predictions banner ═══ #}
    {% if prediction_status and prediction_status.missingCount > 0 %}
        <div class="hp-card" style="padding:16px 20px;margin-bottom:24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;background:color-mix(in oklab, var(--warn) 10%, var(--bg-2));border-color:color-mix(in oklab, var(--warn) 30%, transparent)">
            <div style="display:flex;align-items:center;gap:12px">
                <span style="font-size:20px" aria-hidden="true">⚠️</span>
                <div>
                    <div style="font-size:14px;font-weight:600;color:var(--warn)">
                        Máš {{ prediction_status.missingCount }} {{ prediction_status.missingCount == 1 ? 'neodtipovaný zápas' : (prediction_status.missingCount < 5 ? 'neodtipované zápasy' : 'neodtipovaných zápasů') }}!
                    </div>
                    {% if prediction_status.nextMatch %}
                        <div style="font-size:12px;color:var(--fg-3);margin-top:2px">
                            Další: {{ team_flag(prediction_status.nextMatch.homeTeam.code) }} {{ prediction_status.nextMatch.homeTeam.code }}
                            vs {{ team_flag(prediction_status.nextMatch.awayTeam.code) }} {{ prediction_status.nextMatch.awayTeam.code }}
                            — {{ prediction_status.nextMatch.playedAt|date('d.m. H:i') }}
                        </div>
                    {% endif %}
                </div>
            </div>
            <a href="{{ path('prediction_list') }}" class="hp-btn hp-btn-primary hp-btn-sm">Tipovat</a>
        </div>
    {% endif %}

    {# ═══ Payment QR banner ═══ #}
    {% if paymentQrString %}
        <div class="hp-card" style="padding:16px 20px;margin-bottom:24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;background:color-mix(in oklab, var(--accent) 8%, var(--bg-2));border-color:color-mix(in oklab, var(--accent) 25%, transparent)">
            <div style="display:flex;align-items:center;gap:12px">
                <span style="font-size:20px" aria-hidden="true">💳</span>
                <div>
                    <div style="font-size:14px;font-weight:600;color:var(--accent)">
                        Nezaplaceno{% if paymentAmount %} — {{ paymentAmount|number_format(0, ',', ' ') }} Kč{% endif %}
                    </div>
                    <div style="font-size:12px;color:var(--fg-3);margin-top:2px">Naskenuj QR kód pro zaplacení účastnického poplatku</div>
                </div>
            </div>
            <div style="background:var(--bg-2);padding:8px;border-radius:var(--radius-sm);border:1px solid var(--line)">
                <canvas data-controller="qr" data-qr-data-value="{{ paymentQrString }}"></canvas>
            </div>
        </div>
    {% endif %}

    {# ═══ Main: Leaderboard + Sidebar ═══ #}
    <div style="display:grid;grid-template-columns:1.5fr 1fr;gap:16px" class="hp-main-grid">
        {# ── Leaderboard table ── #}
        <div class="hp-card tour-leaderboard">
            <div class="hp-card-head">
                <div>
                    <div class="hp-card-title">Žebříček</div>
                    {% if leaderboardUpdatedAt %}
                        <div class="hp-card-sub">Aktualizováno {{ leaderboardUpdatedAt|date('d.m. H:i') }}</div>
                    {% endif %}
                </div>
            </div>
            <div style="overflow:auto">
                <table class="hp-tbl" data-controller="sort">
                    <thead>
                        <tr>
                            <th style="width:44px">#</th>
                            <th>Hráč</th>
                            <th class="hp-num" style="cursor:pointer" data-action="click->sort#toggle" data-sort-col-param="2" data-sort-key-param="points">Body</th>
                            <th class="hp-num" style="width:80px;cursor:pointer" data-action="click->sort#toggle" data-sort-col-param="3" data-sort-key-param="diff">Od 1.</th>
                            {% if todayPoints|length > 0 %}
                                <th class="hp-num" style="width:80px;cursor:pointer" data-action="click->sort#toggle" data-sort-col-param="4" data-sort-key-param="today">Dnes</th>
                            {% endif %}
                            <th style="width:40px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% set leaderPoints = leaderboard|length > 0 ? leaderboard[0].totalPoints : 0 %}
                        {% set previousPoints = null %}
                        {% for row in leaderboard %}
                            {% set isCurrentUser = currentUser and currentUser.id == row.user.id %}
                            {% set diffFromFirst = leaderPoints - row.totalPoints %}
                            {% set today = todayPoints[row.user.id] ?? 0 %}
                            <tr style="{{ isCurrentUser ? 'background:color-mix(in oklab, var(--accent) 10%, transparent);box-shadow:inset 3px 0 0 var(--accent)' : '' }}">
                                <td>
                                    {{ m.rank_chip(row.rank) }}
                                </td>
                                <td>
                                    <a href="{{ path('player_profile', {username: row.user.username}) }}" style="display:inline-flex;align-items:center;gap:10px;text-decoration:none;color:var(--fg)">
                                        {{ m.avatar(row.user.username) }}
                                        <span style="display:flex;flex-direction:column;line-height:1.15">
                                            <span style="font-weight:600;font-size:14px">
                                                {{ row.user.username }}
                                                {% if isCurrentUser %}
                                                    <span style="margin-left:6px;color:var(--accent);font-size:11px;font-weight:700">TY</span>
                                                {% endif %}
                                            </span>
                                            {% set streak = playerStreaks[row.user.id] ?? null %}
                                            {% if streak and streak.hot %}
                                                <span class="hp-chip hp-chip-hot" style="font-size:10px;padding:2px 6px;margin-top:2px">🔥 streak {{ streak.streak }}</span>
                                            {% elseif streak and streak.cold %}
                                                <span class="hp-chip hp-chip-cold" style="font-size:10px;padding:2px 6px;margin-top:2px">❄ studená ruka</span>
                                            {% endif %}
                                        </span>
                                    </a>
                                </td>
                                <td class="hp-num">
                                    <span class="hp-pts hp-pts-lg" style="color:var(--fg)"
                                          data-controller="countup" data-countup-value-value="{{ row.totalPoints }}" data-countup-decimals-value="2">{{ row.totalPoints|number_format(2) }}</span>
                                </td>
                                <td class="hp-num">
                                    {% if diffFromFirst == 0 %}
                                        <span style="color:var(--pos)">—</span>
                                    {% else %}
                                        <span style="color:var(--fg-3);font-family:var(--font-mono);font-size:13px">−{{ diffFromFirst|number_format(2) }}</span>
                                    {% endif %}
                                </td>
                                {% if todayPoints|length > 0 %}
                                    <td class="hp-num">
                                        {% if today > 0 %}
                                            <span class="hp-trend-up" style="font-family:var(--font-mono);font-weight:600;font-size:13px">+{{ today|number_format(2) }}</span>
                                        {% else %}
                                            <span style="color:var(--fg-4)">—</span>
                                        {% endif %}
                                    </td>
                                {% endif %}
                                <td>
                                    {% set diff = previousPoints is not null ? previousPoints - row.totalPoints : 0 %}
                                    {% if diff < 0 %}
                                        <span class="hp-trend-up" title="Posun nahoru">▲</span>
                                    {% elseif diff > 0 and not loop.first %}
                                        <span class="hp-trend-down" title="Posun dolů">▼</span>
                                    {% else %}
                                        <span style="color:var(--fg-4)">·</span>
                                    {% endif %}
                                </td>
                            </tr>
                            {% set previousPoints = row.totalPoints %}
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# ── Sidebar ── #}
        <div style="display:flex;flex-direction:column;gap:16px">
            {# Stats card #}
            <div class="hp-card tour-stats">
                <div class="hp-card-head">
                    <span class="hp-card-title">Statistiky turnaje</span>
                </div>
                <div>
                    <div style="display:flex;justify-content:space-between;align-items:baseline;padding:14px 20px;border-bottom:1px solid var(--line-soft)">
                        <span style="color:var(--fg-3);font-size:13px">Odehráno zápasů</span>
                        <span style="font-weight:700;font-size:15px;font-family:var(--font-mono);color:var(--fg)">{{ matchesPlayed }}/{{ matchesTotal }}</span>
                    </div>
                    {% if highestMatchScore %}
                        <div style="display:flex;justify-content:space-between;align-items:baseline;padding:14px 20px;border-bottom:1px solid var(--line-soft)">
                            <span style="color:var(--fg-3);font-size:13px">Nejvíc bodů za zápas</span>
                            <span>
                                <span style="font-weight:700;font-size:15px;font-family:var(--font-mono);color:var(--fg)">{{ highestMatchScore.points|number_format(2) }}</span>
                                <span style="margin-left:6px;font-size:11px;color:var(--fg-4)">({{ highestMatchScore.username }})</span>
                            </span>
                        </div>
                    {% endif %}
                    {% if mostExactPredictions %}
                        <div style="display:flex;justify-content:space-between;align-items:baseline;padding:14px 20px">
                            <span style="color:var(--fg-3);font-size:13px">Nejvíc přesných tipů</span>
                            <span>
                                <span style="font-weight:700;font-size:15px;font-family:var(--font-mono);color:var(--fg)">{{ mostExactPredictions.count }}×</span>
                                <span style="margin-left:6px;font-size:11px;color:var(--fg-4)">({{ mostExactPredictions.username }})</span>
                            </span>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# Upcoming matches sidebar (smaller list) #}
            {% if not isFinished and upcomingMatches|length > 0 %}
                <div class="hp-card tour-upcoming" style="flex:1">
                    <div class="hp-card-head">
                        <span class="hp-card-title">Další zápasy</span>
                        <a href="{{ path('prediction_list') }}" style="font-size:12px;color:var(--accent);text-decoration:none">Tipy &rarr;</a>
                    </div>
                    <div>
                        {% for game in upcomingMatches %}
                            <div style="padding:12px 20px;display:flex;align-items:center;justify-content:space-between;{{ not loop.last ? 'border-bottom:1px solid var(--line-soft)' : '' }}">
                                <div style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--fg)">
                                    {{ team_flag(game.homeTeam.code) }} {{ game.homeTeam.code }}
                                    <span style="color:var(--fg-4);font-size:11px">vs</span>
                                    {{ team_flag(game.awayTeam.code) }} {{ game.awayTeam.code }}
                                </div>
                                <span style="font-family:var(--font-mono);font-size:11px;color:var(--fg-3)">{{ game.playedAt|date('d.m. H:i') }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>
    </div>

    {# ═══ Points timeline chart ═══ #}
    {% if timeline.labels|length > 0 %}
        <div class="hp-card tour-chart" style="margin-top:16px">
            <div class="hp-card-head">
                <div>
                    <div class="hp-card-title">Průběh bodů</div>
                    <div class="hp-card-sub">Najetím myši zvýrazníš hráče</div>
                </div>
            </div>
            <div style="padding:16px 20px;position:relative;height:350px">
                <canvas id="points-chart"></canvas>
            </div>
        </div>
    {% endif %}

    {# ═══ Mobile FAB ═══ #}
    {% if prediction_status and prediction_status.missingCount > 0 %}
        <a href="{{ path('prediction_list') }}" class="fixed bottom-6 left-6 z-30 flex h-14 w-14 items-center justify-center rounded-full hp-btn-primary sm:hidden"
           style="box-shadow:0 10px 30px color-mix(in oklab, var(--accent) 40%, transparent)"
           aria-label="Tipovat">
            <span style="font-size:22px" aria-hidden="true">🎯</span>
        </a>
    {% endif %}

    {# ═══ Responsive grid ═══ #}
    <style>
        @media (max-width: 1023px) {
            .hp-hero-grid { grid-template-columns: 1fr !important; }
            .hp-main-grid { grid-template-columns: 1fr !important; }
        }
    </style>

    {# ═══ Chart.js ═══ #}
    {% if timeline.labels|length > 0 %}
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.1/dist/chart.umd.min.js"
                integrity="sha384-jb8JQMbMoBUzgWatfe6COACi2ljcDdZQ2OxczGA3bGNeWe+6DChMTBJemed7ZnvJ"
                crossorigin="anonymous"></script>
        <script>
            (function () {
                const root = getComputedStyle(document.documentElement);
                const getVar = (v) => root.getPropertyValue(v).trim();

                // Token-aware colors
                const gridColor = getVar('--line-soft') || 'rgba(255,255,255,0.08)';
                const tickColor = getVar('--fg-4') || '#666';
                const legendColor = getVar('--fg-2') || '#999';

                // Palette derived from player hues
                const COLORS = [
                    'oklch(0.72 0.16 200)', 'oklch(0.72 0.16 25)',
                    'oklch(0.72 0.16 150)', 'oklch(0.72 0.16 80)',
                    'oklch(0.72 0.16 285)', 'oklch(0.72 0.16 315)',
                    'oklch(0.72 0.16 180)', 'oklch(0.72 0.16 40)',
                    'oklch(0.72 0.16 250)', 'oklch(0.72 0.16 120)',
                ];

                const timelineData = {{ timeline|json_encode(constant('JSON_HEX_TAG'))|raw }};

                const datasets = timelineData.datasets.map(function (ds, i) {
                    var color = COLORS[i % COLORS.length];
                    return {
                        label: ds.username,
                        data: ds.data,
                        borderColor: color,
                        backgroundColor: color,
                        borderWidth: 2,
                        pointRadius: 2,
                        pointHoverRadius: 5,
                        tension: 0.3,
                        fill: false,
                        _originalColor: color,
                    };
                });

                new Chart(document.getElementById('points-chart'), {
                    type: 'line',
                    data: {
                        labels: timelineData.labels,
                        datasets: datasets,
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: {
                            mode: 'index',
                            intersect: false,
                        },
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    usePointStyle: true,
                                    padding: 16,
                                    font: { size: 11, family: "'Inter', sans-serif" },
                                    color: legendColor,
                                },
                                onHover: function (e, legendItem, legend) {
                                    legend.chart.data.datasets.forEach(function (ds, i) {
                                        if (i === legendItem.datasetIndex) {
                                            ds.borderColor = ds._originalColor;
                                            ds.borderWidth = 3;
                                        } else {
                                            ds.borderColor = ds._originalColor
                                                .replace('oklch(', 'oklch(')
                                                .replace(')', ' / 0.2)');
                                            ds.borderWidth = 1.5;
                                        }
                                    });
                                    legend.chart.update('none');
                                },
                                onLeave: function (e, legendItem, legend) {
                                    legend.chart.data.datasets.forEach(function (ds) {
                                        ds.borderColor = ds._originalColor;
                                        ds.borderWidth = 2;
                                    });
                                    legend.chart.update('none');
                                },
                            },
                            tooltip: {
                                backgroundColor: getVar('--bg-2') || '#1a1a2e',
                                borderColor: getVar('--line') || '#333',
                                borderWidth: 1,
                                titleColor: getVar('--fg') || '#fff',
                                bodyColor: getVar('--fg-2') || '#ccc',
                                titleFont: { weight: 700 },
                                bodyFont: { family: "'JetBrains Mono', monospace" },
                                callbacks: {
                                    label: function (ctx) {
                                        return ctx.dataset.label + ': ' + ctx.parsed.y.toFixed(2) + ' b.';
                                    },
                                },
                            },
                        },
                        scales: {
                            x: {
                                ticks: {
                                    font: { size: 9, family: "'JetBrains Mono', monospace" },
                                    maxRotation: 45,
                                    color: tickColor,
                                },
                                grid: { display: false },
                            },
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    font: { size: 11, family: "'JetBrains Mono', monospace" },
                                    color: tickColor,
                                },
                                grid: {
                                    color: gridColor,
                                },
                                title: {
                                    display: true,
                                    text: 'Body',
                                    font: { size: 12, family: "'Inter', sans-serif" },
                                    color: tickColor,
                                },
                            },
                        },
                    },
                });
            })();
        </script>
    {% endif %}
{% endblock %}
