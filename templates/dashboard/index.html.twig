{% extends 'base.html.twig' %}

{% block title %}{{ tournament.name }} — Hockey Pool{% endblock %}

{% block body %}
    {# Tournament header #}
    <div class="mb-8 overflow-hidden rounded-2xl bg-[#0f172a] p-6 text-white shadow-xl ring-1 ring-white/5 sm:p-8 dark:bg-[#1e293b] dark:ring-white/10">
        <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
            <div>
                <h1 class="text-2xl font-bold sm:text-3xl">🏒 {{ tournament.name }}</h1>
                <p class="mt-1 text-sm text-gray-400">
                    {% if isFinished %}
                        Turnaj ukončen
                    {% else %}
                        Probíhá — {{ matchesPlayed }}/{{ matchesTotal }} zápasů odehráno
                    {% endif %}
                </p>
            </div>
            {% if isFinished and medalRules|length >= 3 %}
                <div class="flex items-end gap-1 text-center text-xs">
                    {# Silver - medium height #}
                    <div class="flex w-14 flex-col items-center rounded-lg bg-white/10 px-2 pb-2 pt-3">
                        <span class="text-gray-300" aria-hidden="true">🥈</span>
                        <div class="my-1">{{ team_flag(medalRules[1].actualTeamValue.code, 'inline-block h-5 w-7 rounded-sm') }}</div>
                        <span class="font-medium">{{ medalRules[1].actualTeamValue.code }}</span>
                    </div>
                    {# Gold - tallest #}
                    <div class="flex w-16 flex-col items-center rounded-lg bg-white/10 px-2 pb-2 pt-5">
                        <span class="text-yellow-400" aria-hidden="true">🥇</span>
                        <div class="my-1">{{ team_flag(medalRules[0].actualTeamValue.code, 'inline-block h-6 w-9 rounded-sm') }}</div>
                        <span class="font-bold">{{ medalRules[0].actualTeamValue.code }}</span>
                    </div>
                    {# Bronze - shortest #}
                    <div class="flex w-14 flex-col items-center rounded-lg bg-white/10 px-2 pb-2 pt-1">
                        <span class="text-amber-600" aria-hidden="true">🥉</span>
                        <div class="my-1">{{ team_flag(medalRules[2].actualTeamValue.code, 'inline-block h-5 w-7 rounded-sm') }}</div>
                        <span class="font-medium">{{ medalRules[2].actualTeamValue.code }}</span>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>

    {# Missing predictions banner #}
    {% if prediction_status and prediction_status.missingCount > 0 %}
        <div class="mb-6 flex flex-col items-start justify-between gap-3 rounded-xl border border-amber-200 bg-amber-50 px-6 py-4 sm:flex-row sm:items-center dark:border-amber-700 dark:bg-amber-900/30">
            <div class="flex items-center gap-3">
                <span class="text-2xl" aria-hidden="true">⚠️</span>
                <div>
                    <p class="text-sm font-medium text-amber-900 dark:text-amber-200">
                        Máš {{ prediction_status.missingCount }} {{ prediction_status.missingCount == 1 ? 'neodtipovaný zápas' : (prediction_status.missingCount < 5 ? 'neodtipované zápasy' : 'neodtipovaných zápasů') }}!
                    </p>
                    {% if prediction_status.nextMatch %}
                        <p class="mt-0.5 text-xs text-amber-700 dark:text-amber-300">
                            Další zápas: {{ team_flag(prediction_status.nextMatch.homeTeam.code) }} {{ prediction_status.nextMatch.homeTeam.code }}
                            vs {{ team_flag(prediction_status.nextMatch.awayTeam.code) }} {{ prediction_status.nextMatch.awayTeam.code }}
                            — {{ prediction_status.nextMatch.playedAt|date('d.m. H:i') }}
                        </p>
                    {% endif %}
                </div>
            </div>
            <a href="{{ path('prediction_list') }}" class="shrink-0 rounded-lg bg-amber-600 px-4 py-2 text-sm font-medium text-white hover:bg-amber-700">
                Tipovat
            </a>
        </div>
    {% endif %}

    {% if paymentQrString %}
        <div class="mb-6 flex flex-col items-start justify-between gap-4 rounded-xl border border-blue-200 bg-blue-50 px-6 py-4 sm:flex-row sm:items-center dark:border-blue-800 dark:bg-blue-900/20">
            <div class="flex items-center gap-4">
                <span class="text-2xl" aria-hidden="true">💳</span>
                <div>
                    <p class="text-sm font-medium text-blue-900 dark:text-blue-200">
                        Nezaplaceno{% if paymentAmount %} — {{ paymentAmount|number_format(0, ',', ' ') }} Kč{% endif %}
                    </p>
                    <p class="mt-0.5 text-xs text-blue-700 dark:text-blue-300">Naskenuj QR kód pro zaplacení účastnického poplatku</p>
                </div>
            </div>
            <div class="shrink-0 rounded-lg bg-white p-2 shadow-sm dark:bg-[#1e293b]">
                <canvas data-controller="qr" data-qr-data-value="{{ paymentQrString }}"></canvas>
            </div>
        </div>
    {% endif %}

    <div class="grid gap-6 lg:grid-cols-3">
        {# Leaderboard — spans 2 columns on large screens #}
        <div class="tour-leaderboard lg:col-span-2">
            <div class="overflow-hidden rounded-xl bg-white shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
                <div class="border-b border-gray-200 bg-[#0f172a] px-6 py-4 dark:border-gray-700">
                    <h2 class="text-lg font-semibold text-white">Žebříček</h2>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-gray-100 bg-gray-50 text-left text-xs uppercase tracking-wider text-gray-500 dark:border-gray-700 dark:bg-[#0f172a] dark:text-gray-400">
                                <th scope="col" class="px-4 py-3 w-10">#</th>
                                <th scope="col" class="px-4 py-3">Hráč</th>
                                <th scope="col" class="px-4 py-3 text-right">Body</th>
                                <th scope="col" class="hidden px-4 py-3 text-right sm:table-cell" title="Rozdíl od předchozího">+/-</th>
                                <th scope="col" class="hidden px-4 py-3 text-right sm:table-cell" title="Ztráta na 1. místo">Od 1.</th>
                                {% if todayPoints|length > 0 %}
                                    <th scope="col" class="px-4 py-3 text-right" title="Body dnes">Dnes</th>
                                {% endif %}
                            </tr>
                        </thead>
                        <tbody>
                            {% set previousPoints = null %}
                            {% set leaderPoints = leaderboard|length > 0 ? leaderboard[0].totalPoints : 0 %}
                            {% for row in leaderboard %}
                                {% set isCurrentUser = currentUser and currentUser.id == row.user.id %}
                                {% set diff = previousPoints is not null ? previousPoints - row.totalPoints : 0 %}
                                {% set diffFromFirst = leaderPoints - row.totalPoints %}
                                {% set today = todayPoints[row.user.id] ?? 0 %}
                                {% if isCurrentUser %}
                                    {% set rowClass = 'bg-[#38bdf8]/10 font-semibold' %}
                                {% elseif loop.index is odd %}
                                    {% set rowClass = 'bg-white dark:bg-[#1e293b]' %}
                                {% else %}
                                    {% set rowClass = 'bg-gray-50 dark:bg-[#0f172a]/50' %}
                                {% endif %}
                                <tr class="{{ rowClass }} border-b border-gray-100 last:border-0 dark:border-gray-700 dark:text-gray-100">
                                    <td class="px-4 py-3">
                                        {% if row.rank <= 3 %}
                                            <span class="text-base" aria-hidden="true">{{ row.rank == 1 ? '🥇' : (row.rank == 2 ? '🥈' : '🥉') }}</span>
                                            <span class="sr-only">{{ row.rank }}.</span>
                                        {% else %}
                                            <span class="text-gray-400">{{ row.rank }}.</span>
                                        {% endif %}
                                    </td>
                                    <td class="px-4 py-3">
                                        <a href="{{ path('player_profile', {username: row.user.username}) }}" class="hover:text-[#38bdf8] dark:text-gray-100">
                                            {{ row.user.username }}
                                        </a>
                                        {% if isCurrentUser %}
                                            <span class="ml-1 text-xs text-[#38bdf8]">← ty</span>
                                        {% endif %}
                                    </td>
                                    <td class="px-4 py-3 text-right tabular-nums">
                                        {{ row.totalPoints|number_format(2) }}
                                    </td>
                                    <td class="hidden px-4 py-3 text-right tabular-nums text-gray-400 sm:table-cell">
                                        {% if diff > 0 %}
                                            -{{ diff|number_format(2) }}
                                        {% endif %}
                                    </td>
                                    <td class="hidden px-4 py-3 text-right tabular-nums sm:table-cell {{ diffFromFirst > 0 ? 'text-red-400 dark:text-red-500' : 'text-green-600 dark:text-green-400' }}">
                                        {% if diffFromFirst > 0 %}
                                            -{{ diffFromFirst|number_format(2) }}
                                        {% elseif loop.first %}
                                            —
                                        {% endif %}
                                    </td>
                                    {% if todayPoints|length > 0 %}
                                        <td class="px-4 py-3 text-right tabular-nums {{ today > 0 ? 'text-green-600 dark:text-green-400' : 'text-gray-300 dark:text-gray-600' }}">
                                            {% if today > 0 %}
                                                +{{ today|number_format(2) }}
                                            {% else %}
                                                —
                                            {% endif %}
                                        </td>
                                    {% endif %}
                                </tr>
                                {% set previousPoints = row.totalPoints %}
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            {# Points progression chart #}
            {% if timeline.labels|length > 0 %}
                <div class="tour-chart mt-6 rounded-xl bg-white p-6 shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
                    <h2 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">Průběh bodů</h2>
                    <div class="relative" style="height: 350px;">
                        <canvas id="points-chart"></canvas>
                    </div>
                </div>
            {% endif %}
        </div>

        {# Right sidebar #}
        <div class="space-y-6">
            {# Quick stats #}
            <div class="tour-stats rounded-xl bg-white shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
                <div class="border-b border-gray-200 bg-[#0f172a] px-6 py-4 dark:border-gray-700">
                    <h2 class="text-lg font-semibold text-white">Statistiky</h2>
                </div>
                <div class="divide-y divide-gray-100 dark:divide-gray-700">
                    <div class="flex items-center justify-between px-6 py-4">
                        <span class="text-sm text-gray-500 dark:text-gray-400">Odehráno zápasů</span>
                        <span class="font-semibold dark:text-gray-100">{{ matchesPlayed }}/{{ matchesTotal }}</span>
                    </div>
                    {% if highestMatchScore %}
                        <div class="flex items-center justify-between px-6 py-4">
                            <span class="text-sm text-gray-500 dark:text-gray-400">Nejvíc bodů za zápas</span>
                            <span class="font-semibold dark:text-gray-100">{{ highestMatchScore.points|number_format(2) }}
                                <span class="text-xs text-gray-400 dark:text-gray-500">({{ highestMatchScore.username }})</span>
                            </span>
                        </div>
                    {% endif %}
                    {% if mostExactPredictions %}
                        <div class="flex items-center justify-between px-6 py-4">
                            <span class="text-sm text-gray-500 dark:text-gray-400">Nejvíc přesných tipů</span>
                            <span class="font-semibold dark:text-gray-100">{{ mostExactPredictions.count }}×
                                <span class="text-xs text-gray-400 dark:text-gray-500">({{ mostExactPredictions.username }})</span>
                            </span>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# Upcoming matches or final results #}
            {% if not isFinished and upcomingMatches|length > 0 %}
                <div class="tour-upcoming rounded-xl bg-white shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
                    <div class="border-b border-gray-200 bg-[#0f172a] px-6 py-4 dark:border-gray-700">
                        <h2 class="text-lg font-semibold text-white">Nadcházející zápasy</h2>
                    </div>
                    <div class="divide-y divide-gray-100 dark:divide-gray-700">
                        {% for game in upcomingMatches %}
                            <div class="px-6 py-3">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-2 text-sm dark:text-gray-100">
                                        <span>{{ team_flag(game.homeTeam.code) }} {{ game.homeTeam.code }}</span>
                                        <span class="text-gray-400 dark:text-gray-500">vs</span>
                                        <span class="dark:text-gray-100">{{ team_flag(game.awayTeam.code) }} {{ game.awayTeam.code }}</span>
                                    </div>
                                    <span class="text-xs text-gray-400 dark:text-gray-500">
                                        {{ game.playedAt|date('d.m. H:i') }}
                                    </span>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% elseif isFinished %}
                <div class="rounded-xl bg-gradient-to-br from-[#0f172a] to-[#1e293b] p-6 text-center text-white shadow">
                    <div class="mb-2 text-4xl" aria-hidden="true">🏆</div>
                    <h3 class="text-lg font-bold">Turnaj ukončen</h3>
                    {% if leaderboard|length > 0 %}
                        <p class="mt-2 text-[#38bdf8]">
                            Vítěz: {{ leaderboard[0].user.username }}
                            <span class="text-white/70">({{ leaderboard[0].totalPoints|number_format(2) }} b.)</span>
                        </p>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>

    {% if prediction_status and prediction_status.missingCount > 0 %}
        <a href="{{ path('prediction_list') }}" class="fixed bottom-6 right-6 flex h-14 w-14 items-center justify-center rounded-full bg-[#0f172a] text-2xl text-white shadow-lg hover:bg-[#1e293b] dark:bg-[#38bdf8] dark:text-[#0f172a] sm:hidden" aria-label="Tipovat">
            <span aria-hidden="true">🎯</span>
        </a>
    {% endif %}

    {% if timeline.labels|length > 0 %}
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.1/dist/chart.umd.min.js"
                integrity="sha384-jb8JQMbMoBUzgWatfe6COACi2ljcDdZQ2OxczGA3bGNeWe+6DChMTBJemed7ZnvJ"
                crossorigin="anonymous"></script>
        <script>
            (function () {
                const isDark = document.documentElement.classList.contains('dark');
                const gridColor = isDark ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.1)';
                const tickColor = isDark ? '#9ca3af' : '#6b7280';
                const legendColor = isDark ? '#d1d5db' : '#374151';

                const COLORS = [
                    '#3b82f6', '#ef4444', '#10b981', '#f59e0b', '#8b5cf6',
                    '#ec4899', '#06b6d4', '#f97316', '#6366f1', '#14b8a6',
                ];

                const timelineData = {{ timeline|json_encode(constant('JSON_HEX_TAG'))|raw }};

                const datasets = timelineData.datasets.map(function (ds, i) {
                    return {
                        label: ds.username,
                        data: ds.data,
                        borderColor: COLORS[i % COLORS.length],
                        backgroundColor: COLORS[i % COLORS.length] + '20',
                        borderWidth: 2,
                        pointRadius: 2,
                        pointHoverRadius: 5,
                        tension: 0.3,
                        fill: false,
                    };
                });

                new Chart(document.getElementById('points-chart'), {
                    type: 'line',
                    data: {
                        labels: timelineData.labels,
                        datasets: datasets,
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: {
                            mode: 'index',
                            intersect: false,
                        },
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    usePointStyle: true,
                                    padding: 16,
                                    font: { size: 11 },
                                    color: legendColor,
                                },
                            },
                            tooltip: {
                                callbacks: {
                                    label: function (ctx) {
                                        return ctx.dataset.label + ': ' + ctx.parsed.y.toFixed(2) + ' b.';
                                    },
                                },
                            },
                        },
                        scales: {
                            x: {
                                ticks: {
                                    font: { size: 9 },
                                    maxRotation: 45,
                                    color: tickColor,
                                },
                                grid: { display: false },
                            },
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    font: { size: 11 },
                                    color: tickColor,
                                },
                                grid: {
                                    color: gridColor,
                                },
                                title: {
                                    display: true,
                                    text: 'Body',
                                    font: { size: 12 },
                                    color: tickColor,
                                },
                            },
                        },
                    },
                });
            })();
        </script>
    {% endif %}
{% endblock %}
