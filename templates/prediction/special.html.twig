{% extends 'base.html.twig' %}

{% block title %}Speciální tipy — Hockey Pool{% endblock %}

{% block body %}
    <div class="mb-6">
        <a href="{{ path('special_bet_overview') }}" class="inline-flex items-center gap-1 text-sm font-medium hover:underline" style="color:var(--fg-3)">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
            Zpět
        </a>
    </div>

    <div class="mx-auto max-w-2xl">
        <div class="mb-6">
            <h1 class="text-2xl font-bold" style="color:var(--fg)">Speciální tipy</h1>
            <p class="mt-1 text-sm" style="color:var(--fg-3)">{{ tournament.name }}</p>
            {% if isLocked %}
                <div class="hp-alert hp-alert-info mt-3">
                    Speciální tipy jsou uzamčeny — turnaj už začal.
                </div>
            {% endif %}
        </div>

        <form method="post" class="space-y-6">
            <input type="hidden" name="_token" value="{{ csrf_token('special_bets') }}">

            <div class="hp-card">
                <div class="hp-card-head" style="background:var(--bg-3)">
                    <h2 class="hp-card-title">Vyplň své tipy</h2>
                </div>
                <div class="divide-y" style="border-color:var(--line-soft)">
                    {% for rule in rules %}
                        {% set bet = existingBets[rule.id] ?? null %}
                        <div class="px-6 py-4">
                            <label for="rule_{{ rule.id }}" class="hp-field-label mb-1 block">
                                {{ rule.name }}
                                <span class="ml-1" style="color:var(--fg-4)">({{ rule.points }} b. — {{ rule.scoringType.label }})</span>
                            </label>

                            {% if rule.valueType.value == 'team' %}
                                <select name="rule_{{ rule.id }}" id="rule_{{ rule.id }}"
                                        class="hp-field-input w-full" {{ isLocked ? 'disabled' : '' }}>
                                    <option value="">— Vyber tým —</option>
                                    {% for team in teams %}
                                        <option value="{{ team.id }}" {{ bet and bet.teamValue and bet.teamValue.id == team.id ? 'selected' : '' }}>
                                            {{ team.name }} ({{ team.code }})
                                        </option>
                                    {% endfor %}
                                </select>
                            {% elseif rule.valueType.value == 'string' %}
                                <input type="text" name="rule_{{ rule.id }}" id="rule_{{ rule.id }}"
                                       value="{{ bet ? bet.stringValue : '' }}"
                                       class="hp-field-input w-full" {{ isLocked ? 'disabled' : '' }}
                                       placeholder="např. Pastrňák">
                            {% elseif rule.valueType.value == 'integer' %}
                                <input type="number" name="rule_{{ rule.id }}" id="rule_{{ rule.id }}"
                                       value="{{ bet ? bet.intValue : '' }}"
                                       class="hp-field-input w-full" {{ isLocked ? 'disabled' : '' }}
                                       min="0" placeholder="číslo">
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>

            {% if not isLocked %}
                <div class="text-center">
                    <button type="submit" class="hp-btn hp-btn-primary">
                        Uložit speciální tipy
                    </button>
                </div>
            {% endif %}
        </form>
    </div>
{% endblock %}
