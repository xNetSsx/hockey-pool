{% extends 'base.html.twig' %}

{% block title %}Speciální tipy — Hockey Pool{% endblock %}

{% block body %}
    <div class="mb-6">
        <a href="{{ path('prediction_list') }}" class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">← Zpět na tipy</a>
    </div>

    <div class="mx-auto max-w-2xl">
        <div class="mb-6">
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">⭐ Speciální tipy</h1>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{{ tournament.name }}</p>
            {% if isLocked %}
                <div class="mt-3 rounded-md bg-amber-50 p-3 text-sm text-amber-800 dark:bg-amber-900/30 dark:text-amber-300">
                    🔒 Speciální tipy jsou uzamčeny — turnaj už začal.
                </div>
            {% endif %}
        </div>

        {% set inputClass = 'w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20 disabled:bg-gray-100 disabled:text-gray-500 dark:bg-[#0f172a] dark:border-gray-600 dark:text-white dark:disabled:bg-gray-800 dark:disabled:text-gray-500' %}

        <form method="post" class="space-y-6">
            <input type="hidden" name="_token" value="{{ csrf_token('special_bets') }}">

            <div class="overflow-hidden rounded-xl bg-white shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
                <div class="border-b bg-[#0f172a] px-6 py-4">
                    <h2 class="text-lg font-semibold text-white">Speciální tipy</h2>
                </div>
                <div class="divide-y divide-gray-100 dark:divide-gray-700">
                    {% for rule in rules %}
                        {% set bet = existingBets[rule.id] ?? null %}
                        <div class="px-6 py-4">
                            <label for="rule_{{ rule.id }}" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">
                                {{ rule.name }}
                                <span class="ml-1 text-xs text-gray-400 dark:text-gray-500">({{ rule.points }} b. — {{ rule.scoringType.label }})</span>
                            </label>

                            {% if rule.valueType.value == 'team' %}
                                <select name="rule_{{ rule.id }}" id="rule_{{ rule.id }}"
                                        class="{{ inputClass }}" {{ isLocked ? 'disabled' : '' }}>
                                    <option value="">— Vyber tým —</option>
                                    {% for team in teams %}
                                        <option value="{{ team.id }}" {{ bet and bet.teamValue and bet.teamValue.id == team.id ? 'selected' : '' }}>
                                            {{ team.name }} ({{ team.code }})
                                        </option>
                                    {% endfor %}
                                </select>
                            {% elseif rule.valueType.value == 'string' %}
                                <input type="text" name="rule_{{ rule.id }}" id="rule_{{ rule.id }}"
                                       value="{{ bet ? bet.stringValue : '' }}"
                                       class="{{ inputClass }}" {{ isLocked ? 'disabled' : '' }}
                                       placeholder="např. Pastrňák">
                            {% elseif rule.valueType.value == 'integer' %}
                                <input type="number" name="rule_{{ rule.id }}" id="rule_{{ rule.id }}"
                                       value="{{ bet ? bet.intValue : '' }}"
                                       class="{{ inputClass }}" {{ isLocked ? 'disabled' : '' }}
                                       min="0" placeholder="číslo">
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>

            {% if not isLocked %}
                <div class="text-center">
                    <button type="submit"
                            class="rounded-lg bg-blue-600 px-8 py-2.5 font-semibold text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:bg-[#38bdf8] dark:text-[#0f172a] dark:hover:bg-[#7dd3fc]">
                        Uložit speciální tipy
                    </button>
                </div>
            {% endif %}
        </form>
    </div>
{% endblock %}
