{% extends 'base.html.twig' %}

{% block title %}Tip: {{ game.homeTeam.code }} vs {{ game.awayTeam.code }} — Hockey Pool{% endblock %}

{% set czechTeamCode = null %}
{% set czechSide = null %}
{% if game.homeTeam.code == 'CZE' %}
    {% set czechTeamCode = 'CZE' %}
    {% set czechSide = 'home' %}
{% elseif game.awayTeam.code == 'CZE' %}
    {% set czechTeamCode = 'CZE' %}
    {% set czechSide = 'away' %}
{% endif %}

{% block body %}
    <div style="margin-bottom:24px">
        <a href="{{ path('prediction_list') }}" style="font-size:14px;color:var(--fg-3);text-decoration:none">&larr; Zpět na tipy</a>
    </div>

    <div style="max-width:520px;margin:0 auto">
        <div class="hp-card" {{ stimulus_controller('confetti') }}>
            <div class="hp-card-head">
                <div>
                    <div class="hp-card-title">{{ isNew ? 'Nový tip' : 'Upravit tip' }}</div>
                    <div class="hp-card-sub">{{ game.playedAt|date('d.m.Y H:i') }}</div>
                </div>
                <span class="hp-chip hp-chip-accent">{{ game.homeTeam.code }} vs {{ game.awayTeam.code }}</span>
            </div>

            <div style="padding:24px">
                {# Match display #}
                <div style="display:flex;align-items:center;justify-content:center;gap:24px;margin-bottom:24px;text-align:center">
                    <div>
                        <div>{{ team_flag(game.homeTeam.code, 'inline-block h-8 w-12 rounded-sm') }}</div>
                        <div style="margin-top:6px;font-family:var(--font-display);font-size:18px;font-weight:700;color:var(--fg)">{{ game.homeTeam.code }}</div>
                        <div style="font-size:12px;color:var(--fg-4)">{{ game.homeTeam.name }}</div>
                    </div>
                    <div style="font-family:var(--font-display);font-size:48px;font-weight:700;color:var(--fg-4)">vs</div>
                    <div>
                        <div>{{ team_flag(game.awayTeam.code, 'inline-block h-8 w-12 rounded-sm') }}</div>
                        <div style="margin-top:6px;font-family:var(--font-display);font-size:18px;font-weight:700;color:var(--fg)">{{ game.awayTeam.code }}</div>
                        <div style="font-size:12px;color:var(--fg-4)">{{ game.awayTeam.name }}</div>
                    </div>
                </div>

                {{ form_start(form, {attr: {class: 'space-y-4', id: 'prediction-form', 'data-action': 'submit->confetti#fire'}}) }}
                    <div style="display:flex;align-items:end;justify-content:center;gap:16px">
                        <div style="text-align:center">
                            {{ form_label(form.homeScore, null, {label_attr: {class: 'hp-field-label', style: 'display:block;margin-bottom:6px'}}) }}
                            {{ form_widget(form.homeScore, {attr: {class: 'hp-field-input', style: 'width:80px;text-align:center;font-size:24px;font-weight:700;font-family:var(--font-display)', id: 'home-score'}}) }}
                            {{ form_errors(form.homeScore) }}
                        </div>
                        <div style="padding-bottom:12px;font-family:var(--font-display);font-size:36px;font-weight:700;color:var(--fg-4)">:</div>
                        <div style="text-align:center">
                            {{ form_label(form.awayScore, null, {label_attr: {class: 'hp-field-label', style: 'display:block;margin-bottom:6px'}}) }}
                            {{ form_widget(form.awayScore, {attr: {class: 'hp-field-input', style: 'width:80px;text-align:center;font-size:24px;font-weight:700;font-family:var(--font-display)', id: 'away-score'}}) }}
                            {{ form_errors(form.awayScore) }}
                        </div>
                    </div>

                    {{ form_errors(form) }}

                    <div style="background:var(--bg-3);padding:12px;border-radius:10px;font-size:12px;color:var(--fg-3);margin-top:16px">
                        <strong style="color:var(--fg-2)">Bodování:</strong> přesný tip +3 · správný vítěz +1 · špatně 0
                    </div>

                    <div style="padding-top:16px;text-align:center">
                        {{ form_widget(form.save, {attr: {class: 'hp-btn hp-btn-primary', style: 'width:100%;padding:12px 24px', id: 'submit-btn'}}) }}
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>

{% endblock %}

{% block modals %}
    {% if czechSide %}
        <dialog id="treason-modal-1" aria-labelledby="treason-modal-1-title">
            <div style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;background:oklch(0 0 0 / 0.85);display:flex;align-items:center;justify-content:center;padding:0 1rem">
                <div class="hp-card" style="max-width:400px;width:100%;padding:32px;text-align:center;border-color:var(--neg);animation:shake 0.5s ease-in-out">
                    <div style="margin-bottom:12px;font-size:64px">🇨🇿</div>
                    <h2 id="treason-modal-1-title" style="font-family:var(--font-display);font-size:28px;font-weight:900;text-transform:uppercase;letter-spacing:0.04em;color:var(--neg);margin-bottom:4px">Vlastizrada!</h2>
                    <p style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--neg);margin-bottom:16px">Detekován tip proti vlasti</p>
                    <p style="font-size:14px;color:var(--fg-3);margin-bottom:24px">
                        Vážně tipuješ prohru České republiky?<br>
                        <strong style="color:var(--fg-2)">Tohle je tvoje šance to napravit.</strong>
                    </p>
                    <div style="display:flex;flex-direction:column;gap:8px">
                        <button autofocus onclick="document.getElementById('treason-modal-1').close()" class="hp-btn hp-btn-primary" style="width:100%">
                            🇨🇿 Sláva! Opravím to
                        </button>
                        <button onclick="showSecondWarning()" class="hp-btn hp-btn-ghost" style="width:100%">
                            Stojím si za tím...
                        </button>
                    </div>
                </div>
            </div>
        </dialog>

        <dialog id="treason-modal-2" aria-labelledby="treason-modal-2-title">
            <div style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;background:oklch(0.15 0.08 25 / 0.9);display:flex;align-items:center;justify-content:center;padding:0 1rem">
                <div class="hp-card" style="max-width:400px;width:100%;padding:32px;text-align:center;border-color:var(--neg);animation:shake 0.3s ease-in-out 3">
                    <div style="margin-bottom:12px;font-size:64px">⛔</div>
                    <h2 id="treason-modal-2-title" style="font-family:var(--font-display);font-size:24px;font-weight:900;text-transform:uppercase;color:var(--neg);margin-bottom:16px">Poslední varování!</h2>
                    <div style="background:color-mix(in oklab, var(--neg) 15%, var(--bg-2));padding:12px;border-radius:var(--radius);margin-bottom:16px">
                        <p style="font-size:14px;color:var(--neg)">
                            Tímto se oficiálně prohlašuješ za
                        </p>
                        <p style="margin-top:4px;font-family:var(--font-display);font-size:22px;font-weight:900;color:var(--neg)">VLASTIZRÁDCE</p>
                    </div>
                    <p style="font-size:12px;color:var(--fg-4);margin-bottom:24px">
                        Tvůj hanebný tip bude zaznamenán.<br>Ostatní se to dozví. Není cesta zpět.
                    </p>
                    <div style="display:flex;flex-direction:column;gap:8px">
                        <button autofocus onclick="cancelTreason()" class="hp-btn" style="width:100%;background:var(--pos);color:var(--accent-ink)">
                            🇨🇿 Měním tip! Sláva Čechům!
                        </button>
                        <button onclick="confirmTreason()" class="hp-btn" style="width:100%;background:color-mix(in oklab, var(--neg) 30%, var(--bg-3));color:var(--neg);font-size:12px">
                            Potvrzuji zradu...
                        </button>
                    </div>
                </div>
            </div>
        </dialog>

        <style>
            dialog { padding: 0; border: none; background: transparent; max-width: none; max-height: none; }
            dialog::backdrop { display: none; }
            @keyframes shake {
                0%, 100% { transform: translateX(0); }
                10%, 30%, 50%, 70%, 90% { transform: translateX(-4px); }
                20%, 40%, 60%, 80% { transform: translateX(4px); }
            }
        </style>

        <script>
            (function () {
                var czechSide = '{{ czechSide|e('js') }}';
                var form = document.querySelector('form[name="prediction"]') || document.querySelector('form[name="match_result"]') || document.querySelector('#prediction-form') || document.querySelector('form');
                var treasonConfirmed = false;

                function getScore(name) {
                    var el = document.querySelector('[name$="[homeScore]"]');
                    if (name === 'away') el = document.querySelector('[name$="[awayScore]"]');
                    return el ? (parseInt(el.value) || 0) : 0;
                }

                function isBettingAgainstCzech() {
                    var home = getScore('home');
                    var away = getScore('away');
                    if (czechSide === 'home') return away > home;
                    if (czechSide === 'away') return home > away;
                    return false;
                }

                function showModal(id) {
                    document.getElementById(id).showModal();
                }
                function hideModal(id) {
                    document.getElementById(id).close();
                }

                form.addEventListener('submit', function (e) {
                    if (isBettingAgainstCzech() && !treasonConfirmed) {
                        e.preventDefault();
                        showModal('treason-modal-1');
                    }
                });

                window.showSecondWarning = function () {
                    hideModal('treason-modal-1');
                    showModal('treason-modal-2');
                };

                window.cancelTreason = function () {
                    hideModal('treason-modal-2');
                    treasonConfirmed = false;
                };

                window.confirmTreason = function () {
                    hideModal('treason-modal-2');
                    treasonConfirmed = true;
                    form.submit();
                };
            })();
        </script>
    {% endif %}
{% endblock %}
