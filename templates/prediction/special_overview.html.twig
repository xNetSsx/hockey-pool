{% extends 'base.html.twig' %}

{% block title %}Speciální tipy — přehled{% endblock %}

{% block body %}
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Speciální tipy — přehled</h1>
            {% if tournament %}
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{{ tournament.name }}</p>
            {% endif %}
        </div>
        <a href="{{ path('prediction_special') }}"
           class="inline-flex items-center rounded-lg bg-[#0f172a] px-4 py-2 text-sm font-medium text-white hover:bg-[#1e293b]">
            Moje tipy
        </a>
    </div>

    {% if locked %}
        <div class="rounded-xl bg-white p-8 text-center shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
            <p class="text-gray-500 dark:text-gray-400">Tipy ostatních se zobrazí po začátku turnaje.</p>
        </div>
    {% elseif rules|length == 0 %}
        <div class="rounded-xl bg-white p-8 text-center shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
            <p class="text-gray-500 dark:text-gray-400">Žádné speciální tipy pro tento turnaj.</p>
        </div>
    {% else %}
        <div class="overflow-hidden rounded-xl bg-white shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-100 bg-gray-50 text-left text-xs uppercase tracking-wider text-gray-500 dark:border-gray-700 dark:bg-[#0f172a] dark:text-gray-400">
                            <th class="sticky left-0 bg-gray-50 px-4 py-3 dark:bg-[#0f172a]">Pravidlo</th>
                            {% for player in players %}
                                <th class="px-3 py-3 text-center">{{ player.username }}</th>
                            {% endfor %}
                            {% if tournament.status.value == 'finished' %}
                                <th class="px-3 py-3 text-center text-green-600 dark:text-green-400">Skutečnost</th>
                            {% endif %}
                        </tr>
                    </thead>
                    <tbody>
                        {% for rule in rules %}
                            <tr class="border-b border-gray-100 last:border-0 dark:border-gray-700">
                                <td class="sticky left-0 bg-white px-4 py-2.5 font-medium dark:bg-[#1e293b] dark:text-white">
                                    {{ rule.name }}
                                    <span class="ml-1 text-xs text-gray-400 dark:text-gray-500">({{ rule.points }} b.)</span>
                                </td>
                                {% for player in players %}
                                    {% set bet = betsByRuleAndUser[rule.id][player.id] ?? null %}
                                    <td class="whitespace-nowrap px-3 py-2.5 text-center dark:text-gray-100">
                                        {% if bet %}
                                            {% if bet.teamValue %}
                                                {{ team_flag(bet.teamValue.code) }} {{ bet.teamValue.code }}
                                            {% elseif bet.stringValue %}
                                                {{ bet.stringValue }}
                                            {% elseif bet.intValue is not null %}
                                                {{ bet.intValue }}
                                            {% endif %}
                                        {% else %}
                                            <span class="text-gray-300 dark:text-gray-600">—</span>
                                        {% endif %}
                                    </td>
                                {% endfor %}
                                {% if tournament.status.value == 'finished' %}
                                    <td class="whitespace-nowrap px-3 py-2.5 text-center font-semibold text-green-700 dark:text-green-400">
                                        {% if rule.actualTeamValue %}
                                            {{ team_flag(rule.actualTeamValue.code) }} {{ rule.actualTeamValue.code }}
                                        {% elseif rule.actualStringValue %}
                                            {{ rule.actualStringValue }}
                                        {% elseif rule.actualIntValue is not null %}
                                            {{ rule.actualIntValue }}
                                        {% else %}
                                            <span class="text-gray-300 dark:text-gray-600">—</span>
                                        {% endif %}
                                    </td>
                                {% endif %}
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}
{% endblock %}
