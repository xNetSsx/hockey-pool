{% extends 'base.html.twig' %}
{% import '_macros.html.twig' as m %}

{% block title %}Speciální tipy — přehled{% endblock %}

{% block body %}
    {% set currentUserId = currentUserId|default(null) %}
    {% set pointsByRuleAndUser = pointsByRuleAndUser|default({}) %}

    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 style="font-family:var(--font-display);font-size:1.75rem;font-weight:800;letter-spacing:-0.02em;color:var(--fg)">Speciální tipy — přehled</h1>
            {% if tournament %}
                <p style="margin-top:4px;font-size:13px;color:var(--fg-3)">{{ tournament.name }}</p>
            {% endif %}
        </div>
        <div class="flex gap-2">
            <a href="{{ path('prediction_list') }}"
               class="hp-btn hp-btn-ghost hp-btn-sm">
                Zpět na tipy
            </a>
            <a href="{{ path('prediction_special') }}"
               class="hp-btn hp-btn-primary hp-btn-sm">
                Upravit tipy
            </a>
        </div>
    </div>

    {% if rules|length == 0 %}
        <div class="hp-card" style="padding:2.5rem;text-align:center">
            <p style="color:var(--fg-3)">Žádné speciální tipy pro tento turnaj.</p>
        </div>
    {% else %}
        {# Group rules by composite key: scoringType:valueType + optional sub-group #}
        {% set groupLabels = {
            'podium:team':             'Medaile',
            'any_match:string':        'Nejlepší hráči',
            'any_match:team':          'Nejlepší hráči',
            'exact_match:team':              'Pořadí skupin',
            'exact_match:team:a':            'Pořadí skupin — A',
            'exact_match:team:b':            'Pořadí skupin — B',
            'exact_match:team:c':            'Pořadí skupin — C',
            'exact_match:team:d':            'Pořadí skupin — D',
            'exact_match:team:sestupujici':  'Sestupující týmy',
            'exact_match:string':      'Ostatní',
            'exact_match:integer':     'Ostatní',
            'closest:integer':         'Čísla',
            'closest:string':          'Čísla',
        } %}
        {% set groupedRules = {} %}
        {% for rule in rules %}
            {% set base = rule.scoringType.value ~ ':' ~ rule.valueType.value %}
            {% set key = base %}
            {% if rule.scoringType.value == 'exact_match' and rule.valueType.value == 'team' %}
                {% if 'Sestupující' in rule.name %}
                    {% set key = base ~ ':sestupujici' %}
                {% else %}
                    {% for letter in ['a','b','c','d','e','f'] %}
                        {% if ('Skupina ' ~ letter|upper) in rule.name and key == base %}
                            {% set key = base ~ ':' ~ letter %}
                        {% endif %}
                    {% endfor %}
                {% endif %}
            {% endif %}
            {% set groupedRules = groupedRules|merge({(key): (groupedRules[key] ?? [])|merge([rule])}) %}
        {% endfor %}

        {# Compute per-player totals for tfoot #}
        {% set totalPointsPerPlayer = {} %}
        {% for player in players %}
            {% set total = 0 %}
            {% for rule in rules %}
                {% set pts = pointsByRuleAndUser[rule.id][player.id] ?? 0 %}
                {% set total = total + pts %}
            {% endfor %}
            {% set totalPointsPerPlayer = totalPointsPerPlayer|merge({(player.id): total}) %}
        {% endfor %}

        {% set colCount = 1 + players|length + (tournament.status.value == 'finished' ? 1 : 0) %}

        <div class="hp-card">
            <div class="overflow-x-auto">
                <table class="hp-tbl" style="font-size:13px">
                    <thead>
                        <tr>
                            <th class="sticky left-0" style="background:var(--bg-3);z-index:10;width:11rem;min-width:11rem">Pravidlo</th>
                            {% for player in players %}
                                {% set isMineHeader = player.id == currentUserId %}
                                <th style="text-align:center;font-weight:600{% if isMineHeader %};color:var(--accent);background:color-mix(in oklab, var(--accent) 8%, var(--bg-3)){% endif %}">
                                    <div class="flex flex-col items-center gap-1">
                                        {{ m.avatar(player.username, 'sm') }}
                                        <span>{{ player.username }}</span>
                                    </div>
                                    {% if isMineHeader %}<span style="font-size:10px;font-weight:400;opacity:0.6">(ty)</span>{% endif %}
                                </th>
                            {% endfor %}
                            {% if tournament.status.value == 'finished' %}
                                <th style="text-align:center;color:var(--pos)">Skutečnost</th>
                            {% endif %}
                        </tr>
                    </thead>
                    <tbody>
                        {% set rowIndex = 0 %}
                        {% for groupKey, groupRules in groupedRules %}
                            <tr>
                                <td colspan="{{ colCount }}" style="{% if not loop.first %}border-top:2px solid var(--line);{% endif %}background:var(--bg);padding:6px 16px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--fg-4)">
                                    {{ groupLabels[groupKey] ?? groupKey }}
                                </td>
                            </tr>
                            {% set isSkupinaGroup = groupKey|slice(-2) in [':a', ':b', ':c', ':d', ':e', ':f'] %}
                            {% for rule in groupRules %}
                            {% set rowIndex = rowIndex + 1 %}
                            {% set isEven = rowIndex is even %}
                            <tr style="transition:background 0.12s{% if isEven %};background:color-mix(in oklab, var(--bg-3) 30%, transparent){% endif %}">
                                <td class="sticky left-0" style="width:11rem;max-width:11rem;z-index:5;background:var(--bg-2);border-right:1px solid var(--line);border-bottom:1px solid var(--line-soft);padding:12px 16px" title="{{ rule.name }}">
                                    <div class="truncate" style="font-weight:500;color:var(--fg)">{{ isSkupinaGroup ? rule.name|split(' - ')|last : rule.name }}</div>
                                    <div style="font-size:11px;color:var(--fg-4)">({{ rule.points }} b.)</div>
                                </td>
                                {% for player in players %}
                                    {% set bet = betsByRuleAndUser[rule.id][player.id] ?? null %}
                                    {% set earnedPoints = pointsByRuleAndUser[rule.id][player.id] ?? null %}
                                    {% set isFullScore = earnedPoints is not null and earnedPoints >= rule.points %}
                                    {% set isMine = player.id == currentUserId %}
                                    <td style="white-space:nowrap;padding:12px 16px;text-align:center;border-bottom:1px solid var(--line-soft){% if isFullScore %};background:color-mix(in oklab, var(--pos) 15%, transparent);border-left:2px solid var(--pos);border-right:2px solid var(--pos){% elseif isMine %};background:color-mix(in oklab, var(--accent) 6%, transparent){% endif %}{% if isMine %};font-weight:500{% endif %}">
                                        {% if bet %}
                                            <div style="{% if isFullScore %}font-weight:600;color:var(--fg){% elseif isMine %}color:var(--fg){% else %}color:var(--fg-2){% endif %}">
                                                {% if bet.teamValue %}
                                                    <span class="inline-flex items-center gap-1">{{ team_flag(bet.teamValue.code) }} {{ bet.teamValue.code }}</span>
                                                {% elseif bet.stringValue %}
                                                    {{ bet.stringValue }}
                                                {% elseif bet.intValue is not null %}
                                                    {{ bet.intValue }}
                                                {% endif %}
                                            </div>
                                            {% if earnedPoints is not null %}
                                                <div style="margin-top:2px;font-size:11px;font-family:var(--font-mono){% if isFullScore %};font-weight:600;color:var(--pos){% else %};color:var(--fg-4){% endif %}">
                                                    +{{ earnedPoints|number_format(0) }} b.
                                                </div>
                                            {% endif %}
                                        {% else %}
                                            <span style="color:var(--fg-4)">—</span>
                                        {% endif %}
                                    </td>
                                {% endfor %}
                                {% if tournament.status.value == 'finished' %}
                                    <td style="white-space:nowrap;padding:12px 16px;text-align:center;font-weight:600;color:var(--pos);border-bottom:1px solid var(--line-soft)">
                                        {% if rule.actualTeamValue %}
                                            <span class="inline-flex items-center gap-1">{{ team_flag(rule.actualTeamValue.code) }} {{ rule.actualTeamValue.code }}</span>
                                        {% elseif rule.actualStringValue %}
                                            {{ rule.actualStringValue }}
                                        {% elseif rule.actualIntValue is not null %}
                                            {{ rule.actualIntValue }}
                                        {% else %}
                                            <span style="color:var(--fg-4)">—</span>
                                        {% endif %}
                                    </td>
                                {% endif %}
                            </tr>
                            {% endfor %}
                        {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr style="border-top:2px solid var(--line);background:var(--bg-3)">
                            <td class="sticky left-0" style="background:var(--bg-3);padding:12px 16px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--fg-4);z-index:5">
                                Celkem
                            </td>
                            {% for player in players %}
                                {% set total = totalPointsPerPlayer[player.id] ?? 0 %}
                                {% set isMine = player.id == currentUserId %}
                                <td style="padding:12px 16px;text-align:center;font-size:14px;font-weight:700;font-family:var(--font-display){% if isMine %};color:var(--accent){% else %};color:var(--fg){% endif %}">
                                    {{ total|number_format(0) }} b.
                                </td>
                            {% endfor %}
                            {% if tournament.status.value == 'finished' %}
                                <td></td>
                            {% endif %}
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    {% endif %}
{% endblock %}
