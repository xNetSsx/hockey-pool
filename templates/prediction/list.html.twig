{% extends 'base.html.twig' %}
{% from '_macros.html.twig' import hp_prediction_badge_class %}

{% block title %}Moje tipy — Hockey Pool{% endblock %}

{% block body %}
    <div id="predictions-header" class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 style="font-family:var(--font-display);font-size:1.75rem;font-weight:800;letter-spacing:-0.02em;color:var(--fg)">Moje tipy</h1>
            <span class="hp-chip hp-chip-accent" style="margin-top:8px">{{ tournament.name }}</span>
        </div>
        <div class="flex gap-2">
            <a href="{{ path('special_bet_overview') }}"
               class="hp-btn hp-btn-primary hp-btn-sm">
                Speciální tipy
            </a>
        </div>
    </div>

    {% for phaseValue, games in groupedGames %}
        <div class="tour-phase mb-4 mt-8 first:mt-0">
            <h2 class="hp-chip hp-chip-accent" style="font-weight:600;text-transform:uppercase;letter-spacing:0.06em">
                {{ phaseValue|phase_label }}
            </h2>
        </div>

        <div class="hp-card mb-6">
            <div style="display:flex;flex-direction:column">
                {% set lastDate = null %}
                {% for game in games %}
                    {% set gameDate = game.playedAt|date('Y-m-d') %}
                    {% set prediction = userPredictions[game.id] ?? null %}
                    {% set locked = game.playedAt <= now %}

                    {# Date separator #}
                    {% if gameDate != lastDate %}
                        <div style="background:var(--bg-3);padding:6px 20px;border-bottom:1px solid var(--line-soft)">
                            <span class="hp-label">
                                {{ game.playedAt|date('d.m.Y') }}
                            </span>
                        </div>
                        {% set lastDate = gameDate %}
                    {% endif %}

                    <div class="tour-game-row flex items-center gap-3 sm:gap-4" style="padding:12px 16px;border-bottom:1px solid var(--line-soft);color:var(--fg){% if loop.last %};border-bottom:0{% endif %}">
                        {# Time #}
                        <div class="w-10 shrink-0 text-center sm:w-12" style="font-size:12px;color:var(--fg-4);font-family:var(--font-mono)">
                            {{ game.playedAt|date('H:i') }}
                        </div>

                        {# Teams + Score #}
                        <div class="flex min-w-0 flex-1 items-center gap-2 sm:gap-3">
                            <div class="flex w-20 items-center justify-end gap-1 text-sm sm:w-28">
                                <span class="truncate" style="font-weight:600;color:var(--fg)">{{ game.homeTeam.code }}</span>
                                <span>{{ team_flag(game.homeTeam.code) }}</span>
                            </div>

                            <div class="w-14 text-center sm:w-16">
                                {% if game.isFinished %}
                                    <span class="hp-score" style="font-size:14px;padding:2px 8px">
                                        {{ game.homeScore }}<span style="color:var(--fg-4)">:</span>{{ game.awayScore }}
                                    </span>
                                    {% if game.isTiebreaker %}
                                        <span style="display:block;margin-top:2px;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--warn)">remíza</span>
                                    {% endif %}
                                {% else %}
                                    <span style="font-size:12px;color:var(--fg-4)">vs</span>
                                {% endif %}
                            </div>

                            <div class="flex w-20 items-center gap-1 text-sm sm:w-28">
                                <span>{{ team_flag(game.awayTeam.code) }}</span>
                                <span class="truncate" style="font-weight:600;color:var(--fg)">{{ game.awayTeam.code }}</span>
                            </div>
                        </div>

                        {# Prediction + Action #}
                        <div class="tour-game-action flex shrink-0 items-center gap-2">
                            {% if not locked %}
                                {{ component('InlineTip', { gameId: game.id }) }}
                            {% else %}
                                {% if prediction %}
                                    <span class="{{ hp_prediction_badge_class(prediction, game) }}">
                                        {{ prediction.homeScore }}:{{ prediction.awayScore }}
                                    </span>
                                {% else %}
                                    <span style="padding:4px 10px;font-size:12px;border-radius:var(--radius-sm);background:var(--bg-3);color:var(--fg-4);border:1px solid var(--line)">&#128274;</span>
                                {% endif %}
                                <a href="{{ path('match_detail', {id: game.id}) }}"
                                   class="hp-btn hp-btn-ghost hp-btn-sm" style="padding:4px 10px;font-size:12px">
                                    Tipy hráčů
                                </a>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endfor %}

    {# Tailwind safelist: text-green-500 text-yellow-500 text-orange-500 text-red-500 text-red-600 animate-pulse #}
    <script>
        (function () {
            function updateCountdowns() {
                document.querySelectorAll('.countdown-timer').forEach(function (el) {
                    var deadline = new Date(el.dataset.deadline).getTime();
                    var now = Date.now();
                    var diff = deadline - now;

                    if (diff <= 0) {
                        el.textContent = '🔒';
                        el.className = 'text-[11px]';
                        return;
                    }

                    var days = Math.floor(diff / 86400000);
                    var hours = Math.floor((diff % 86400000) / 3600000);
                    var mins = Math.floor((diff % 3600000) / 60000);
                    var text, color;

                    if (days > 3) {
                        text = days + 'd';
                        color = 'text-green-500';
                    } else if (days > 0) {
                        text = days + 'd ' + hours + 'h';
                        color = 'text-yellow-500';
                    } else if (hours > 3) {
                        text = hours + 'h ' + mins + 'm';
                        color = 'text-orange-500';
                    } else if (hours > 0) {
                        text = hours + 'h ' + mins + 'm';
                        color = 'text-red-500';
                    } else {
                        text = mins + 'm';
                        color = 'text-red-600 animate-pulse';
                    }

                    el.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="inline h-3.5 w-3.5 ' + color + '" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><circle cx="12" cy="12" r="10"></circle><path stroke-linecap="round" d="M12 6v6l4 2"></path></svg><span class="font-medium text-gray-700 dark:text-gray-300">' + text + '</span>';
                    el.className = 'flex items-center gap-1 text-[11px] tabular-nums';
                });
            }

            updateCountdowns();
            setInterval(updateCountdowns, 60000);
        })();
    </script>
{% endblock %}
