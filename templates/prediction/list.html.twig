{% extends 'base.html.twig' %}
{% from '_macros.html.twig' import prediction_badge_class %}

{% block title %}Moje tipy — Hockey Pool{% endblock %}

{% block body %}
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">🎯 Moje tipy</h1>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{{ tournament.name }}</p>
        </div>
        <div class="flex gap-2">
            <a href="{{ path('prediction_special') }}"
               class="inline-flex items-center rounded-lg bg-[#0f172a] px-4 py-2 text-sm font-medium text-white hover:bg-[#1e293b]">
                Moje speciální tipy
            </a>
            <a href="{{ path('special_bet_overview') }}"
               class="inline-flex items-center rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-white/10">
                Tipy ostatních
            </a>
        </div>
    </div>

    {% for phaseValue, games in groupedGames %}
        <div class="mb-4 mt-8 first:mt-0">
            <h2 class="inline-block rounded-lg bg-[#0f172a] px-4 py-2 text-sm font-semibold uppercase tracking-wider text-white">
                {{ phaseValue|phase_label }}
            </h2>
        </div>

        <div class="mb-6 overflow-hidden rounded-xl bg-white shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
            <div class="divide-y divide-gray-100 dark:divide-gray-700">
                {% set lastDate = null %}
                {% for game in games %}
                    {% set gameDate = game.playedAt|date('Y-m-d') %}
                    {% set prediction = userPredictions[game.id] ?? null %}
                    {% set locked = game.playedAt <= now %}

                    {# Date separator #}
                    {% if gameDate != lastDate %}
                        <div class="bg-gray-50 px-6 py-2 dark:bg-[#0f172a]/50">
                            <span class="text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">
                                {{ game.playedAt|date('d.m.Y') }}
                            </span>
                        </div>
                        {% set lastDate = gameDate %}
                    {% endif %}

                    <div class="flex items-center gap-3 px-4 py-3 sm:gap-4 sm:px-6 dark:text-gray-100">
                        {# Time #}
                        <div class="w-10 shrink-0 text-center text-xs text-gray-400 sm:w-12 dark:text-gray-500">
                            {{ game.playedAt|date('H:i') }}
                        </div>

                        {# Teams + Score #}
                        <div class="flex min-w-0 flex-1 items-center gap-2 sm:gap-3">
                            <div class="flex w-20 items-center justify-end gap-1 text-sm sm:w-28">
                                <span class="truncate font-medium">{{ game.homeTeam.code }}</span>
                                <span>{{ team_flag(game.homeTeam.code) }}</span>
                            </div>

                            <div class="w-14 text-center sm:w-16">
                                {% if game.isFinished %}
                                    <span class="rounded bg-[#0f172a] px-2 py-0.5 text-xs font-bold tabular-nums text-white sm:text-sm">
                                        {{ game.homeScore }}:{{ game.awayScore }}
                                    </span>
                                {% else %}
                                    <span class="text-xs text-gray-400 dark:text-gray-500">vs</span>
                                {% endif %}
                            </div>

                            <div class="flex w-20 items-center gap-1 text-sm sm:w-28">
                                <span>{{ team_flag(game.awayTeam.code) }}</span>
                                <span class="truncate font-medium">{{ game.awayTeam.code }}</span>
                            </div>
                        </div>

                        {# Prediction + Action #}
                        <div class="flex shrink-0 items-center gap-2">
                            {% if prediction %}
                                <span class="inline-block rounded border px-2 py-0.5 text-xs font-medium tabular-nums {{ prediction_badge_class(prediction, game) }}">
                                    {{ prediction.homeScore }}:{{ prediction.awayScore }}
                                </span>
                            {% endif %}

                            {% if not locked %}
                                {% if not prediction %}
                                    <span class="countdown-timer flex items-center gap-1 text-[11px] tabular-nums" data-deadline="{{ game.playedAt|date('c') }}"></span>
                                {% endif %}
                                <a href="{{ path('prediction_edit', {id: game.id}) }}"
                                   class="rounded bg-[#0f172a] px-3 py-1 text-xs font-medium text-white hover:bg-[#1e293b] dark:bg-[#38bdf8] dark:text-[#0f172a] dark:hover:bg-[#7dd3fc]">
                                    {{ prediction ? 'Změnit' : 'Tipovat' }}
                                </a>
                            {% elseif not prediction %}
                                <span class="rounded bg-gray-100 px-3 py-1 text-xs text-gray-400 dark:bg-gray-700 dark:text-gray-500">🔒</span>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endfor %}

    {# Tailwind safelist: text-green-500 text-yellow-500 text-orange-500 text-red-500 text-red-600 animate-pulse #}
    <script>
        (function () {
            function updateCountdowns() {
                document.querySelectorAll('.countdown-timer').forEach(function (el) {
                    var deadline = new Date(el.dataset.deadline).getTime();
                    var now = Date.now();
                    var diff = deadline - now;

                    if (diff <= 0) {
                        el.textContent = '🔒';
                        el.className = 'text-[11px]';
                        return;
                    }

                    var days = Math.floor(diff / 86400000);
                    var hours = Math.floor((diff % 86400000) / 3600000);
                    var mins = Math.floor((diff % 3600000) / 60000);
                    var text, color;

                    if (days > 3) {
                        text = days + 'd';
                        color = 'text-green-500';
                    } else if (days > 0) {
                        text = days + 'd ' + hours + 'h';
                        color = 'text-yellow-500';
                    } else if (hours > 3) {
                        text = hours + 'h ' + mins + 'm';
                        color = 'text-orange-500';
                    } else if (hours > 0) {
                        text = hours + 'h ' + mins + 'm';
                        color = 'text-red-500';
                    } else {
                        text = mins + 'm';
                        color = 'text-red-600 animate-pulse';
                    }

                    el.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="inline h-3.5 w-3.5 ' + color + '" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><circle cx="12" cy="12" r="10"></circle><path stroke-linecap="round" d="M12 6v6l4 2"></path></svg><span class="font-medium text-gray-700 dark:text-gray-300">' + text + '</span>';
                    el.className = 'flex items-center gap-1 text-[11px] tabular-nums';
                });
            }

            updateCountdowns();
            setInterval(updateCountdowns, 60000);
        })();
    </script>
{% endblock %}
