{% extends 'base.html.twig' %}

{% block title %}Moje tipy — Hockey Pool{% endblock %}

{% block body %}
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">🎯 Moje tipy</h1>
            <p class="mt-1 text-sm text-gray-500">{{ tournament.name }}</p>
        </div>
        <a href="{{ path('prediction_special') }}"
           class="inline-flex items-center rounded-lg bg-[#0f172a] px-4 py-2 text-sm font-medium text-white hover:bg-[#1e293b]">
            ⭐ Speciální tipy
        </a>
    </div>

    {% for phaseValue, games in groupedGames %}
        <div class="mb-4 mt-8 first:mt-0">
            <h2 class="inline-block rounded-lg bg-[#0f172a] px-4 py-2 text-sm font-semibold uppercase tracking-wider text-white">
                {{ phaseValue|phase_label }}
            </h2>
        </div>

        <div class="mb-6 overflow-hidden rounded-xl bg-white shadow">
            <div class="divide-y divide-gray-100">
                {% set lastDate = null %}
                {% for game in games %}
                    {% set gameDate = game.playedAt|date('Y-m-d') %}
                    {% set prediction = userPredictions[game.id] ?? null %}
                    {% set locked = game.playedAt <= now %}

                    {# Date separator #}
                    {% if gameDate != lastDate %}
                        <div class="bg-gray-50 px-6 py-2">
                            <span class="text-xs font-medium uppercase tracking-wider text-gray-500">
                                {{ game.playedAt|date('d.m.Y') }}
                            </span>
                        </div>
                        {% set lastDate = gameDate %}
                    {% endif %}

                    <div class="flex items-center gap-3 px-4 py-3 sm:gap-4 sm:px-6">
                        {# Time #}
                        <div class="w-10 shrink-0 text-center text-xs text-gray-400 sm:w-12">
                            {{ game.playedAt|date('H:i') }}
                        </div>

                        {# Teams + Score #}
                        <div class="flex min-w-0 flex-1 items-center gap-2 sm:gap-3">
                            <div class="flex w-20 items-center justify-end gap-1 text-sm sm:w-28">
                                <span class="truncate font-medium">{{ game.homeTeam.code }}</span>
                                <span>{{ game.homeTeam.flagEmoji }}</span>
                            </div>

                            <div class="w-14 text-center sm:w-16">
                                {% if game.isFinished %}
                                    <span class="rounded bg-[#0f172a] px-2 py-0.5 text-xs font-bold tabular-nums text-white sm:text-sm">
                                        {{ game.homeScore }}:{{ game.awayScore }}
                                    </span>
                                {% else %}
                                    <span class="text-xs text-gray-400">vs</span>
                                {% endif %}
                            </div>

                            <div class="flex w-20 items-center gap-1 text-sm sm:w-28">
                                <span>{{ game.awayTeam.flagEmoji }}</span>
                                <span class="truncate font-medium">{{ game.awayTeam.code }}</span>
                            </div>
                        </div>

                        {# Prediction + Action #}
                        <div class="flex shrink-0 items-center gap-2">
                            {% if prediction %}
                                {% if game.isFinished %}
                                    {% if prediction.isExactScore(game) %}
                                        {% set badgeClass = 'bg-amber-100 text-amber-800 border-amber-300' %}
                                    {% elseif prediction.isCorrectWinner(game) %}
                                        {% set badgeClass = 'bg-green-100 text-green-800 border-green-300' %}
                                    {% else %}
                                        {% set badgeClass = 'bg-red-100 text-red-800 border-red-300' %}
                                    {% endif %}
                                {% else %}
                                    {% set badgeClass = 'bg-blue-50 text-blue-700 border-blue-200' %}
                                {% endif %}
                                <span class="inline-block rounded border px-2 py-0.5 text-xs font-medium tabular-nums {{ badgeClass }}">
                                    {{ prediction.homeScore }}:{{ prediction.awayScore }}
                                </span>
                            {% endif %}

                            {% if not locked %}
                                <a href="{{ path('prediction_edit', {id: game.id}) }}"
                                   class="rounded bg-blue-600 px-3 py-1 text-xs font-medium text-white hover:bg-blue-700">
                                    {{ prediction ? 'Změnit' : 'Tipovat' }}
                                </a>
                            {% elseif not prediction %}
                                <span class="rounded bg-gray-100 px-3 py-1 text-xs text-gray-400">🔒</span>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endfor %}
{% endblock %}
