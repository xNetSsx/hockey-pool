{% extends 'admin/layout.html.twig' %}

{% block title %}Týmy — Admin{% endblock %}

{% block admin_body %}
    <div class="mb-4 flex items-center justify-between">
        <h1 class="text-xl font-bold">Týmy</h1>
        <a href="{{ path('admin_team_new') }}" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">+ Nový</a>
    </div>

    <div class="overflow-hidden rounded-xl bg-white shadow">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b bg-gray-50 text-left text-xs uppercase tracking-wider text-gray-500">
                    <th class="px-6 py-3">Kód</th>
                    <th class="px-6 py-3">Název</th>
                    <th class="px-6 py-3">Vlajka</th>
                    <th class="px-6 py-3"></th>
                </tr>
            </thead>
            <tbody>
                {% for team in teams %}
                    <tr class="border-b border-gray-100 last:border-0">
                        <td class="px-6 py-3 font-mono font-medium">{{ team.code }}</td>
                        <td class="px-6 py-3">{{ team.name }}</td>
                        <td class="px-6 py-3 text-xl">{{ team.flagEmoji ?? '—' }}</td>
                        <td class="px-6 py-3 text-right">
                            <a href="{{ path('admin_team_edit', {id: team.id}) }}" class="text-blue-600 hover:underline">Upravit</a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
