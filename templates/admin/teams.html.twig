{% extends 'admin/layout.html.twig' %}

{% block title %}Týmy — Admin{% endblock %}

{% block admin_body %}
    <div class="mb-4 flex items-center justify-between">
        <h1 class="text-xl font-bold" style="color:var(--fg)">Týmy</h1>
        <a href="{{ path('admin_team_new') }}" class="hp-btn hp-btn-primary hp-btn-sm">+ Nový</a>
    </div>

    <div class="hp-card">
        <table class="hp-tbl">
            <thead>
                <tr>
                    <th>Kód</th>
                    <th>Název</th>
                    <th>Vlajka</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for team in teams %}
                    <tr>
                        <td class="font-mono font-medium" style="color:var(--fg)">{{ team.code }}</td>
                        <td style="color:var(--fg)">{{ team.name }}</td>
                        <td>{{ team_flag(team.code) ?: '—' }}</td>
                        <td class="text-right">
                            <a href="{{ path('admin_team_edit', {id: team.id}) }}" class="text-xs hover:underline" style="color:var(--accent)">Upravit</a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
