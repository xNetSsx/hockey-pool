{% extends 'admin/layout.html.twig' %}

{% block title %}Turnaje — Admin{% endblock %}

{% block admin_body %}
    <div class="mb-4 flex items-center justify-between">
        <h1 class="text-xl font-bold" style="color:var(--fg)">Turnaje</h1>
        <a href="{{ path('admin_tournament_new') }}" class="hp-btn hp-btn-primary hp-btn-sm">+ Nový turnaj</a>
    </div>

    {% if active|length > 0 %}
        <h2 class="hp-label mb-2 mt-6">Aktivní a nadcházející</h2>
        {{ _self.tournament_table(active, hasRuleSet, hasSpecialRules, cloneSources) }}
    {% endif %}

    {% if archived|length > 0 %}
        <h2 class="hp-label mb-2 mt-6">Archiv</h2>
        {{ _self.tournament_table(archived, hasRuleSet, hasSpecialRules, cloneSources) }}
    {% endif %}

    {% if active|length == 0 and archived|length == 0 %}
        <div class="hp-card p-8 text-center">
            <p style="color:var(--fg-3)">Žádné turnaje.</p>
        </div>
    {% endif %}
{% endblock %}

{% macro tournament_table(tournaments, hasRuleSet, hasSpecialRules, cloneSources) %}
    <div class="hp-card mb-6">
        <table class="hp-tbl">
            <tbody>
                {% for t in tournaments %}
                    <tr>
                        <td class="font-medium" style="color:var(--fg)">{{ t.name }}</td>
                        <td style="color:var(--fg-3)">{{ t.year }}</td>
                        <td>
                            {% if t.status.value == 'in_progress' %}
                                <span class="hp-chip" style="background:color-mix(in oklab,var(--pos) 15%,transparent);color:var(--pos);border-color:color-mix(in oklab,var(--pos) 30%,transparent)">Probíhá</span>
                            {% elseif t.status.value == 'finished' %}
                                <span class="hp-chip">Ukončen</span>
                            {% else %}
                                <span class="hp-chip hp-chip-accent">Nadcházející</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if hasRuleSet[t.id] %}
                                <span class="text-xs" style="color:var(--pos)">✓ Bodování</span>
                            {% endif %}
                            {% if hasSpecialRules[t.id] %}
                                <span class="ml-1 text-xs" style="color:var(--pos)">✓ Pravidla</span>
                            {% endif %}
                            {% if not hasRuleSet[t.id] and not hasSpecialRules[t.id] %}
                                <span class="text-xs" style="color:var(--warn)">⚠ Bez nastavení</span>
                            {% endif %}
                        </td>
                        <td class="text-right">
                            <div class="flex items-center justify-end gap-2">
                                {% if not hasRuleSet[t.id] and not hasSpecialRules[t.id] and cloneSources[t.id] is defined and cloneSources[t.id]|length > 0 %}
                                    <form method="post" action="{{ path('admin_tournament_clone', {id: t.id}) }}" class="flex items-center gap-1">
                                        <select name="sourceId" class="hp-field-input px-2 py-1 text-xs">
                                            {% for src in cloneSources[t.id] %}
                                                <option value="{{ src.id }}">{{ src.name }}</option>
                                            {% endfor %}
                                        </select>
                                        <button type="submit" class="hp-btn hp-btn-sm" style="background:var(--pos);color:var(--accent-ink)">
                                            Kopírovat
                                        </button>
                                    </form>
                                {% endif %}
                                <a href="{{ path('admin_tournament_content', {id: t.id, field: 'rules'}) }}" class="text-xs hover:underline" style="color:var(--fg-3)">Pravidla</a>
                                <a href="{{ path('admin_tournament_content', {id: t.id, field: 'manual'}) }}" class="text-xs hover:underline" style="color:var(--fg-3)">Manuál</a>
                                <a href="{{ path('admin_tournament_ruleset', {id: t.id}) }}" class="text-xs hover:underline" style="color:var(--fg-3)">Bodování</a>
                                <a href="{{ path('admin_tournament_payment', {id: t.id}) }}" class="text-xs hover:underline" style="color:var(--fg-3)">Platba</a>
                                <a href="{{ path('admin_tournament_edit', {id: t.id}) }}" class="text-xs hover:underline" style="color:var(--accent)">Upravit</a>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endmacro %}
