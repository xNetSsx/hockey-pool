{% extends 'admin/layout.html.twig' %}

{% block title %}Zápasy — Admin{% endblock %}

{% block admin_body %}
    <div class="mb-4 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <h1 class="text-xl font-bold" style="color:var(--fg)">Zápasy</h1>
        <div class="flex flex-wrap items-center gap-2">
            {% if tournament %}
                <a href="{{ path('admin_export_tournament', {id: tournament.id}) }}"
                   class="hp-btn hp-btn-sm" style="background:var(--pos);color:var(--accent-ink)">
                    ⬇ Export Excel
                </a>
            {% endif %}
            <a href="{{ path('admin_match_bulk') }}" class="hp-btn hp-btn-sm" style="background:var(--pos);color:var(--accent-ink)">+ Hromadně</a>
            <a href="{{ path('admin_match_new') }}" class="hp-btn hp-btn-primary hp-btn-sm">+ Nový zápas</a>
        </div>
    </div>

    {# Tournament filter #}
    {% if tournaments|length > 1 %}
        <div class="mb-6 flex flex-wrap items-center gap-2">
            <span class="text-sm" style="color:var(--fg-3)">Turnaj:</span>
            {% for t in tournaments %}
                <a href="{{ path('admin_matches', {tournament: t.id}) }}"
                   class="rounded-full px-3 py-1 text-sm transition-colors" style="{{ tournament and tournament.id == t.id ? 'background:var(--bg-3);color:var(--fg);border:1px solid var(--line)' : 'background:var(--bg-2);color:var(--fg-3);border:1px solid var(--line-soft)' }}">
                    {{ t.name }}
                </a>
            {% endfor %}
        </div>
    {% endif %}

    {% if not tournament %}
        <div class="hp-card p-8 text-center">
            <p style="color:var(--fg-3)">Žádný turnaj.</p>
        </div>
    {% elseif groupedGames|length == 0 %}
        <div class="hp-card p-8 text-center">
            <p style="color:var(--fg-3)">Zatím žádné zápasy v turnaji {{ tournament.name }}.</p>
        </div>
    {% else %}
        {% for phaseValue, games in groupedGames %}
            <details class="group mb-4" open>
                <summary class="mb-2 cursor-pointer list-none">
                    <div class="inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold uppercase tracking-wider" style="background:var(--bg-3);color:var(--fg);border:1px solid var(--line)">
                        <span class="text-xs transition group-open:rotate-90">▶</span>
                        {{ phaseValue|phase_label }}
                        <span class="hp-chip hp-chip-accent px-2 py-0.5 text-xs font-normal">{{ games|length }}</span>
                    </div>
                </summary>
                <div class="hp-card">
                    <table class="hp-tbl">
                        <tbody>
                            {% for game in games %}
                                <tr>
                                    <td class="w-28 text-xs" style="color:var(--fg-4)">{{ game.playedAt|date('d.m. H:i') }}</td>
                                    <td class="w-24 text-right" style="color:var(--fg)">{{ team_flag(game.homeTeam.code) }} {{ game.homeTeam.code }}</td>
                                    <td class="w-16 text-center">
                                        {% if game.isFinished %}
                                            <span class="font-bold tabular-nums" style="color:var(--fg)">{{ game.homeScore }}:{{ game.awayScore }}</span>
                                        {% else %}
                                            <span style="color:var(--fg-4)">vs</span>
                                        {% endif %}
                                    </td>
                                    <td class="w-24" style="color:var(--fg)">{{ team_flag(game.awayTeam.code) }} {{ game.awayTeam.code }}</td>
                                    <td class="space-x-2 text-right">
                                        <a href="{{ path('admin_match_edit', {id: game.id}) }}" class="text-xs hover:underline" style="color:var(--accent)">Upravit</a>
                                        <a href="{{ path('admin_match_result', {id: game.id}) }}"
                                           class="hp-btn hp-btn-primary hp-btn-sm"
                                           onclick="return confirm('Upravuješ výsledek zápasu, ne svůj tip. Pokračovat?')">
                                            {{ game.isFinished ? 'Změnit skóre' : 'Zadat skóre' }}
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </details>
        {% endfor %}
    {% endif %}
{% endblock %}
