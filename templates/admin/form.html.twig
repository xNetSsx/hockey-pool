{% extends 'admin/layout.html.twig' %}

{% block title %}{{ title }} — Admin{% endblock %}

{% set inputClass = 'w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20' %}

{% block admin_body %}
    <div class="mx-auto max-w-lg">
        <div class="mb-4">
            <a href="{{ path(back) }}" class="text-sm text-gray-500 hover:text-gray-700">← Zpět</a>
        </div>

        <div class="overflow-hidden rounded-xl bg-white shadow">
            <div class="border-b border-gray-200 bg-[#0f172a] px-6 py-4">
                <h1 class="text-lg font-semibold text-white">{{ title }}</h1>
            </div>
            <div class="p-6">
                {{ form_start(form, {attr: {class: 'space-y-4', novalidate: 'novalidate'}}) }}
                    {% for field in form %}
                        {% if field.vars.name not in ['_token', 'save'] %}
                            <div>
                                {{ form_label(field, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                                {{ form_widget(field, {attr: field.vars.attr|merge({class: (field.vars.attr.class ?? '') ~ ' ' ~ inputClass})}) }}
                                {{ form_errors(field) }}
                            </div>
                        {% endif %}
                    {% endfor %}
                    <div class="pt-4">
                        <button type="submit" class="w-full rounded-lg bg-blue-600 px-4 py-2.5 font-semibold text-white hover:bg-blue-700">
                            Uložit
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
