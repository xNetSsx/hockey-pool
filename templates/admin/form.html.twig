{% extends 'admin/layout.html.twig' %}

{% block title %}{{ title }} — Admin{% endblock %}

{% block admin_body %}
    <div class="mx-auto max-w-lg">
        <div class="mb-4">
            <a href="{{ path(back) }}" class="text-sm hover:underline" style="color:var(--fg-3)">← Zpět</a>
        </div>

        <div class="hp-card">
            <div class="hp-card-head">
                <h1 class="hp-card-title text-lg">{{ title }}</h1>
            </div>
            <div class="p-6">
                {{ form_start(form, {attr: {class: 'space-y-4', novalidate: 'novalidate'}}) }}
                    {% for field in form %}
                        {% if field.vars.name not in ['_token', 'save'] and 'button' not in field.vars.block_prefixes %}
                            <div>
                                {{ form_label(field, null, {label_attr: {class: 'hp-field-label mb-1 block'}}) }}
                                {{ form_widget(field, {attr: field.vars.attr|merge({class: (field.vars.attr.class ?? '') ~ ' hp-field-input w-full'})}) }}
                                {{ form_errors(field) }}
                            </div>
                        {% endif %}
                    {% endfor %}
                    <div class="pt-4">
                        <button type="submit" class="hp-btn hp-btn-primary w-full">
                            Uložit
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
