{% extends 'admin/layout.html.twig' %}

{% block title %}Výsledky speciálních tipů — Admin{% endblock %}

{% block admin_body %}
    <div class="mx-auto max-w-2xl">
        <h1 class="mb-4 text-xl font-bold" style="color:var(--fg)">Zadat výsledky — {{ tournament.name }}</h1>

        {% if tournaments|length > 1 %}
            <div class="mb-6 flex flex-wrap items-center gap-2">
                <span class="text-sm" style="color:var(--fg-3)">Turnaj:</span>
                {% for t in tournaments %}
                    <a href="{{ path('admin_special_results', {id: t.id}) }}"
                       class="rounded-full px-3 py-1 text-sm transition-colors" style="{{ tournament.id == t.id ? 'background:var(--bg-3);color:var(--fg);border:1px solid var(--line)' : 'background:var(--bg-2);color:var(--fg-3);border:1px solid var(--line-soft)' }}">
                        {{ t.name }}
                    </a>
                {% endfor %}
            </div>
        {% endif %}

        {% if rules|length == 0 %}
            <div class="hp-card p-8 text-center">
                <p style="color:var(--fg-3)">Žádná pravidla. Nejprve <a href="{{ path('admin_rules') }}" class="hover:underline" style="color:var(--accent)">vytvoř pravidla</a>.</p>
            </div>
        {% else %}
            <form method="post" action="{{ path('admin_special_results_save', {id: tournament.id}) }}" class="space-y-6">
                <input type="hidden" name="_token" value="{{ csrf_token('special_results') }}">

                <div class="hp-card">
                    <div class="hp-card-head">
                        <h2 class="hp-card-title">Skutečné výsledky</h2>
                    </div>
                    <div>
                        {% for rule in rules %}
                            <div class="px-6 py-4" style="{{ not loop.last ? 'border-bottom:1px solid var(--line-soft)' : '' }}">
                                <label for="rule_{{ rule.id }}" class="hp-field-label mb-1 block">
                                    {{ rule.name }}
                                    <span style="color:var(--fg-4)">({{ rule.valueType.label }}, {{ rule.points }} b.)</span>
                                </label>

                                {% if rule.valueType.value == 'team' %}
                                    <select name="rule_{{ rule.id }}" id="rule_{{ rule.id }}" class="hp-field-input w-full">
                                        <option value="">— Vyber tým —</option>
                                        {% for team in teams %}
                                            <option value="{{ team.id }}" {{ rule.actualTeamValue and rule.actualTeamValue.id == team.id ? 'selected' : '' }}>
                                                {{ team.name }} ({{ team.code }})
                                            </option>
                                        {% endfor %}
                                    </select>
                                {% elseif rule.valueType.value == 'string' %}
                                    <input type="text" name="rule_{{ rule.id }}" id="rule_{{ rule.id }}"
                                           value="{{ rule.actualStringValue }}"
                                           class="hp-field-input w-full">
                                {% elseif rule.valueType.value == 'integer' %}
                                    <input type="number" name="rule_{{ rule.id }}" id="rule_{{ rule.id }}"
                                           value="{{ rule.actualIntValue is not null ? rule.actualIntValue : '' }}"
                                           class="hp-field-input w-full" min="0">
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <div class="text-center">
                    <button type="submit" class="hp-btn hp-btn-primary">
                        Uložit a přepočítat speciální tipy
                    </button>
                </div>
            </form>
        {% endif %}
    </div>
{% endblock %}
