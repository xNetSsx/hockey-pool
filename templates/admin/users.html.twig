{% extends 'admin/layout.html.twig' %}

{% block title %}Uživatelé — Admin{% endblock %}

{% block admin_body %}
    <div class="mb-4 flex items-center justify-between">
        <h1 class="text-xl font-bold" style="color:var(--fg)">Uživatelé</h1>
        <a href="{{ path('admin_user_new') }}" class="hp-btn hp-btn-primary hp-btn-sm">+ Nový</a>
    </div>

    <div class="hp-card">
        <table class="hp-tbl">
            <thead>
                <tr>
                    <th>Jméno</th>
                    <th>Email</th>
                    <th>Admin</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for u in users %}
                    <tr>
                        <td class="font-medium" style="color:var(--fg)">{{ u.username }}</td>
                        <td style="color:var(--fg-3)">{{ u.email ?? '—' }}</td>
                        <td>
                            {% if 'ROLE_ADMIN' in u.roles %}
                                <span class="hp-chip" style="background:color-mix(in oklab,var(--neg) 15%,transparent);color:var(--neg);border-color:color-mix(in oklab,var(--neg) 30%,transparent)">Admin</span>
                            {% endif %}
                        </td>
                        <td class="text-right">
                            <a href="{{ path('admin_user_edit', {id: u.id}) }}" class="text-xs hover:underline" style="color:var(--accent)">Upravit</a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
