{% extends 'admin/layout.html.twig' %}

{% block title %}Uživatelé — Admin{% endblock %}

{% block admin_body %}
    <div class="mb-4 flex items-center justify-between">
        <h1 class="text-xl font-bold">Uživatelé</h1>
        <a href="{{ path('admin_user_new') }}" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">+ Nový</a>
    </div>

    <div class="overflow-hidden rounded-xl bg-white shadow">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b bg-gray-50 text-left text-xs uppercase tracking-wider text-gray-500">
                    <th class="px-6 py-3">Jméno</th>
                    <th class="px-6 py-3">Email</th>
                    <th class="px-6 py-3">Admin</th>
                    <th class="px-6 py-3"></th>
                </tr>
            </thead>
            <tbody>
                {% for u in users %}
                    <tr class="border-b border-gray-100 last:border-0">
                        <td class="px-6 py-3 font-medium">{{ u.username }}</td>
                        <td class="px-6 py-3 text-gray-500">{{ u.email ?? '—' }}</td>
                        <td class="px-6 py-3">
                            {% if 'ROLE_ADMIN' in u.roles %}
                                <span class="rounded bg-red-100 px-2 py-0.5 text-xs font-medium text-red-700">Admin</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-3 text-right">
                            <a href="{{ path('admin_user_edit', {id: u.id}) }}" class="text-blue-600 hover:underline">Upravit</a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
