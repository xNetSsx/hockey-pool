{% extends 'base.html.twig' %}

{% block body %}
    <div class="mb-6 flex flex-wrap items-center gap-3 rounded-xl px-6 py-4" style="background:var(--bg-3)">
        <span class="text-sm font-semibold" style="color:var(--fg)">Admin:</span>
        <a href="{{ path('admin_tournaments') }}" class="rounded-full px-3 py-1 text-sm transition-colors" style="color:var(--fg-2);{% if app.request.attributes.get('_route') starts with 'admin_tournament' %}background:var(--bg-2);border:1px solid var(--line){% endif %}">Turnaje</a>
        <a href="{{ path('admin_teams') }}" class="rounded-full px-3 py-1 text-sm transition-colors" style="color:var(--fg-2);{% if app.request.attributes.get('_route') starts with 'admin_team' %}background:var(--bg-2);border:1px solid var(--line){% endif %}">Týmy</a>
        <a href="{{ path('admin_users') }}" class="rounded-full px-3 py-1 text-sm transition-colors" style="color:var(--fg-2);{% if app.request.attributes.get('_route') starts with 'admin_user' %}background:var(--bg-2);border:1px solid var(--line){% endif %}">Uživatelé</a>
        <a href="{{ path('admin_matches') }}" class="rounded-full px-3 py-1 text-sm transition-colors" style="color:var(--fg-2);{% if app.request.attributes.get('_route') starts with 'admin_match' %}background:var(--bg-2);border:1px solid var(--line){% endif %}">Zápasy</a>
        <a href="{{ path('admin_rules') }}" class="rounded-full px-3 py-1 text-sm transition-colors" style="color:var(--fg-2);{% if app.request.attributes.get('_route') starts with 'admin_rule' %}background:var(--bg-2);border:1px solid var(--line){% endif %}">Pravidla tipů</a>
        <a href="{{ path('admin_special_results') }}" class="rounded-full px-3 py-1 text-sm transition-colors" style="color:var(--fg-2);{% if app.request.attributes.get('_route') starts with 'admin_special' %}background:var(--bg-2);border:1px solid var(--line){% endif %}">Výsledky</a>
        <a href="{{ path('admin_participants') }}" class="rounded-full px-3 py-1 text-sm transition-colors" style="color:var(--fg-2);{% if app.request.attributes.get('_route') starts with 'admin_participant' %}background:var(--bg-2);border:1px solid var(--line){% endif %}">Účastníci</a>
        <div class="ml-auto flex items-center gap-2">
            <form method="post" action="{{ path('admin_fetch_results') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('fetch_results') }}">
                <button type="submit" class="hp-btn hp-btn-sm rounded-full font-medium" style="background:var(--accent);color:var(--accent-ink)">
                    📡 Aktualizovat výsledky
                </button>
            </form>
            <form method="post" action="{{ path('admin_recalculate') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('recalculate') }}">
                <button type="submit" class="hp-btn hp-btn-sm rounded-full font-medium" style="background:var(--warn);color:var(--accent-ink)" onclick="return confirm('Přepočítat všechny body?')">
                    🔄 Přepočítat body
                </button>
            </form>
        </div>
    </div>

    {% block admin_body %}{% endblock %}
{% endblock %}
