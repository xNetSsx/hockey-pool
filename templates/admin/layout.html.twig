{% extends 'base.html.twig' %}

{% block body %}
    <div class="mb-6 flex flex-wrap items-center gap-3 rounded-xl bg-[#0f172a] px-6 py-4">
        <span class="text-sm font-semibold text-white">Admin:</span>
        <a href="{{ path('admin_tournaments') }}" class="rounded px-3 py-1 text-sm text-gray-300 hover:bg-white/10 hover:text-white {{ app.request.attributes.get('_route') starts with 'admin_tournament' ? 'bg-white/10 text-white' : '' }}">Turnaje</a>
        <a href="{{ path('admin_teams') }}" class="rounded px-3 py-1 text-sm text-gray-300 hover:bg-white/10 hover:text-white {{ app.request.attributes.get('_route') starts with 'admin_team' ? 'bg-white/10 text-white' : '' }}">Týmy</a>
        <a href="{{ path('admin_users') }}" class="rounded px-3 py-1 text-sm text-gray-300 hover:bg-white/10 hover:text-white {{ app.request.attributes.get('_route') starts with 'admin_user' ? 'bg-white/10 text-white' : '' }}">Uživatelé</a>
        <a href="{{ path('admin_matches') }}" class="rounded px-3 py-1 text-sm text-gray-300 hover:bg-white/10 hover:text-white {{ app.request.attributes.get('_route') starts with 'admin_match' ? 'bg-white/10 text-white' : '' }}">Zápasy</a>
        <a href="{{ path('admin_rules') }}" class="rounded px-3 py-1 text-sm text-gray-300 hover:bg-white/10 hover:text-white {{ app.request.attributes.get('_route') starts with 'admin_rule' ? 'bg-white/10 text-white' : '' }}">Pravidla tipů</a>
        <a href="{{ path('admin_special_results') }}" class="rounded px-3 py-1 text-sm text-gray-300 hover:bg-white/10 hover:text-white {{ app.request.attributes.get('_route') == 'admin_special_results' ? 'bg-white/10 text-white' : '' }}">Výsledky</a>
        <form method="post" action="{{ path('admin_recalculate') }}" class="ml-auto">
            <input type="hidden" name="_token" value="{{ csrf_token('recalculate') }}">
            <button type="submit" class="rounded bg-amber-600 px-3 py-1 text-sm font-medium text-white hover:bg-amber-700 dark:bg-amber-500 dark:hover:bg-amber-600" onclick="return confirm('Přepočítat všechny body?')">
                🔄 Přepočítat body
            </button>
        </form>
    </div>

    {% block admin_body %}{% endblock %}
{% endblock %}
