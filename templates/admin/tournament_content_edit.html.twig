{% extends 'admin/layout.html.twig' %}

{% block title %}{{ title }} — {{ tournament.name }} — Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/trix@2/dist/trix.min.css">
    <style>
        trix-editor { min-height: 300px; }
        trix-toolbar .trix-button-group { border-color: var(--line); }
        trix-toolbar .trix-button { background: var(--bg-2); color: var(--fg-2); border-color: var(--line); }
        trix-toolbar .trix-button.trix-active { background: var(--bg-3); }
        trix-editor { background: var(--bg); color: var(--fg); border-color: var(--line); }
    </style>
{% endblock %}

{% block admin_body %}
    <div class="mx-auto max-w-3xl">
        <div class="mb-4">
            <a href="{{ path('admin_tournaments') }}" class="text-sm hover:underline" style="color:var(--fg-3)">&larr; Zpět na turnaje</a>
        </div>

        <h1 class="mb-6 text-xl font-bold" style="color:var(--fg)">{{ title }} — {{ tournament.name }}</h1>

        <form method="post" action="{{ path('admin_tournament_content_save', {id: tournament.id, field: field}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('tournament_content') }}">
            <input id="content-input" type="hidden" name="content" value="{{ content }}">

            <div class="hp-card mb-6">
                <trix-editor input="content-input" class="rounded-b-xl"></trix-editor>
            </div>

            <div class="flex items-center justify-between">
                <a href="{{ field == 'rules' ? path('rules_page') : path('manual_page') }}"
                   class="text-sm hover:underline" style="color:var(--fg-3)">
                    Zobrazit stránku
                </a>
                <button type="submit" class="hp-btn hp-btn-primary">
                    Uložit
                </button>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/trix@2/dist/trix.umd.min.js"></script>
{% endblock %}
