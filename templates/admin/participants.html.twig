{% extends 'admin/layout.html.twig' %}

{% block title %}Účastníci — {{ tournament.name }}{% endblock %}

{% block body %}
    {{ parent() }}

    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Účastníci — {{ tournament.name }}</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{{ participants|length }} hráčů</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
        {# Current participants #}
        <div class="overflow-hidden rounded-xl bg-white shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
            <div class="border-b border-gray-200 bg-[#0f172a] px-6 py-4 dark:border-gray-700">
                <h2 class="text-lg font-semibold text-white">Registrovaní hráči</h2>
            </div>
            {% if participants|length > 0 %}
                <div class="divide-y divide-gray-100 dark:divide-gray-700">
                    {% for p in participants %}
                        <div class="flex items-center justify-between px-6 py-3">
                            <div class="flex items-center gap-3">
                                <span class="text-sm font-medium text-gray-900 dark:text-white">{{ p.user.username }}</span>
                                {% if p.paid %}
                                    <span class="rounded bg-green-100 px-2 py-0.5 text-xs font-medium text-green-800 dark:bg-green-900/30 dark:text-green-300">Zaplaceno</span>
                                {% else %}
                                    <span class="rounded bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-800 dark:bg-amber-900/30 dark:text-amber-300">Nezaplaceno</span>
                                {% endif %}
                            </div>
                            <div class="flex items-center gap-2">
                                <form method="post" action="{{ path('admin_participant_toggle_paid', {id: p.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('participant_paid') }}">
                                    <button type="submit" class="rounded px-2 py-1 text-xs text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-white/10" title="{{ p.paid ? 'Označit jako nezaplacené' : 'Označit jako zaplacené' }}">
                                        {{ p.paid ? '❌' : '💰' }}
                                    </button>
                                </form>
                                <form method="post" action="{{ path('admin_participant_remove', {id: p.id}) }}" onsubmit="return confirm('Opravdu odebrat {{ p.user.username }}?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('participant_remove') }}">
                                    <button type="submit" class="rounded px-2 py-1 text-xs text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20">
                                        Odebrat
                                    </button>
                                </form>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="px-6 py-8 text-center text-sm text-gray-500 dark:text-gray-400">
                    Zatím žádní účastníci.
                </div>
            {% endif %}
        </div>

        {# Add participant #}
        {% if availableUsers|length > 0 %}
            <div class="overflow-hidden rounded-xl bg-white shadow dark:bg-[#1e293b] dark:shadow-gray-900/30">
                <div class="border-b border-gray-200 bg-[#0f172a] px-6 py-4 dark:border-gray-700">
                    <h2 class="text-lg font-semibold text-white">Přidat hráče</h2>
                </div>
                <form method="post" action="{{ path('admin_participant_add') }}" class="p-6">
                    <input type="hidden" name="_token" value="{{ csrf_token('participant_add') }}">
                    <div class="mb-4">
                        <select name="user_id" required
                                class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-gray-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20 dark:border-gray-600 dark:bg-[#0f172a] dark:text-white">
                            <option value="">— Vyber hráče —</option>
                            {% for user in availableUsers %}
                                <option value="{{ user.id }}">{{ user.username }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <button type="submit"
                            class="w-full rounded-lg bg-blue-600 px-4 py-2.5 font-semibold text-white hover:bg-blue-700 dark:bg-[#38bdf8] dark:text-[#0f172a] dark:hover:bg-[#7dd3fc]">
                        Přidat do turnaje
                    </button>
                </form>
            </div>
        {% endif %}
    </div>
{% endblock %}
