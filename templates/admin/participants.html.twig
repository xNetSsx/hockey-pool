{% extends 'admin/layout.html.twig' %}

{% block title %}Účastníci — {{ tournament.name }}{% endblock %}

{% block body %}
    {{ parent() }}

    <div class="mb-6">
        <h1 class="text-2xl font-bold" style="color:var(--fg)">Účastníci — {{ tournament.name }}</h1>
        <p class="mt-1 text-sm" style="color:var(--fg-3)">{{ participants|length }} hráčů</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
        {# Current participants #}
        <div class="hp-card">
            <div class="hp-card-head">
                <h2 class="hp-card-title text-lg">Registrovaní hráči</h2>
            </div>
            {% if participants|length > 0 %}
                <div>
                    {% for p in participants %}
                        <div class="flex items-center justify-between px-6 py-3" style="{{ not loop.last ? 'border-bottom:1px solid var(--line-soft)' : '' }}">
                            <div class="flex items-center gap-3">
                                <span class="text-sm font-medium" style="color:var(--fg)">{{ p.user.username }}</span>
                                {% if p.paid %}
                                    <span class="hp-chip" style="background:color-mix(in oklab,var(--pos) 15%,transparent);color:var(--pos);border-color:color-mix(in oklab,var(--pos) 30%,transparent)">Zaplaceno</span>
                                {% else %}
                                    <span class="hp-chip hp-chip-hot">Nezaplaceno</span>
                                {% endif %}
                            </div>
                            <div class="flex items-center gap-2">
                                <form method="post" action="{{ path('admin_participant_toggle_paid', {id: p.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('participant_paid') }}">
                                    <button type="submit" class="hp-btn hp-btn-sm rounded px-2 py-1 text-xs" title="{{ p.paid ? 'Označit jako nezaplacené' : 'Označit jako zaplacené' }}">
                                        {{ p.paid ? '❌' : '💰' }}
                                    </button>
                                </form>
                                <form method="post" action="{{ path('admin_participant_remove', {id: p.id}) }}" onsubmit="return confirm('Opravdu odebrat {{ p.user.username }}?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('participant_remove') }}">
                                    <button type="submit" class="hp-btn hp-btn-sm rounded px-2 py-1 text-xs" style="color:var(--neg)">
                                        Odebrat
                                    </button>
                                </form>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="px-6 py-8 text-center text-sm" style="color:var(--fg-3)">
                    Zatím žádní účastníci.
                </div>
            {% endif %}
        </div>

        {# Add participant #}
        {% if availableUsers|length > 0 %}
            <div class="hp-card">
                <div class="hp-card-head">
                    <h2 class="hp-card-title text-lg">Přidat hráče</h2>
                </div>
                <form method="post" action="{{ path('admin_participant_add') }}" class="p-6">
                    <input type="hidden" name="_token" value="{{ csrf_token('participant_add') }}">
                    <div class="mb-4">
                        <select name="user_id" required class="hp-field-input w-full">
                            <option value="">— Vyber hráče —</option>
                            {% for user in availableUsers %}
                                <option value="{{ user.id }}">{{ user.username }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <button type="submit" class="hp-btn hp-btn-primary w-full">
                        Přidat do turnaje
                    </button>
                </form>
            </div>
        {% endif %}
    </div>
{% endblock %}
