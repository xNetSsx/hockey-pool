{% extends 'admin/layout.html.twig' %}

{% block title %}Výsledek: {{ game.homeTeam.code }} vs {{ game.awayTeam.code }} — Admin{% endblock %}

{% block admin_body %}
    <div class="mx-auto max-w-lg">
        <div class="mb-4">
            <a href="{{ path('admin_matches') }}" class="text-sm hover:underline" style="color:var(--fg-3)">← Zpět na zápasy</a>
        </div>

        <div class="hp-card">
            <div class="hp-card-head flex-col items-start gap-1">
                <h1 class="hp-card-title text-lg">Zadat výsledek</h1>
                <p class="hp-card-sub">{{ game.playedAt|date('d.m.Y H:i') }}</p>
            </div>
            <div class="p-6">
                <div class="mb-6 flex items-center justify-center gap-6 text-center">
                    <div>
                        <div>{{ team_flag(game.homeTeam.code, 'inline-block h-8 w-12 rounded-sm') }}</div>
                        <div class="mt-1 text-sm font-bold" style="color:var(--fg)">{{ game.homeTeam.code }}</div>
                    </div>
                    <div class="text-xl font-bold" style="color:var(--fg-4)">vs</div>
                    <div>
                        <div>{{ team_flag(game.awayTeam.code, 'inline-block h-8 w-12 rounded-sm') }}</div>
                        <div class="mt-1 text-sm font-bold" style="color:var(--fg)">{{ game.awayTeam.code }}</div>
                    </div>
                </div>

                {{ form_start(form) }}
                    <div class="flex items-end justify-center gap-4">
                        <div class="text-center">
                            {{ form_label(form.homeScore, null, {label_attr: {class: 'hp-field-label mb-1 block'}}) }}
                            {{ form_widget(form.homeScore, {attr: {class: 'hp-field-input w-20 text-center text-lg font-bold'}}) }}
                        </div>
                        <div class="pb-2 text-xl font-bold" style="color:var(--fg-4)">:</div>
                        <div class="text-center">
                            {{ form_label(form.awayScore, null, {label_attr: {class: 'hp-field-label mb-1 block'}}) }}
                            {{ form_widget(form.awayScore, {attr: {class: 'hp-field-input w-20 text-center text-lg font-bold'}}) }}
                        </div>
                    </div>
                    <label class="mt-6 flex cursor-pointer items-center justify-between rounded-lg px-4 py-3" style="border:1px solid var(--line);background:var(--bg-3)">
                        <span class="text-sm font-medium" style="color:var(--fg-2)">Zápas skončil remízou</span>
                        {{ form_widget(form.isTiebreaker, {attr: {class: 'h-5 w-5 cursor-pointer rounded'}}) }}
                    </label>
                    <div class="mt-6 text-center">
                        {{ form_widget(form.save, {attr: {class: 'hp-btn hp-btn-primary'}}) }}
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
