{% extends 'admin/layout.html.twig' %}

{% block title %}Pravidla speciálních tipů — Admin{% endblock %}

{% block admin_body %}
    <div class="mb-4 flex items-center justify-between">
        <h1 class="text-xl font-bold" style="color:var(--fg)">Pravidla speciálních tipů{{ tournament ? ' — ' ~ tournament.name : '' }}</h1>
        <a href="{{ path('admin_rule_new') }}" class="hp-btn hp-btn-primary hp-btn-sm">+ Nové pravidlo</a>
    </div>

    {% if rules|length == 0 %}
        <div class="hp-card p-8 text-center">
            <p style="color:var(--fg-3)">Žádná pravidla. Přidej první pravidlo speciálního tipu.</p>
        </div>
    {% else %}
        <div class="hp-card">
            <table class="hp-tbl">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Název</th>
                        <th>Typ</th>
                        <th>Bodování</th>
                        <th>Body</th>
                        <th>Výsledek</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for rule in rules %}
                        <tr>
                            <td style="color:var(--fg-4)">{{ rule.sortOrder }}</td>
                            <td class="font-medium" style="color:var(--fg)">{{ rule.name }}</td>
                            <td style="color:var(--fg-3)">{{ rule.valueType.label }}</td>
                            <td class="text-xs" style="color:var(--fg-3)">{{ rule.scoringType.label }}</td>
                            <td class="font-semibold" style="color:var(--fg)">{{ rule.points }}</td>
                            <td>
                                {% if rule.hasActualValue %}
                                    <span class="hp-chip" style="background:color-mix(in oklab,var(--pos) 15%,transparent);color:var(--pos);border-color:color-mix(in oklab,var(--pos) 30%,transparent)">
                                        {% if rule.actualTeamValue %}{{ team_flag(rule.actualTeamValue.code) }} {{ rule.actualTeamValue.code }}{% endif %}
                                        {% if rule.actualStringValue %}{{ rule.actualStringValue }}{% endif %}
                                        {% if rule.actualIntValue is not null %}{{ rule.actualIntValue }}{% endif %}
                                    </span>
                                {% else %}
                                    <span class="text-xs" style="color:var(--fg-4)">—</span>
                                {% endif %}
                            </td>
                            <td class="text-right" style="display:flex;gap:12px;justify-content:flex-end;align-items:center">
                                <a href="{{ path('admin_rule_edit', {id: rule.id}) }}" class="text-xs hover:underline" style="color:var(--accent)">Upravit</a>
                                <form method="post" action="{{ path('admin_rule_delete', {id: rule.id}) }}" data-turbo-confirm="Opravdu smazat pravidlo „{{ rule.name }}"? Smažou se i všechny tipy hráčů na toto pravidlo.">
                                    <input type="hidden" name="_token" value="{{ csrf_token('rule_delete') }}">
                                    <button type="submit" class="text-xs hover:underline" style="color:var(--neg)">Smazat</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
