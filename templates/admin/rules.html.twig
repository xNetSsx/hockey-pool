{% extends 'admin/layout.html.twig' %}

{% block title %}Pravidla speciálních tipů — Admin{% endblock %}

{% block admin_body %}
    <div class="mb-4 flex items-center justify-between">
        <h1 class="text-xl font-bold">Pravidla speciálních tipů{{ tournament ? ' — ' ~ tournament.name : '' }}</h1>
        <a href="{{ path('admin_rule_new') }}" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">+ Nové pravidlo</a>
    </div>

    {% if rules|length == 0 %}
        <div class="rounded-xl bg-white p-8 text-center shadow">
            <p class="text-gray-500">Žádná pravidla. Přidej první pravidlo speciálního tipu.</p>
        </div>
    {% else %}
        <div class="overflow-hidden rounded-xl bg-white shadow">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b bg-gray-50 text-left text-xs uppercase tracking-wider text-gray-500">
                        <th class="px-6 py-3">#</th>
                        <th class="px-6 py-3">Název</th>
                        <th class="px-6 py-3">Typ</th>
                        <th class="px-6 py-3">Bodování</th>
                        <th class="px-6 py-3">Body</th>
                        <th class="px-6 py-3">Výsledek</th>
                        <th class="px-6 py-3"></th>
                    </tr>
                </thead>
                <tbody>
                    {% for rule in rules %}
                        <tr class="border-b border-gray-100 last:border-0">
                            <td class="px-6 py-3 text-gray-400">{{ rule.sortOrder }}</td>
                            <td class="px-6 py-3 font-medium">{{ rule.name }}</td>
                            <td class="px-6 py-3 text-gray-500">{{ rule.valueType.label }}</td>
                            <td class="px-6 py-3 text-gray-500 text-xs">{{ rule.scoringType.label }}</td>
                            <td class="px-6 py-3 font-semibold">{{ rule.points }}</td>
                            <td class="px-6 py-3">
                                {% if rule.hasActualValue %}
                                    <span class="rounded bg-green-100 px-2 py-0.5 text-xs text-green-800">
                                        {% if rule.actualTeamValue %}{{ rule.actualTeamValue.flagEmoji }} {{ rule.actualTeamValue.code }}{% endif %}
                                        {% if rule.actualStringValue %}{{ rule.actualStringValue }}{% endif %}
                                        {% if rule.actualIntValue is not null %}{{ rule.actualIntValue }}{% endif %}
                                    </span>
                                {% else %}
                                    <span class="text-xs text-gray-300">—</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-3 text-right">
                                <a href="{{ path('admin_rule_edit', {id: rule.id}) }}" class="text-blue-600 hover:underline text-xs">Upravit</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
