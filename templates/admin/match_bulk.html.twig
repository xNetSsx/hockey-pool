{% extends 'admin/layout.html.twig' %}

{% block title %}Hromadné přidání zápasů — Admin{% endblock %}

{% block admin_body %}
    <div class="mx-auto max-w-4xl">
        <div class="mb-4">
            <a href="{{ path('admin_matches') }}" class="text-sm hover:underline" style="color:var(--fg-3)">← Zpět na zápasy</a>
        </div>

        <div class="hp-card">
            <div class="hp-card-head flex-col items-start gap-1">
                <h1 class="hp-card-title text-lg">Hromadné přidání zápasů</h1>
                <p class="hp-card-sub">Vyber turnaj a fázi, pak přidej zápasy</p>
            </div>

            <div class="p-6">
                {{ form_start(form, {attr: {class: 'space-y-6', novalidate: 'novalidate', id: 'bulk-form'}}) }}

                    {# Tournament + Phase #}
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            {{ form_label(form.tournament, null, {label_attr: {class: 'hp-field-label mb-1 block'}}) }}
                            {{ form_widget(form.tournament, {attr: {class: 'hp-field-input w-full'}}) }}
                        </div>
                        <div>
                            {{ form_label(form.phase, null, {label_attr: {class: 'hp-field-label mb-1 block'}}) }}
                            {{ form_widget(form.phase, {attr: {class: 'hp-field-input w-full'}}) }}
                        </div>
                    </div>

                    {# Games rows #}
                    <div>
                        <div class="mb-2 flex items-center justify-between">
                            <label class="hp-field-label">Zápasy</label>
                            <button type="button" id="add-row"
                                    class="hp-btn hp-btn-sm" style="background:var(--pos);color:var(--accent-ink)">
                                + Přidat řádek
                            </button>
                        </div>

                        <div id="games-container" class="space-y-3"
                             data-prototype="{{ form_widget(form.games.vars.prototype)|e('html_attr') }}"
                             data-index="{{ form.games|length }}">
                            {% for row in form.games %}
                                <div class="game-row flex items-end gap-3 rounded-lg p-3" style="background:var(--bg-3);border:1px solid var(--line)">
                                    <div class="flex-1">
                                        {{ form_label(row.homeTeam, null, {label_attr: {class: 'hp-field-label mb-1 block'}}) }}
                                        {{ form_widget(row.homeTeam, {attr: {class: 'hp-field-input w-full'}}) }}
                                    </div>
                                    <span class="pb-2 text-sm font-bold" style="color:var(--fg-4)">vs</span>
                                    <div class="flex-1">
                                        {{ form_label(row.awayTeam, null, {label_attr: {class: 'hp-field-label mb-1 block'}}) }}
                                        {{ form_widget(row.awayTeam, {attr: {class: 'hp-field-input w-full'}}) }}
                                    </div>
                                    <div class="w-48">
                                        {{ form_label(row.playedAt, null, {label_attr: {class: 'hp-field-label mb-1 block'}}) }}
                                        {{ form_widget(row.playedAt, {attr: {class: 'hp-field-input w-full'}}) }}
                                    </div>
                                    <button type="button" class="remove-row pb-2 hover:opacity-80" style="color:var(--neg)" title="Odebrat">✕</button>
                                </div>
                            {% endfor %}
                        </div>
                    </div>

                    <div class="text-center">
                        <button type="submit" class="hp-btn hp-btn-primary">
                            Vytvořit zápasy
                        </button>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>

    <script>
        (function () {
            const container = document.getElementById('games-container');
            const addBtn = document.getElementById('add-row');
            let index = parseInt(container.dataset.index);

            addBtn.addEventListener('click', function () {
                const prototype = container.dataset.prototype;
                const html = prototype.replace(/__name__/g, index);
                index++;
                container.dataset.index = index;

                const wrapper = document.createElement('div');
                wrapper.className = 'game-row flex items-end gap-3 rounded-lg p-3';
                wrapper.style.cssText = 'background:var(--bg-3);border:1px solid var(--line)';
                wrapper.innerHTML = html + '<button type="button" class="remove-row pb-2 hover:opacity-80" style="color:var(--neg)" title="Odebrat">✕</button>';

                // Style the generated inputs
                wrapper.querySelectorAll('select, input').forEach(function (el) {
                    el.className = 'hp-field-input w-full';
                });
                wrapper.querySelectorAll('label').forEach(function (el) {
                    el.className = 'hp-field-label mb-1 block';
                });

                // Wrap fields in flex-1 divs
                const fields = wrapper.querySelectorAll('div');
                fields.forEach(function (field) {
                    field.className = 'flex-1';
                });

                container.appendChild(wrapper);
            });

            container.addEventListener('click', function (e) {
                if (e.target.classList.contains('remove-row')) {
                    e.target.closest('.game-row').remove();
                }
            });
        })();
    </script>
{% endblock %}
