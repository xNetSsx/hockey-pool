{% extends 'base.html.twig' %}
{% import '_macros.html.twig' as m %}

{% block title %}Přihlášení — Hockey Pool{% endblock %}

{% block body %}
    <div style="min-height:calc(100vh - 160px);display:grid;place-items:center;padding:40px 0">
        <div style="display:grid;grid-template-columns:1.1fr 1fr;gap:40px;align-items:center;max-width:1000px;width:100%">

            {# ── Left: Hero text ── #}
            <div class="hidden md:block">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px">
                    {{ m.brand_mark() }}
                    <span style="font-weight:800;letter-spacing:-0.01em;font-size:22px;color:var(--fg)">Hockey Pool</span>
                </div>
                <h1 style="font-family:var(--font-display);font-size:72px;line-height:0.95;letter-spacing:-0.02em;font-weight:800;margin:8px 0 14px;color:var(--fg)">
                    TIPUJ S PARTOU.<br>VYHRAJ SEZÓNU.
                </h1>
                <p style="font-size:16px;color:var(--fg-3);line-height:1.55;max-width:460px;margin-bottom:22px">
                    Tipovací liga pro partu přátel. Mistrovství světa, olympiády, playoffs — hraj přes celou sezónu a uháněj Síní slávy.
                </p>
                <div style="display:flex;gap:24px;flex-wrap:wrap">
                    <div>
                        <div class="hp-stat-big-value">12</div>
                        <div class="hp-stat-big-label">hráčů</div>
                    </div>
                    <div>
                        <div class="hp-stat-big-value">6</div>
                        <div class="hp-stat-big-label">turnajů v archivu</div>
                    </div>
                    <div>
                        <div class="hp-stat-big-value">64</div>
                        <div class="hp-stat-big-label">zápasů letos</div>
                    </div>
                </div>
            </div>

            {# ── Right: Login card ── #}
            <div class="hp-card" style="padding:32px">
                {# Mobile-only brand (hidden on desktop where hero shows it) #}
                <div class="md:hidden" style="display:flex;align-items:center;gap:10px;margin-bottom:16px">
                    {{ m.brand_mark() }}
                    <span style="font-weight:800;font-size:20px;color:var(--fg)">Hockey Pool</span>
                </div>

                <h2 style="font-size:22px;font-weight:800;margin:0 0 6px;color:var(--fg)">Přihlášení</h2>
                <p style="font-size:13px;color:var(--fg-3);margin:0 0 22px">Přihlas se svým uživatelským jménem</p>

                {% if error %}
                    <div class="hp-alert hp-alert-error">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="post" data-turbo="false">
                    <div style="display:flex;flex-direction:column;gap:14px">
                        <div class="hp-field">
                            <label for="username" class="hp-field-label">Uživatelské jméno</label>
                            <input
                                type="text"
                                id="username"
                                name="_username"
                                value="{{ last_username }}"
                                required
                                autofocus
                                autocomplete="username"
                                class="hp-field-input"
                                placeholder="např. Ondra"
                            >
                        </div>

                        <div class="hp-field">
                            <label for="password" class="hp-field-label">Heslo</label>
                            <input
                                type="password"
                                id="password"
                                name="_password"
                                required
                                autocomplete="current-password"
                                class="hp-field-input"
                            >
                        </div>

                        <div style="display:flex;align-items:center;gap:8px">
                            <input
                                type="checkbox"
                                id="remember_me"
                                name="_remember_me"
                                style="accent-color:var(--accent);width:16px;height:16px"
                            >
                            <label for="remember_me" style="font-size:13px;color:var(--fg-3)">Zapamatovat si mě</label>
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <button type="submit" class="hp-btn hp-btn-primary" style="margin-top:6px;padding:12px 18px;width:100%">
                            Přihlásit se
                        </button>

                        <div style="font-size:12px;color:var(--fg-3);text-align:center;margin-top:6px">
                            Nemáš účet? Napiš Honzovi.
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# Stack to single column on mobile #}
    <style>
        @media (max-width: 767px) {
            div[style*="grid-template-columns:1.1fr"] {
                grid-template-columns: 1fr !important;
            }
        }
    </style>
{% endblock %}
