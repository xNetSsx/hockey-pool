{% extends 'base.html.twig' %}

{% block title %}Přihlášení — Hockey Pool{% endblock %}

{% block body %}
    <div class="flex min-h-[70vh] items-center justify-center">
        <div class="w-full max-w-md px-4">
            <div class="rounded-2xl bg-white p-8 shadow-lg dark:bg-[#1e293b]">
                <div class="mb-6 text-center">
                    <div class="mb-2 text-5xl">🏒</div>
                    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Hockey Pool</h1>
                    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Přihlas se a tipuj</p>
                </div>

                {% if error %}
                    <div class="mb-4 rounded-md bg-red-50 p-3 text-sm text-red-800 dark:bg-red-900/30 dark:text-red-300">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="post">
                    <div class="mb-4">
                        <label for="username" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">
                            Uživatelské jméno
                        </label>
                        <input
                            type="text"
                            id="username"
                            name="_username"
                            value="{{ last_username }}"
                            required
                            autofocus
                            autocomplete="username"
                            class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-gray-900 placeholder-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20 dark:border-gray-600 dark:bg-[#0f172a] dark:text-white dark:placeholder-gray-500 dark:focus:border-[#38bdf8]"
                            placeholder="např. Ondra"
                        >
                    </div>

                    <div class="mb-4">
                        <label for="password" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">
                            Heslo
                        </label>
                        <input
                            type="password"
                            id="password"
                            name="_password"
                            required
                            autocomplete="current-password"
                            class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-gray-900 placeholder-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20 dark:border-gray-600 dark:bg-[#0f172a] dark:text-white dark:placeholder-gray-500 dark:focus:border-[#38bdf8]"
                        >
                    </div>

                    <div class="mb-6 flex items-center">
                        <input
                            type="checkbox"
                            id="remember_me"
                            name="_remember_me"
                            class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500 dark:border-gray-600 dark:bg-[#0f172a]"
                        >
                        <label for="remember_me" class="ml-2 text-sm text-gray-600 dark:text-gray-400">
                            Zapamatovat si mě
                        </label>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button
                        type="submit"
                        class="w-full rounded-lg bg-blue-600 px-4 py-2.5 font-semibold text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:bg-[#38bdf8] dark:text-[#0f172a] dark:hover:bg-[#7dd3fc]"
                    >
                        Přihlásit se
                    </button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
